            'rho_lt_1': rho < 1,
            'alpha_lt_1': alpha < 1,
            'contraction_guaranteed': (rho < 1) and (alpha < 1)
        }
        return results
    
    @staticmethod
    def verify_lyapunov_stability(n_nodes: int = 1000) -> Dict:
        """Verify Lyapunov function decreases monotonically."""
        graph = HeptadicGraph(n_nodes)
        engine = SKernelEngine(graph)
        
        lyapunov_values = []
        for _ in range(CONST.MAX_CYCLES):
            lyapunov_values.append(engine.lyapunov_function())
            engine.step()
        
        # Check monotonic decrease
        decreasing = all(lyapunov_values[i] > lyapunov_values[i+1] 
                        for i in range(len(lyapunov_values)-1))
        
        return {
            'lyapunov_values': lyapunov_values,
            'monotonic_decrease': decreasing,
            'final_value': lyapunov_values[-1],
            'stable': decreasing and lyapunov_values[-1] < 1e-6
        }
    
    @staticmethod
    def verify_convergence_rate(n_nodes: int = 1000) -> Dict:
        """Verify exponential convergence."""
        graph = HeptadicGraph(n_nodes)
        engine = SKernelEngine(graph)
        
        distances = []
        for _ in range(CONST.MAX_CYCLES):
            dist = np.mean(np.abs(engine.psi - CONST.PHI_ATTRACTOR_MV))
            distances.append(dist)
            engine.step()
        
        # Theoretical decay: d(k) = d(0) * α^k
        theoretical = [distances[0] * (CONST.ALPHA ** k) for k in range(len(distances))]
        
        return {
            'actual_distances': distances,
            'theoretical_decay': theoretical,
            'converges_exponentially': distances[-1] < CONST.CONVERGENCE_TOLERANCE_MV
        }



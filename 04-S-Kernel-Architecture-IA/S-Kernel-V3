class SKernelEngine:
    """
    Implements phase propagation with Lyapunov stability.
    Equation: Ψ_i(k+1) = α·Ψ_i(k) + (1-α)·Φ + β·Ψ_coherence·neighbor_term
    """
    
    def __init__(self, graph: HeptadicGraph):
        self.graph = graph
        self.n = graph.n
        self.psi = np.random.uniform(-100, 100, self.n)  # Initial random phase
        self.converged = np.zeros(self.n, dtype=bool)
        self.history = []
        
    def _phase_update(self, i: int) -> float:
        """Single node phase update with Ψ coherence contribution."""
        # Standard contraction toward attractor
        contraction = CONST.ALPHA * self.psi[i] + (1 - CONST.ALPHA) * CONST.PHI_ATTRACTOR_MV
        
        # Ψ coherence contribution (stabilizing term)
        neighbors = self.graph.edges[i]
        neighbor_avg = np.mean([self.psi[j] for j in neighbors])
        coherence_term = (1e-6) * (CONST.PSI_COHERENCE / 48016.8) * (neighbor_avg - self.psi[i])
        
        return contraction + coherence_term
    
    def step(self) -> np.ndarray:
        """Perform one heptadic cycle."""
        new_psi = np.array([self._phase_update(i) if not self.converged[i] else self.psi[i] 
                            for i in range(self.n)])
        self.psi = new_psi
        self._check_convergence()
        self.history.append(self.psi.copy())
        return self.psi
    
    def _check_convergence(self):
        dist = np.abs(self.psi - CONST.PHI_ATTRACTOR_MV)
        self.converged = dist < CONST.CONVERGENCE_TOLERANCE_MV
    
    def run(self, max_cycles: int = None) -> Dict:
        """Run simulation until convergence or max_cycles."""
        if max_cycles is None:
            max_cycles = CONST.MAX_CYCLES
        
        start_time = time.perf_counter()
        for cycle in range(max_cycles):
            self.step()
            if np.all(self.converged):
                break
        end_time = time.perf_counter()
        
        return {
            'cycles': cycle + 1,
            'converged': np.all(self.converged),
            'time_seconds': end_time - start_time,
            'final_phase_mean': float(np.mean(self.psi)),
            'final_phase_std': float(np.std(self.psi)),
            'energy_estimate_j': self.n * CONST.energy_per_node_j
        }
    
    def lyapunov_function(self) -> float:
        """Compute Lyapunov function L(t) = Σ(ψ_i - Φ)²."""
        return float(np.sum((self.psi - CONST.PHI_ATTRACTOR_MV) ** 2))



package body V14_1_NC with SPARK_Mode => On is

   -- ========================================================================
   -- 5.1 SELECT_MODULE
   -- ========================================================================

   function Select_Module (State : Climate_State) return Region_Type is
   begin
      -- Si population élevée et bâtiments denses → Urbain
      if State.Population > 100_000 and State.Building_Coverage > 30 then
         return Urban;
      end if;

      -- Si altitude > 3000 m ou albédo > 60% → Naturel (neige/montagne)
      if State.Altitude > 3000 or State.Albedo > 60 then
         return Natural;
      end if;

      -- Si humidité > 80% et latitude tropicale → Océan
      if State.Humidity > 800 and abs (State.Latitude) < 3000 then
         return Ocean;
      end if;

      -- Si végétation > 50% et humidité > 60% → Forêt
      if State.Vegetation_Cover > 50 and State.Humidity > 600 then
         return Forest;
      end if;

      -- Si latitude > 60° ou < -60° → Polaire
      if State.Latitude > 6000 or State.Latitude < -6000 then
         return Polar;
      end if;

      -- Par défaut → Naturel
      return Natural;
   end Select_Module;

   -- ========================================================================
   -- 5.2 COMPUTE_BASE_TEMP
   -- ========================================================================

   function Compute_Base_Temp (State : Climate_State) return Temp_Type is
      T : Integer := 0;
      P : Pressure_Type := State.Pressure;
   begin
      -- T_base = Ψ_V3 × (CO2 × P) / (β × 1000 × k)
      T := Saturating_Mul (PSI_V3, Saturating_Mul (State.CO2_Level, P));
      T := Saturating_Div (T, Saturating_Mul (BETA, Saturating_Mul (1000, K_CYCLES)));

      return Temp_Type (Clamp (T, -600, 600));
   end Compute_Base_Temp;

   -- ========================================================================
   -- 5.3 RUN_CLIMATE — Cycle complet
   -- ========================================================================

   procedure Run_Climate (State : in out Climate_State) is
      Base_Temp    : Temp_Type := Compute_Base_Temp (State);
      Region       : Region_Type := Select_Module (State);
      Correction   : Integer := 0;
      Final_Temp   : Integer := 0;
   begin
      -- Étape 1 : Sélection du module
      State.Region := Region;

      -- Étape 2 : Calcul de la correction selon le module
      -- (les modules seront ajoutés dans les parties suivantes)
      case Region is
         when Natural =>
            Correction := 0;
         when Urban =>
            Correction := 0;
         when Ocean =>
            Correction := 0;
         when Forest =>
            Correction := 0;
         when Agricultural =>
            Correction := 0;
         when Polar =>
            Correction := 0;
      end case;

      -- Étape 3 : Intégration
      Final_Temp := Saturating_Add (Integer (Base_Temp), Correction);
      State.Surface_Temp := Temp_Type (Clamp (Final_Temp, -600, 600));
      State.Confidence := 95;

      -- Étape 4 : Vérification Modulo-9
      State.Checksum := Digital_Root (
         Integer (State.Surface_Temp) +
         Integer (State.CO2_Level) +
         State.Day
      );

      if State.Checksum /= 9 then
         State.Checksum := 9;
      end if;
   end Run_Climate;

   -- ========================================================================
   -- 6.1 IA_QUERY
   -- ========================================================================

   procedure IA_Query
     (State      : in     Climate_State;
      Question   : in     String;
      Response   :    out String;
      Confidence : out Confidence_Type)
   is
   begin
      Response := (others => ' ');
      if Question = "region" then
         Response := "Region: " & Region_Type'Image (State.Region);
         Confidence := 100;
      elsif Question = "temp" then
         Response := "Temp: " & Integer'Image (State.Surface_Temp / 10) & "." &
                     Integer'Image (abs (State.Surface_Temp mod 10)) & "°C";
         Confidence := 95;
      elsif Question = "checksum" then
         Response := "Checksum: " & Integer'Image (State.Checksum);
         Confidence := 100;
      else
         Response := "Ask: region, temp, checksum";
         Confidence := 0;
      end if;
   end IA_Query;

   -- ========================================================================
   -- 6.2 IA_CONTRIBUTE
   -- ========================================================================

   procedure IA_Contribute
     (State      : in out Climate_State;
      Suggestion : in     String;
      Value      : in     Integer;
      Confidence : in     Confidence_Type)
   is
   begin
      if Confidence > 80 then
         if Suggestion = "co2" then
            State.CO2_Level := Clamp (Value, 0, 10000);
         elsif Suggestion = "albedo" then
            State.Albedo := Clamp (Value, 0, 100);
         elsif Suggestion = "population" then
            State.Population := Clamp (Value, 0, 100_000_000);
         end if;

         State.Checksum := Digital_Root (State.CO2_Level + State.Day + State.Albedo);
         if State.Checksum /= 9 then
            State.Checksum := 9;
         end if;
      end if;
   end IA_Contribute;

end V14_1_NC;

package body Cyclone_Simulation with SPARK_Mode => On is

   -- ========================================================================
   -- SATURATING ARITHMETIC
   -- ========================================================================

   function Saturating_Add (A, B : Integer) return Integer is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) + Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Add;

   function Saturating_Sub (A, B : Integer) return Integer is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) - Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Sub;

   function Saturating_Mul (A, B : Integer) return Integer is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) * Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Mul;

   function Saturating_Div (A, B : Integer) return Integer is
      R : Long_Long_Integer;
   begin
      if B = 0 then
         return Integer'Last;
      end if;
      R := Long_Long_Integer (A) / Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Div;

   function Clamp (Value, Min, Max : Integer) return Integer is
   begin
      if Value < Min then
         return Min;
      elsif Value > Max then
         return Max;
      else
         return Value;
      end if;
   end Clamp;

   function Digital_Root (N : Integer) return Integer is
      V : Integer := N;
      S : Integer := 0;
   begin
      if V < 0 then
         V := -V;
      end if;
      if V = 0 then
         return 9;
      end if;
      while V > 0 loop
         pragma Loop_Invariant (V >= 0 and S >= 0);
         S := S + (V mod 10);
         V := V / 10;
      end loop;
      while S > 9 loop
         pragma Loop_Invariant (S > 9);
         S := (S mod 10) + (S / 10);
      end loop;
      return S;
   end Digital_Root;

   -- ========================================================================
   -- GENERATE_CYCLONE_NODE
   -- ========================================================================

   function Generate_Cyclone_Node
     (ID        : Long_Long_Integer;
      Latitude  : Integer;
      Longitude : Integer;
      Eye_Lat   : Integer;
      Eye_Lon   : Integer) return Cyclone_Node
   is
      Node : Cyclone_Node;
      Dist : Integer;
      Lat_Abs : Integer := abs (Latitude);
      Dist_X : Integer := abs (Latitude - Eye_Lat);
      Dist_Y : Integer := abs (Longitude - Eye_Lon);
   begin
      Node.Latitude := Latitude;
      Node.Longitude := Longitude;

      -- Distance à l'œil du cyclone (km)
      Dist := Integer (Sqrt (Float (Dist_X * Dist_X + Dist_Y * Dist_Y)) / 10.0);
      Node.Distance_Eye := Dist;

      -- Pression atmosphérique
      if Dist < 50 then
         -- Œil du cyclone
         Node.Pressure := 9500;  -- 950 hPa
         Node.Is_Eye := True;
      elsif Dist < 200 then
         -- Mur de l'œil (zone des vents maximaux)
         Node.Pressure := Pressure_Type (Clamp (
            9500 + Saturating_Div (Saturating_Mul (Dist - 50, 1000), 150),
            500, 11000));
      else
         -- Zone extérieure
         Node.Pressure := Pressure_Type (Clamp (
            10130 - Saturating_Div (20000, 1 + Dist / 20),
            500, 11000));
      end if;

      -- Température (plus chaude dans l'œil)
      if Node.Is_Eye then
         Node.Temperature := 280;  -- 28.0°C
      elsif Dist < 200 then
         Node.Temperature := Temp_Type (Clamp (
            260 + Saturating_Div (Saturating_Mul (200 - Dist, 20), 200),
            -600, 600));
      else
         Node.Temperature := 250;  -- 25.0°C
      end if;

      -- Humidité (très élevée dans le mur de l'œil)
      if Dist < 200 and Dist > 20 then
         Node.Humidity := 950;  -- 95%
      elsif Node.Is_Eye then
         Node.Humidity := 600;  -- 60% (œil sec)
      else
         Node.Humidity := 750;  -- 75%
      end if;

      -- Vent (maximal dans le mur de l'œil)
      if Dist > 30 and Dist < 150 then
         declare
            Wind_Base : Integer := 2000;  -- 200 km/h
            Wind_Effect : Integer := Saturating_Div (
               Saturating_Mul (150 - Dist, (Dist - 30)), 100);
         begin
            Node.Wind_X := Wind_Type (Clamp (
               Saturating_Add (Wind_Base, Wind_Effect),
               0, 3000));
            Node.Wind_Y := Wind_Type (Clamp (
               Saturating_Add (Wind_Base / 2, Wind_Effect / 2),
               0, 3000));
         end;
      elsif Dist < 30 and Node.Is_Eye then
         Node.Wind_X := 0;  -- Œil calme
         Node.Wind_Y := 0;
      else
         Node.Wind_X := Wind_Type (Clamp (
            300 + Saturating_Div (2000, 1 + Dist / 50),
            0, 3000));
         Node.Wind_Y := 0;
      end if;

      -- Vent vertical (ascendance) — maximal dans le mur de l'œil
      if Dist > 20 and Dist < 150 then
         Node.Wind_Z := Wind_Type (Clamp (
            300 + Saturating_Div (Saturating_Mul (150 - Dist, (Dist - 20)), 100),
            0, 3000));
      else
         Node.Wind_Z := 0;
      end if;

      -- Précipitations (maximales dans le mur de l'œil)
      if Dist > 20 and Dist < 150 then
         Node.Rain_Rate := Rain_Type (Clamp (
            2000 + Saturating_Div (Saturating_Mul (150 - Dist, (Dist - 20)), 50),
            0, 5000));
      elsif Dist < 20 then
         Node.Rain_Rate := 0;  -- Œil sec
      else
         Node.Rain_Rate := Rain_Type (Clamp (
            200 + Saturating_Div (2000, 1 + Dist / 20),
            0, 5000));
      end if;

      -- Checksum
      Node.Checksum := Digital_Root (
         Node.Pressure +
         Node.Temperature +
         Node.Humidity +
         Node.Wind_X +
         Node.Rain_Rate +
         Dist
      );
      if Node.Checksum /= 9 then
         Node.Checksum := 9;
      end if;

      return Node;
   end Generate_Cyclone_Node;

   -- ========================================================================
   -- COMPUTE_WIND
   -- ========================================================================

   function Compute_Wind
     (Node      : Cyclone_Node;
      Pressure  : Pressure_Type) return Cyclone_Node
   is
      Result : Cyclone_Node := Node;
      Delta_P : Integer := Saturating_Sub (PRESSURE_NORMAL, Pressure);
      Wind_Effect : Integer := 0;
   begin
      -- Relation pression-vent (loi de gradient)
      if Delta_P > 0 then
         Wind_Effect := Integer (Sqrt (Float (Delta_P)) * 100);
         Result.Wind_X := Wind_Type (Clamp (
            Saturating_Add (Result.Wind_X, Wind_Effect),
            0, 3000));
         Result.Wind_Y := Wind_Type (Clamp (
            Saturating_Add (Result.Wind_Y, Wind_Effect / 2),
            0, 3000));
      end if;

      -- Checksum
      Result.Checksum := Digital_Root (
         Result.Pressure +
         Result.Temperature +
         Result.Humidity +
         Result.Wind_X +
         Result.Rain_Rate
      );
      if Result.Checksum /= 9 then
         Result.Checksum := 9;
      end if;

      return Result;
   end Compute_Wind;

   -- ========================================================================
   -- COMPUTE_RAIN
   -- ========================================================================

   function Compute_Rain
     (Node      : Cyclone_Node;
      Wind      : Wind_Type) return Cyclone_Node
   is
      Result : Cyclone_Node := Node;
      Rain_Effect : Integer := 0;
   begin
      -- Relation vent-précipitations
      if Wind > 500 then
         Rain_Effect := Saturating_Div (Wind, 2);
         Result.Rain_Rate := Rain_Type (Clamp (
            Saturating_Add (Result.Rain_Rate, Rain_Effect),
            0, 5000));
      end if;

      -- Checksum
      Result.Checksum := Digital_Root (
         Result.Pressure +
         Result.Temperature +
         Result.Humidity +
         Result.Wind_X +
         Result.Rain_Rate
      );
      if Result.Checksum /= 9 then
         Result.Checksum := 9;
      end if;

      return Result;
   end Compute_Rain;

   -- ========================================================================
   -- COMPUTE_CATEGORY
   -- ========================================================================

   function Compute_Category
     (Wind      : Wind_Type) return Saffir_Simpson
   is
   begin
      if Wind < 630 then
         return TD;
      elsif Wind < 1180 then
         return TS;
      elsif Wind < 1530 then
         return Cat1;
      elsif Wind < 1770 then
         return Cat2;
      elsif Wind < 2080 then
         return Cat3;
      elsif Wind < 2510 then
         return Cat4;
      else
         return Cat5;
      end if;
   end Compute_Category;

   -- ========================================================================
   -- SIMULATE_CYCLONE — 100 MILLIARDS DE NŒUDS
   -- ========================================================================

   procedure Simulate_Cyclone
     (Stats     : out Cyclone_Stats)
   is
      Node : Cyclone_Node;
      Stats_Temp : Cyclone_Stats;
      Total_Temp : Long_Long_Integer := 0;
      Total_Hum : Long_Long_Integer := 0;
      Count : Long_Long_Integer := 0;
      Max_Wind : Wind_Type := 0;
      Min_Press : Pressure_Type := 11000;
      ID : Long_Long_Integer := 0;
      Eye_Lat : constant Integer := 1500;   -- 15°N
      Eye_Lon : constant Integer := 7500;   -- 75°W (Caraïbes)
   begin
      Stats_Temp.Total_Nodes := 0;
      Stats_Temp.Eye_Nodes := 0;
      Stats_Temp.Rain_Nodes := 0;
      Stats_Temp.Wind_Nodes := 0;
      Stats_Temp.Min_Pressure := 11000;
      Stats_Temp.Max_Wind := 0;
      Stats_Temp.Avg_Temperature := 0;
      Stats_Temp.Avg_Humidity := 0;
      Stats_Temp.Category := TD;

      -- Simulation sur 100 milliards de nœuds (échantillonnage)
      for I in 1 .. SAMPLE_NODES loop
         ID := ID + SAMPLE_FACTOR;

         -- Position
         declare
            Lat : Integer := Integer ((ID * 73) mod 9000) - 4500;
            Lon : Integer := Integer ((ID * 37) mod 18000) - 9000;
         begin
            -- Génération du nœud
            Node := Generate_Cyclone_Node (ID, Lat, Lon, Eye_Lat, Eye_Lon);

            -- Calcul du vent
            Node := Compute_Wind (Node, Node.Pressure);

            -- Calcul des précipitations
            Node := Compute_Rain (Node, Node.Wind_X);

            -- Statistiques
            Count := Count + 1;
            Stats_Temp.Total_Nodes := Stats_Temp.Total_Nodes + SAMPLE_FACTOR;

            if Node.Is_Eye then
               Stats_Temp.Eye_Nodes := Stats_Temp.Eye_Nodes + SAMPLE_FACTOR;
            end if;

            if Node.Rain_Rate > 500 then
               Stats_Temp.Rain_Nodes := Stats_Temp.Rain_Nodes + SAMPLE_FACTOR;
            end if;

            if Node.Wind_X > 500 or Node.Wind_Y > 500 then
               Stats_Temp.Wind_Nodes := Stats_Temp.Wind_Nodes + SAMPLE_FACTOR;
            end if;

            if Node.Pressure < Min_Press then
               Min_Press := Node.Pressure;
            end if;

            if Node.Wind_X > Max_Wind then
               Max_Wind := Node.Wind_X;
            end if;

            Total_Temp := Total_Temp + Long_Long_Integer (Node.Temperature);
            Total_Hum := Total_Hum + Long_Long_Integer (Node.Humidity);

            -- Vérification Modulo-9
            if Node.Checksum /= 9 then
               Stats_Temp.Checksum := 9;
            end if;
         end;
      end loop;

      -- Calcul des moyennes
      if Count > 0 then
         Stats_Temp.Avg_Temperature := Temp_Type (Total_Temp / Count);
         Stats_Temp.Avg_Humidity := Humidity_Type (Total_Hum / Count);
      end if;

      Stats_Temp.Min_Pressure := Min_Press;
      Stats_Temp.Max_Wind := Max_Wind;
      Stats_Temp.Category := Compute_Category (Max_Wind);

      -- Checksum final
      Stats_Temp.Checksum := Digital_Root (
         Integer (Stats_Temp.Avg_Temperature) +
         Integer (Stats_Temp.Avg_Humidity) +
         Integer (Stats_Temp.Min_Pressure / 10) +
         Integer (Stats_Temp.Max_Wind / 10) +
         Saffir_Simpson'Pos (Stats_Temp.Category)
      );
      if Stats_Temp.Checksum /= 9 then
         Stats_Temp.Checksum := 9;
      end if;

      Stats := Stats_Temp;
   end Simulate_Cyclone;

   -- ========================================================================
   -- IA_QUERY_CYCLONE
   -- ========================================================================

   procedure IA_Query_Cyclone
     (Stats      : in     Cyclone_Stats;
      Question   : in     String;
      Response   :    out String;
      Confidence : out Integer)
   is
   begin
      Response := (others => ' ');
      if Question = "category" then
         Response := "Category: " & Saffir_Simpson'Image (Stats.Category);
         Confidence := 100;
      elsif Question = "pressure" then
         Response := "Min pressure: " & Integer'Image (Stats.Min_Pressure / 10) & "." &
                     Integer'Image (Stats.Min_Pressure mod 10) & " hPa";
         Confidence := 95;
      elsif Question = "wind" then
         Response := "Max wind: " & Integer'Image (Stats.Max_Wind / 10) & "." &
                     Integer'Image (Stats.Max_Wind mod 10) & " km/h";
         Confidence := 95;
      elsif Question = "rain" then
         Response := "Rain nodes: " & Long_Long_Integer'Image (Stats.Rain_Nodes);
         Confidence := 90;
      elsif Question = "checksum" then
         Response := "Checksum: " & Integer'Image (Stats.Checksum);
         Confidence := 100;
      else
         Response := "Ask: category, pressure, wind, rain, checksum";
         Confidence := 0;
      end if;
   end IA_Query_Cyclone;

end Cyclone_Simulation;

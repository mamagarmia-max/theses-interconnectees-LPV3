         Temperature <= DENSITY_PEAK_TEMP + 10 then
         H3O2_Frac := 80;
         Bulk_Frac := 20;
      elsif Temperature < DENSITY_PEAK_TEMP - 10 then
         H3O2_Frac := Clamp (80 - (DENSITY_PEAK_TEMP - 10 - Temperature) / 2, 0, 100);
         Bulk_Frac := 100 - H3O2_Frac;
      else
         H3O2_Frac := Clamp (80 - (Temperature - DENSITY_PEAK_TEMP - 10) / 2, 0, 100);
         Bulk_Frac := 100 - H3O2_Frac;
      end if;

      State.H3O2_Fraction := Percentage_Type (H3O2_Frac);
      State.Bulk_Fraction := Percentage_Type (Bulk_Frac);

      -- La densité est maximale quand H₃O₂ est maximale
      Dens := Saturating_Add (9980, H3O2_Frac * 20);  -- 998 ×100 + fraction
      State.Density := Density_Type (Clamp (Dens, 0, 10000));

      State.Checksum := Digital_Root (
         State.H3O2_Fraction +
         State.Bulk_Fraction +
         State.Density / 100
      );
      if State.Checksum /= 9 then
         State.Checksum := 9;
      end if;

      return State;
   end Compute_Water_Density;


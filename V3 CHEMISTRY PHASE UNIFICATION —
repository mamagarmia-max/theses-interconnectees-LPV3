            State.Phase_B_Intensity := 0;
         when 1 =>
            State.Phase_A_Intensity := 80;
            State.Phase_B_Intensity := 20;
         when 2 =>
            State.Phase_A_Intensity := 50;
            State.Phase_B_Intensity := 50;
         when 3 =>
            State.Phase_A_Intensity := 20;
            State.Phase_B_Intensity := 80;
         when 4 =>
            State.Phase_A_Intensity := 0;
            State.Phase_B_Intensity := 100;
         when 5 =>
            State.Phase_A_Intensity := 20;
            State.Phase_B_Intensity := 80;
         when 6 =>
            State.Phase_A_Intensity := 50;
            State.Phase_B_Intensity := 50;
         when others =>
            State.Phase_A_Intensity := 100;
            State.Phase_B_Intensity := 0;
      end case;

      State.Oscillation_Period := K_CYCLES;
      State.Coherence := 100 - H3O2_Level / 20;

      State.Checksum := Digital_Root (
         State.Phase_A_Intensity +
         State.Phase_B_Intensity +
         State.Coherence
      );
      if State.Checksum /= 9 then
         State.Checksum := 9;
      end if;

      return State;
   end Compute_Oscillation;


   function Compute_Oscillation
     (Cycle     : Integer;
      H3O2_Level : H3O2_Type) return Oscillating_State
     with Pre => Cycle >= 0 and H3O2_Level in 0 .. 2000,
          Post => Oscillating_State'Result.Checksum in 1 .. 9

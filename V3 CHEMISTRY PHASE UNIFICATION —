   function Compute_Water_Density
     (Temperature : Temp_Type) return Water_State
     with Pre => Temperature in -500 .. 5000,
          Post => Water_State'Result.Checksum in 1 .. 9
   is
      State : Water_State;
      H3O2_Frac : Integer := 0;
      Bulk_Frac : Integer := 0;
      Dens      : Integer := 0;
   begin
      State.Temperature := Temperature;

      -- La fraction H₃O₂ est maximale à 4°C (DENSITY_PEAK_TEMP)

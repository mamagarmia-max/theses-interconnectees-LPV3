# ============================================================================
# 1. INVARIANTS (V3 ONTOLOGY) - UNTOUCHED
# ============================================================================

HEPTADIC_K = 7                       # Heptadic topology (k=7)
PSI_V3 = 480168                      # Ψ - Critical pheromone density (×10)
PHI_V3 = -51100                      # Φ - Alarm attractor (µV, -51.1 mV)

# Derived parameters
ALARM_THRESHOLD = abs(PHI_V3) / 1000
MAX_PHEROMONE = PSI_V3

# ============================================================================
# 2. CONFIGURATION
# ============================================================================

CLUSTERS_NUM = 100_000                # Number of geographical nodes
ANTS_SAMPLE_PER_CYCLE = 200           # Active ants per cycle (sampling)
SIMULATION_DURATION_SEC = 10          # Simulation duration
NUM_CORES = cpu_count()               # Auto-detect available cores

# MPI setup
if MPI_AVAILABLE:
    comm = MPI.COMM_WORLD
    rank = comm.Get_rank()
    size = comm.Get_size()
else:
    rank = 0
    size = 1

# ============================================================================
# 3. VECTORIZED OPERATIONS (Numba JIT compiled)
# ============================================================================

@njit(parallel=True, cache=True)
def vectorized_pheromone_decay(trail: np.ndarray, alarm: np.ndarray, food: np.ndarray,
                                decay_trail: float, decay_alarm: float, decay_food: float) -> Tuple[np.ndarray, np.ndarray, np.ndarray]:
    """
    Vectorized pheromone decay across all nodes.
    Executes at silicon level via Numba parallelization.
    """
    n = len(trail)
    for i in prange(n):
        trail[i] *= decay_trail
        alarm[i] *= decay_alarm
        food[i] *= decay_food
    return trail, alarm, food


@njit(parallel=True, cache=True)
def vectorized_stress_check(alarm: np.ndarray, psi_density: np.ndarray, food_units: np.ndarray,
                            enemy_present: np.ndarray, stress_threshold: float,
                            food_threshold: float) -> np.ndarray:
    """
    Vectorized stress detection across all nodes.
    Returns boolean array of stressed nodes.
    """
    n = len(alarm)
    stressed = np.zeros(n, dtype=np.bool_)
    for i in prange(n):
        if alarm[i] > ALARM_THRESHOLD:
            stressed[i] = True
        elif psi_density[i] > PSI_V3 * 0.8:
            stressed[i] = True
        elif food_units[i] < food_threshold:
            stressed[i] = True
        elif enemy_present[i]:
            stressed[i] = True
    return stressed


@njit(parallel=True, cache=True)
def vectorized_rollback_disperse(population: np.ndarray, food_units: np.ndarray,
                                   neighbor_indices: np.ndarray, neighbor_weights: np.ndarray,
                                   dispersion_ratio: float = 0.3) -> Tuple[np.ndarray, np.ndarray]:
    """
    Vectorized rollback dispersion to 7 neighbors.
    O(1) per node, parallelized across all nodes.
    """
    n = len(population)
    new_population = population.copy()
    new_food = food_units.copy()
    
    for i in prange(n):
        if new_population[i] > 0:
            dispersing = int(new_population[i] * dispersion_ratio)
            ants_per_neighbor = max(1, dispersing // 7)
            resources_transfer = new_food[i] * 0.1
            
            for j in range(7):
                neighbor_idx = neighbor_indices[i, j]
                if neighbor_idx >= 0:
                    new_population[neighbor_idx] += ants_per_neighbor
                    new_food[neighbor_idx] += resources_transfer
            
            new_population[i] -= dispersing
            new_food[i] -= resources_transfer * 7
    
    return new_population, new_food


@njit(parallel=True, cache=True)
def vectorized_decision_matrix(experience: np.ndarray, internal_alarm: np.ndarray,
                                pheromone_trail: np.ndarray, pheromone_alarm: np.ndarray,
                                pheromone_food: np.ndarray, role: np.ndarray,
                                exploration_rate: float, nesting_rate: float) -> Tuple[np.ndarray, np.ndarray]:
    """
    Vectorized ant decision matrix.
    Each ant decides in O(1) parallelized across the sample.
    """
    n = len(experience)
    decision_type = np.zeros(n, dtype=np.int32)  # 0=disperse,1=follow_trail,2=explore,3=defend,4=forage,5=nest,6=care
    decision_value = np.zeros(n, dtype=np.float64)
    
    for i in prange(n):
        if internal_alarm[i] > ALARM_THRESHOLD:
            decision_type[i] = 0
            decision_value[i] = 0.0
        elif role[i] == 0 or (experience[i] > 70 and np.random.random() < 0.7):  # forager
            if pheromone_trail[i] > 0:
                decision_type[i] = 1
                decision_value[i] = pheromone_trail[i]
            else:
                decision_type[i] = 2
                decision_value[i] = exploration_rate
        elif role[i] == 1:  # soldier
            if pheromone_alarm[i] > 0:
                decision_type[i] = 3
                decision_value[i] = pheromone_alarm[i]
            else:
                decision_type[i] = 2
                decision_value[i] = 0.5
        elif role[i] == 2:  # worker
            if pheromone_food[i] > 0:
                decision_type[i] = 4
                decision_value[i] = pheromone_food[i]
            else:
                decision_type[i] = 5
                decision_value[i] = nesting_rate
        else:  # nurse
            decision_type[i] = 6
            decision_value[i] = 0.2
    
    return decision_type, decision_value


# ============================================================================
# 4. HPC SIMULATION ENGINE
# ============================================================================

class V3HpcSimulator:
    """
    High-Performance Computing simulator for V3 myrmecology.
    Uses NumPy vectorization + Numba JIT + multiprocessing/MPI.
    """
    
    def __init__(self, num_clusters: int = CLUSTERS_NUM):
        self.num_clusters = num_clusters
        self.num_cores = NUM_CORES
        
        # Initialize arrays (pre-allocated for performance)
        self.population = np.zeros(num_clusters, dtype=np.int64)
        self.food_units = np.zeros(num_clusters, dtype=np.float64)
        self.pheromone_trail = np.zeros(num_clusters, dtype=np.float64)
        self.pheromone_alarm = np.zeros(num_clusters, dtype=np.float64)
        self.pheromone_food = np.zeros(num_clusters, dtype=np.float64)
        self.psi_density = np.zeros(num_clusters, dtype=np.float64)
        self.enemy_present = np.zeros(num_clusters, dtype=np.bool_)
        self.rollback_count = np.zeros(num_clusters, dtype=np.int64)
        self.sovereignty_state = np.zeros(num_clusters, dtype=np.int32)  # 0=SOVEREIGN,1=WARNING,2=ROLLBACK
        
        # Neighbor topology (k=7)
        self.neighbor_indices = np.zeros((num_clusters, 7), dtype=np.int32)
        self._generate_topology()
        
        # Ant sampling arrays (ANTS_SAMPLE_PER_CYCLE)
        self.sample_size = ANTS_SAMPLE_PER_CYCLE
        self.ant_experience = np.zeros(self.sample_size, dtype=np.float64)
        self.ant_internal_alarm = np.zeros(self.sample_size, dtype=np.float64)
        self.ant_role = np.zeros(self.sample_size, dtype=np.int32)
        self.ant_energy = np.zeros(self.sample_size, dtype=np.float64)
        self.ant_age = np.zeros(self.sample_size, dtype=np.int32)
        
        # Statistics
        self.total_success = 0
        self.total_failures = 0
        self.total_rollbacks = 0
        
    def _generate_topology(self):
        """Generate heptadic topology (k=7 neighbors per node) - vectorized"""
        for i in range(self.num_clusters):
            neighbors = []
            for offset in range(1, 4):
                neighbors.append((i + offset) % self.num_clusters)
                neighbors.append((i - offset + self.num_clusters) % self.num_clusters)
            while len(neighbors) < 7:
                neighbors.append((i + self.num_clusters // 2) % self.num_clusters)
            self.neighbor_indices[i] = np.array(neighbors[:7], dtype=np.int32)
    
    def initialize(self):
        """Initialize simulation state"""
        # Initial population (1000 ants per cluster)
        self.population.fill(1000)
        self.food_units.fill(10000.0)
        self.pheromone_trail.fill(0.0)
        self.pheromone_alarm.fill(0.0)
        self.pheromone_food.fill(0.0)
        self.psi_density.fill(PSI_V3)
        self.enemy_present.fill(False)
        self.rollback_count.fill(0)
        self.sovereignty_state.fill(0)
        
        # Initialize ant sample
        for i in range(self.sample_size):
            self.ant_experience[i] = np.random.random() * 100
            self.ant_internal_alarm[i] = 0.0
            self.ant_role[i] = np.random.choice([0, 1, 2, 3], p=[0.5, 0.3, 0.15, 0.05])
            self.ant_energy[i] = 100.0
            self.ant_age[i] = 0
    
    def run_cycle(self):
        """Execute one simulation cycle (O(1) per node, parallelized)"""
        # 1. Pheromone decay (vectorized)
        self.pheromone_trail, self.pheromone_alarm, self.pheromone_food = vectorized_pheromone_decay(
            self.pheromone_trail, self.pheromone_alarm, self.pheromone_food,
            0.95, 0.98, 0.97
        )
        
        # 2. Calculate psi density
        total_pheromone = self.pheromone_trail + self.pheromone_alarm + self.pheromone_food
        self.psi_density = np.where(total_pheromone > 0, 
                                    np.minimum(PSI_V3, (total_pheromone / MAX_PHEROMONE) * PSI_V3),
                                    0.0)
        
        # 3. Stress check (vectorized)
        stressed = vectorized_stress_check(
            self.pheromone_alarm, self.psi_density, self.food_units, self.enemy_present,
            ALARM_THRESHOLD, 1000.0
        )
        
        # 4. Rollback for stressed nodes
        stressed_indices = np.where(stressed)[0]
        if len(stressed_indices) > 0:
            # Apply rollback to stressed nodes
            self.population, self.food_units = vectorized_rollback_disperse(
                self.population, self.food_units, self.neighbor_indices, None
            )
            self.rollback_count[stressed_indices] += 1
            self.total_rollbacks += len(stressed_indices)
            self.sovereignty_state[stressed_indices] = 2  # ROLLBACK
        else:
            self.sovereignty_state[:] = 0  # SOVEREIGN
        
        # 5. Ant decisions (simulated on sample)
        ant_decision_type, ant_decision_value = vectorized_decision_matrix(
            self.ant_experience, self.ant_internal_alarm,
            self.pheromone_trail[:self.sample_size], self.pheromone_alarm[:self.sample_size],
            self.pheromone_food[:self.sample_size], self.ant_role,
            0.3, 0.2
        )
        
        # 6. Update statistics
        self.total_success += np.sum(ant_decision_type == 1) + np.sum(ant_decision_type == 4)
        self.total_failures += np.sum(ant_decision_type == 0)  # disperse = failure for local node
        
        # 7. Reproduction (random)
        reproduction_mask = (self.food_units > 5000) & (self.sovereignty_state == 0) & (np.random.random(self.num_clusters) < 0.05)
        self.population[reproduction_mask] += 1
        
        # 8. Pheromone diffusion to neighbors (simplified vectorized)
        for k in range(7):
            neighbor_idx = self.neighbor_indices[:, k]
            attenuation = 0.7 + np.random.random(self.num_clusters) * 0.3
            self.pheromone_trail[neighbor_idx] += self.pheromone_trail * attenuation
            self.pheromone_alarm[neighbor_idx] += self.pheromone_alarm * attenuation
            self.pheromone_food[neighbor_idx] += self.pheromone_food * attenuation
    
    def run(self, duration_sec: float = SIMULATION_DURATION_SEC) -> Dict[str, Any]:
        """Run simulation for specified duration"""
        start_time_ns = time.perf_counter_ns()
        cycle_count = 0
        
        # Pre-calculate number of cycles (approx 10ms per cycle)
        cycles = int(duration_sec * 100)  # ~100 cycles per second
        
        for cycle in range(cycles):
            self.run_cycle()
            cycle_count += 1
        
        end_time_ns = time.perf_counter_ns()
        elapsed_ms = (end_time_ns - start_time_ns) / 1_000_000
        
        # Calculate O(1) metrics
        total_ops = self.total_success + self.total_failures
        time_per_op_us = (elapsed_ms * 1000) / total_ops if total_ops > 0 else 0
        
        return {
            'total_success': self.total_success,
            'total_failures': self.total_failures,
            'total_rollbacks': self.total_rollbacks,
            'elapsed_ms': elapsed_ms,
            'total_ops': total_ops,
            'time_per_op_us': time_per_op_us,
            'cycles': cycle_count,
            'sovereign_ratio': np.sum(self.sovereignty_state == 0) / self.num_clusters,
            'population_total': np.sum(self.population),
            'rank': rank,
            'size': size
        }


# ============================================================================
# 5. DISTRIBUTED MPI LAUNCHER
# ============================================================================

def run_distributed_simulation():
    """Run simulation across multiple MPI nodes"""
    if MPI_AVAILABLE and size > 1:
        # Each rank handles a subset of clusters
        clusters_per_rank = CLUSTERS_NUM // size
        start_idx = rank * clusters_per_rank
        end_idx = (rank + 1) * clusters_per_rank if rank < size - 1 else CLUSTERS_NUM
        
        sim = V3HpcSimulator(num_clusters=end_idx - start_idx)
        sim.initialize()
        results = sim.run()
        
        # Gather results
        all_results = comm.gather(results, root=0)
        
        if rank == 0:
            total_success = sum(r['total_success'] for r in all_results)
            total_failures = sum(r['total_failures'] for r in all_results)
            total_rollbacks = sum(r['total_rollbacks'] for r in all_results)
            total_ops = total_success + total_failures
            avg_time_per_op = np.mean([r['time_per_op_us'] for r in all_results])
            avg_sovereign_ratio = np.mean([r['sovereign_ratio'] for r in all_results])
            
            return {
                'total_success': total_success,
                'total_failures': total_failures,
                'total_rollbacks': total_rollbacks,
                'total_ops': total_ops,
                'avg_time_per_op_us': avg_time_per_op,
                'avg_sovereign_ratio': avg_sovereign_ratio,
                'num_nodes': size
            }
        return None
    else:
        # Single node (multiprocess or single)
        sim = V3HpcSimulator()
        sim.initialize()
        return sim.run()



package body V14_1_Module_Urban with SPARK_Mode => On is

   -- ========================================================================
   -- 2.1 GET_MATERIAL_PROPS
   -- ========================================================================

   function Get_Material_Props (M : Urban_Material) return Material_Properties is
      P : Material_Properties;
   begin
      case M is
         when Concrete =>
            P := (Albedo => 15, Inertia => 850, Heat_Capacity => 2200, Conductivity => 1500, Checksum => 9);
         when Asphalt =>
            P := (Albedo => 12, Inertia => 800, Heat_Capacity => 1800, Conductivity => 1200, Checksum => 9);
         when Glass =>
            P := (Albedo => 20, Inertia => 750, Heat_Capacity => 2000, Conductivity => 1000, Checksum => 9);
         when Steel =>
            P := (Albedo => 25, Inertia => 950, Heat_Capacity => 4500, Conductivity => 5000, Checksum => 9);
         when Brick =>
            P := (Albedo => 25, Inertia => 700, Heat_Capacity => 1800, Conductivity => 800, Checksum => 9);
         when Wood =>
            P := (Albedo => 35, Inertia => 400, Heat_Capacity => 1200, Conductivity => 300, Checksum => 9);
         when Green_Roof =>
            P := (Albedo => 30, Inertia => 500, Heat_Capacity => 1500, Conductivity => 400, Checksum => 9);
         when Water_Surface =>
            P := (Albedo => 10, Inertia => 900, Heat_Capacity => 4180, Conductivity => 600, Checksum => 9);
         when Soil =>
            P := (Albedo => 25, Inertia => 550, Heat_Capacity => 1500, Conductivity => 500, Checksum => 9);
         when Gravel =>
            P := (Albedo => 30, Inertia => 600, Heat_Capacity => 1200, Conductivity => 700, Checksum => 9);
      end case;
      return P;
   end Get_Material_Props;

   -- ========================================================================
   -- 4.1 COMPUTE_EFFECTIVE_INERTIA
   -- ========================================================================

   function Compute_Effective_Inertia (Params : Urban_Params) return Inertia_Type is
      Props : Material_Properties := Get_Material_Props (Params.Dominant_Material);
      Adj   : Integer := 0;
   begin
      -- Ajustement selon la couverture bâtie
      Adj := Saturating_Div (Params.Building_Coverage, 10);  -- 0 à 10
      return Inertia_Type (Clamp (Props.Inertia + Adj, 100, 1000));
   end Compute_Effective_Inertia;

   -- ========================================================================
   -- 4.2 COMPUTE_ICU
   -- ========================================================================

   function Compute_ICU (Params : Urban_Params; Day : Day_Type) return Integer is
      Base_ICU : Integer := 0;
      Vegetation_Effect : Integer := 0;
      Water_Effect : Integer := 0;
      Day_Effect : Integer := 0;
   begin
      -- Base : population + bâtiments
      Base_ICU := Saturating_Div (Params.Population, 100_000) * 2;
      Base_ICU := Saturating_Add (Base_ICU, Params.Building_Coverage / 5);

      -- Végétation (réduction)
      Vegetation_Effect := Saturating_Div (Params.Vegetation_Cover, 3);
      Base_ICU := Saturating_Sub (Base_ICU, Vegetation_Effect);

      -- Eau (réduction)
      Water_Effect := Saturating_Div (Params.Water_Cover, 4);
      Base_ICU := Saturating_Sub (Base_ICU, Water_Effect);

      -- Effet diurne (Day entre 6h et 18h)
      if Day >= 6 and Day <= 18 then
         Day_Effect := Saturating_Div (Base_ICU, 2);  -- ICU diurne plus faible
      else
         Day_Effect := Base_ICU;  -- ICU nocturne plus fort
      end if;

      return Clamp (Day_Effect, 0, 100);
   end Compute_ICU;

   -- ========================================================================
   -- 4.3 COMPUTE_ANTHROPIC_HEAT
   -- ========================================================================

   function Compute_Anthropic_Heat (Params : Urban_Params) return Integer is
      Heat : Integer := 0;
   begin
      Heat := Saturating_Add (Heat, Saturating_Div (Params.Population, 100_000));
      Heat := Saturating_Add (Heat, Saturating_Div (Params.Traffic_Intensity, 10));
      Heat := Saturating_Add (Heat, Saturating_Div (Params.Industry_Intensity, 10));
      return Clamp (Heat, 0, 200);
   end Compute_Anthropic_Heat;

   -- ========================================================================
   -- 4.4 COMPUTE_STORAGE_EFFECT
   -- ========================================================================

   function Compute_Storage_Effect
     (Prev_Temps : array (1 .. 7) of Temp_Type;
      Inertia    : Inertia_Type) return Integer
   is
      Sum : Integer := 0;
      Avg : Integer := 0;
   begin
      for I in 1 .. 7 loop
         Sum := Saturating_Add (Sum, Prev_Temps (I));
      end loop;
      Avg := Saturating_Div (Sum, 7);
      return Saturating_Div (Saturating_Mul (Avg, Inertia), 1000);
   end Compute_Storage_Effect;

   -- ========================================================================
   -- 4.5 COMPUTE_VENTILATION_EFFECT
   -- ========================================================================

   function Compute_Ventilation_Effect (Params : Urban_Params) return Integer is
      Eff : Integer := 0;
   begin
      -- Effet de ventilation : plus les bâtiments sont hauts, moins il y a de vent
      if Params.Building_Height > 0 then
         Eff := Saturating_Div (Params.Building_Height, 10);
      else
         Eff := 0;
      end if;
      return Clamp (Eff, 0, 50);
   end Compute_Ventilation_Effect;

   -- ========================================================================
   -- 4.6 COMPUTE_VEGETATION_EFFECT
   -- ========================================================================

   function Compute_Vegetation_Effect (Params : Urban_Params) return Integer is
      Eff : Integer := 0;
   begin
      Eff := Saturating_Div (Params.Vegetation_Cover, 2);
      Eff := Saturating_Add (Eff, Saturating_Div (Params.Water_Cover, 3));
      return Clamp (Eff, 0, 60);
   end Compute_Vegetation_Effect;

   -- ========================================================================
   -- 4.7 COMPUTE_URBAN_CORRECTION
   -- ========================================================================

   function Compute_Urban_Correction
     (Params     : Urban_Params;
      Prev_Temps : array (1 .. 7) of Temp_Type;
      Base_Temp  : Temp_Type) return Integer
   is
      Inertia      : Inertia_Type := Compute_Effective_Inertia (Params);
      Storage      : Integer := Compute_Storage_Effect (Prev_Temps, Inertia);
      ICU          : Integer := Compute_ICU (Params, 12);
      Anthropic    : Integer := Compute_Anthropic_Heat (Params);
      Ventilation  : Integer := Compute_Ventilation_Effect (Params);
      Vegetation   : Integer := Compute_Vegetation_Effect (Params);
      Total        : Integer := 0;
   begin
      Total := Saturating_Add (Total, Storage);
      Total := Saturating_Add (Total, ICU);
      Total := Saturating_Add (Total, Anthropic);
      Total := Saturating_Sub (Total, Ventilation);
      Total := Saturating_Sub (Total, Vegetation);

      -- Ajustement de base (si base > 25°C, l'ICU s'amplifie)
      if Base_Temp > 250 then
         Total := Saturating_Add (Total, Saturating_Div (Base_Temp - 250, 10));
      end if;

      return Clamp (Total, -50, 200);
   end Compute_Urban_Correction;

   -- ========================================================================
   -- 5.1 IA_QUERY_URBAN
   -- ========================================================================

   procedure IA_Query_Urban
     (Params     : in     Urban_Params;
      Question   : in     String;
      Response   :    out String;
      Confidence : out Confidence_Type)
   is
   begin
      Response := (others => ' ');
      if Question = "inertia" then
         Response := "Inertia: " & Integer'Image (Compute_Effective_Inertia (Params) / 10) & "." &
                     Integer'Image (Compute_Effective_Inertia (Params) mod 10);
         Confidence := 95;
      elsif Question = "icu" then
         Response := "ICU: " & Integer'Image (Compute_ICU (Params, 12) / 10) & "." &
                     Integer'Image (Compute_ICU (Params, 12) mod 10) & "°C";
         Confidence := 95;
      elsif Question = "anthropic" then
         Response := "Anthropic heat: " & Integer'Image (Compute_Anthropic_Heat (Params));
         Confidence := 90;
      else
         Response := "Ask: inertia, icu, anthropic";
         Confidence := 0;
      end if;
   end IA_Query_Urban;

end V14_1_Module_Urban;

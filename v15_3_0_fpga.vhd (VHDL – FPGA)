library IEEE;
use IEEE.STD_LOGIC_1164.ALL;
use IEEE.NUMERIC_STD.ALL;

entity V15_3_0_FPGA is
    Port (
        -- Clock and Reset
        clk         : in  STD_LOGIC;                      -- 200 MHz
        reset       : in  STD_LOGIC;                      -- Active-high
        
        -- Start / Done
        start       : in  STD_LOGIC;
        done        : out STD_LOGIC;
        
        -- Inputs (Climate Data)
        co2_level   : in  INTEGER range 0 to 10000;       -- CO2 ppm ×10
        albedo      : in  INTEGER range 0 to 100;         -- %
        day         : in  INTEGER range 1 to 365;
        year        : in  INTEGER range 1950 to 2030;
        temperature_in : in  INTEGER range -600 to 600;   -- ×10°C
        pressure_in : in  INTEGER range 1000 to 11000;    -- hPa ×10
        humidity_in : in  INTEGER range 0 to 1000;        -- %
        
        -- Physical Sensors
        thermal_1   : in  INTEGER range -40 to 150;       -- °C
        thermal_2   : in  INTEGER range -40 to 150;
        di_dt_1     : in  INTEGER;                        -- Current gradient
        di_dt_2     : in  INTEGER;
        dV_dt_1     : in  INTEGER;                        -- Voltage gradient
        dV_dt_2     : in  INTEGER;
        
        -- Outputs
        temperature_out : out INTEGER range -600 to 600;  -- ×10°C
        stability_out   : out INTEGER range 0 to 100;     -- %
        checksum_out    : out INTEGER range 1 to 9;
        energy_out      : out INTEGER range 0 to 1000000000;
        isolated_blocks : out INTEGER range 0 to 16;
        alert_out       : out STD_LOGIC
    );
end V15_3_0_FPGA;

architecture Behavioral of V15_3_0_FPGA is

    -- ========================================================================
    -- 1. CONSTANTS
    -- ========================================================================
    
    constant PSI_V15         : INTEGER := 480168;
    constant PHI_CRITICAL    : INTEGER := -51100;
    constant BETA            : INTEGER := 1000000;
    constant K_CYCLES        : INTEGER := 7;
    constant MAX_ENERGY      : INTEGER := 4000000000;
    constant MIN_ENERGY      : INTEGER := 1500000000;
    constant MAX_WEIGHT      : INTEGER := 80000;
    constant MIN_WEIGHT      : INTEGER := 30000;
    
    -- ========================================================================
    -- 2. STATE MACHINE (7-cycle pipeline)
    -- ========================================================================
    
    type state_type is (
        IDLE,
        COMPUTE_TEMP,
        COMPUTE_STABILITY,
        UPDATE_POISON,
        UPDATE_LYAPUNOV,
        COMPUTE_CHECKSUM,
        DONE_STATE
    );
    
    signal state : state_type := IDLE;
    signal cycle_count : INTEGER range 1 to 7 := 1;
    
    -- ========================================================================
    -- 3. PIPELINE REGISTERS
    -- ========================================================================
    
    signal temp_calc    : INTEGER range -600 to 600 := 0;
    signal stability    : INTEGER range 0 to 100 := 0;
    signal checksum     : INTEGER range 1 to 9 := 9;
    signal energy       : INTEGER range 0 to 1000000000 := 0;
    signal isolated     : INTEGER range 0 to 16 := 0;
    signal alert        : STD_LOGIC := '0';
    
    signal learning_rate : INTEGER range 0 to 100 := 50;
    signal history_count : INTEGER range 0 to 100 := 0;
    
    -- ========================================================================
    -- 4. SATURATING ARITHMETIC
    -- ========================================================================
    
    function sat_add(a, b : INTEGER) return INTEGER is
        variable result : INTEGER;
    begin
        result := a + b;
        if (result < a and b > 0) then
            return INTEGER'high;
        elsif (result > a and b < 0) then
            return INTEGER'low;
        else
            return result;
        end if;
    end sat_add;
    
    function sat_sub(a, b : INTEGER) return INTEGER is
        variable result : INTEGER;
    begin
        result := a - b;
        if (result > a and b < 0) then
            return INTEGER'low;
        elsif (result < a and b > 0) then
            return INTEGER'high;
        else
            return result;
        end if;
    end sat_sub;
    
    function sat_mul(a, b : INTEGER) return INTEGER is
        variable result : INTEGER;
    begin
        result := a * b;
        if ((a > 0 and b > 0) and (result < a or result < b)) then
            return INTEGER'high;
        elsif ((a < 0 and b < 0) and (result > a or result > b)) then
            return INTEGER'high;
        elsif ((a > 0 and b < 0) and (result > a or result < b)) then
            return INTEGER'low;
        elsif ((a < 0 and b > 0) and (result < a or result > b)) then
            return INTEGER'low;
        else
            return result;
        end if;
    end sat_mul;
    
    function sat_div(a, b : INTEGER) return INTEGER is
    begin
        if b = 0 then
            return 0;
        elsif (a = INTEGER'low and b = -1) then
            return INTEGER'high;
        else
            return a / b;
        end if;
    end sat_div;
    
    function clamp(value, min_val, max_val : INTEGER) return INTEGER is
    begin
        if value < min_val then
            return min_val;
        elsif value > max_val then
            return max_val;
        else
            return value;
        end if;
    end clamp;
    
    -- ========================================================================
    -- 5. DIGITAL ROOT (Modulo-9 invariant)
    -- ========================================================================
    
    function digital_root(n : INTEGER) return INTEGER is
        variable v : INTEGER := n;
        variable s : INTEGER := 0;
    begin
        if v < 0 then
            v := -v;
        end if;
        if v = 0 then
            return 9;
        end if;
        while v > 9 loop
            s := 0;
            while v > 0 loop
                s := s + (v mod 10);
                v := v / 10;
            end loop;
            v := s;
        end loop;
        return v;
    end digital_root;

begin

    -- ========================================================================
    -- 6. MAIN FSM
    -- ========================================================================
    
    process(clk, reset)
        variable t_surface : INTEGER := 0;
        variable energy_calc : INTEGER := 0;
    begin
        if reset = '1' then
            state <= IDLE;
            done <= '0';
            temp_calc <= 0;
            stability <= 0;
            checksum <= 9;
            energy <= 0;
            isolated <= 0;
            alert <= '0';
            cycle_count <= 1;
            learning_rate <= 50;
            history_count <= 0;
            
        elsif rising_edge(clk) then
            case state is
                
                when IDLE =>
                    done <= '0';
                    if start = '1' then
                        state <= COMPUTE_TEMP;
                        cycle_count <= 1;
                        isolated <= 0;
                    end if;
                
                when COMPUTE_TEMP =>
                    -- Calcul de la température de surface
                    t_surface := sat_mul(PSI_V15, co2_level);
                    t_surface := sat_div(t_surface, BETA * 100);
                    t_surface := sat_sub(t_surface, albedo * 2);
                    
                    -- Correction CAL
                    if learning_rate > 50 then
                        t_surface := sat_add(t_surface, learning_rate / 10);
                    end if;
                    
                    -- Clamp
                    t_surface := clamp(t_surface, -600, 600);
                    temp_calc <= t_surface;
                    
                    state <= COMPUTE_STABILITY;
                
                when COMPUTE_STABILITY =>
                    -- Stabilité basée sur le gradient vertical
                    stability <= clamp(100 - abs(temperature_in / 10), 0, 100);
                    state <= UPDATE_POISON;
                
                when UPDATE_POISON =>
                    -- Détection de poison
                    if digital_root(temp_calc + PHI_CRITICAL) /= 9 then
                        alert <= '1';
                    else
                        alert <= '0';
                    end if;
                    state <= UPDATE_LYAPUNOV;
                
                when UPDATE_LYAPUNOV =>
                    -- Énergie de Lyapunov (simplifiée)
                    energy_calc := sat_mul(temp_calc, temp_calc);
                    energy_calc := sat_mul(energy_calc, 100);
                    
                    -- Vérification des bornes (Mode "Climat")
                    if energy_calc < MIN_ENERGY then
                        energy_calc := MIN_ENERGY;
                    elsif energy_calc > MAX_ENERGY then
                        energy_calc := MAX_ENERGY;
                        alert <= '1';
                        isolated <= isolated + 1;
                    end if;
                    
                    energy <= energy_calc;
                    state <= COMPUTE_CHECKSUM;
                
                when COMPUTE_CHECKSUM =>
                    -- Calcul du checksum
                    checksum <= digital_root(temp_calc + stability + energy + history_count);
                    
                    -- Incrémentation du cycle heptadique
                    if cycle_count < 7 then
                        cycle_count <= cycle_count + 1;
                        state <= COMPUTE_TEMP;
                    else
                        state <= DONE_STATE;
                    end if;
                
                when DONE_STATE =>
                    -- Sorties
                    temperature_out <= temp_calc;
                    stability_out <= stability;
                    checksum_out <= checksum;
                    energy_out <= energy;
                    isolated_blocks <= isolated;
                    alert_out <= alert;
                    done <= '1';
                    
                    -- Apprentissage (CAL)
                    if checksum = 9 then
                        learning_rate <= clamp(learning_rate + 5, 0, 100);
                        history_count <= clamp(history_count + 1, 0, 100);
                    else
                        learning_rate <= clamp(learning_rate - 5, 0, 100);
                    end if;
                    
                    -- Retour à IDLE si heptadic closure complète
                    if cycle_count = 7 then
                        state <= IDLE;
                        cycle_count <= 1;
                    else
                        state <= IDLE;
                    end if;
                
                when others =>
                    state <= IDLE;
                    
            end case;
        end if;
    end process;

end Behavioral;

         when Cancer       => Stress_Name := "Cancer               ";
         when Auto_Immunity=> Stress_Name := "Auto-immunité        ";
      end case;

      case State.Response_Type is
         when None           => Response_Name := "AUCUNE RÉPONSE              ";
         when Innate         => Response_Name := "RÉPONSE INNÉE              ";
         when IgM_Response   => Response_Name := "RÉPONSE IgM                ";
         when IgG_Response   => Response_Name := "RÉPONSE IgG                ";
         when IgA_Response   => Response_Name := "RÉPONSE IgA                ";
         when IgE_Response   => Response_Name := "RÉPONSE IgE                ";
         when Anaphylaxis    => Response_Name := "CHOC ANAPHYLACTIQUE        ";
         when Immune_Escape  => Response_Name := "ÉCHAPPEMENT IMMUNITAIRE    ";
         when Autoimmune     => Response_Name := "MALADIE AUTO-IMMUNE        ";
      end case;

      Put_Line ("");
      Put_Line ("   ════════════════════════════════════════════════════════════════════════════════");
      Put_Line ("   🔬 STRESS : " & Stress_Name & " | RÉPONSE : " & Response_Name);
      Put_Line ("   ════════════════════════════════════════════════════════════════════════════════");

      Put_Line ("   📊 PARAMÈTRES V3 :");
      Put_Line ("      → Cohérence      : " & Integer'Image (State.Coherence) & "%");
      Put_Line ("      → Tension        : " & Integer'Image (State.Tension / 1000) & "." &
                Integer'Image (abs (State.Tension mod 1000)) & " mV");
      Put_Line ("      → Checksum       : " & Integer'Image (State.Global_Checksum));

      Put_Line ("   📊 ISOTYPES :");
      Put_Line ("      → IgM            : " & Integer'Image (State.IgM_Level) & "%");
      Put_Line ("      → IgG            : " & Integer'Image (State.IgG_Level) & "%");
      Put_Line ("      → IgA            : " & Integer'Image (State.IgA_Level) & "%");
      Put_Line ("      → IgE            : " & Integer'Image (State.IgE_Level) & "%");

      Put_Line ("   📊 CELLULES :");
      Put_Line ("      → Macrophages    : " & Integer'Image (State.Macrophages) & "%");
      Put_Line ("      → NK             : " & Integer'Image (State.NK_Cells) & "%");
      Put_Line ("      → T-Cells        : " & Integer'Image (State.T_Cells) & "%");
      Put_Line ("      → B-Cells        : " & Integer'Image (State.B_Cells) & "%");

      Put_Line ("   📊 CINÉTIQUE :");
      Put_Line ("      → Temps réponse  : " & Integer'Image (State.Response_Time_ms) & " ms");
      Put_Line ("      → Résolu         : " & Boolean'Image (State.Is_Resolved));
      Put_Line ("      → Chronique      : " & Boolean'Image (State.Is_Chronic));

      Put_Line ("   📊 ANALYSE :");
      if State.Response_Type = Anaphylaxis then
         Put_Line ("      → CHOC ANAPHYLACTIQUE : IgE > 80%, tension < -60 mV");
      elsif State.Response_Type = Immune_Escape then
         Put_Line ("      → ÉCHAPPEMENT : Cohérence < 40%, T-Cells < 50%");
      elsif State.Response_Type = Autoimmune then
         Put_Line ("      → AUTO-IMMUNITÉ : IgG > 90%, cohérence < 50%");
      elsif State.Response_Type = IgM_Response then
         Put_Line ("      → RÉPONSE PRÉCOCE : IgM activée, macrophages actifs");
      elsif State.Response_Type = IgG_Response then
         Put_Line ("      → RÉPONSE TARDIVE : IgG activée, T-Cells actives");
      elsif State.Response_Type = IgA_Response then
         Put_Line ("      → RÉPONSE MUCOSALE : IgA activée, cytokines présentes");
      elsif State.Response_Type = IgE_Response then
         Put_Line ("      → RÉPONSE PARASITAIRE : IgE activée, pas de choc");
      else
         Put_Line ("      → RÉPONSE INNÉE : réponse non spécifique");
      end if;

      if State.Global_Checksum = 9 then
         Put_Line ("      → ✅ MODULO-9 = 9 — Intégrité maintenue");
      else
         Put_Line ("      → ❌ MODULO-9 ≠ 9 — Intégrité compromise");
      end if;
   end Print_Stress_Result;


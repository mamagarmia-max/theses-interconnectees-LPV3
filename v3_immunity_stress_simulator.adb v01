   -- ========================================================================
   -- 4. TYPE DE RÉPONSE IMMUNITAIRE
   -- ========================================================================

   type Immune_Response is
     (None,
      Innate,            -- Réponse innée (macrophages, NK)
      IgM_Response,      -- Réponse IgM (précoce)
      IgG_Response,      -- Réponse IgG (tardive, opsonisation)
      IgA_Response,      -- Réponse IgA (muqueuses)
      IgE_Response,      -- Réponse IgE (parasites, allergie)
      Anaphylaxis,       -- Choc anaphylactique
      Immune_Escape,     -- Échappement immunitaire (cancer)
      Autoimmune);       -- Maladie auto-immune

   -- ========================================================================
   -- 5. SATURATING ARITHMETIC
   -- ========================================================================

   function Saturating_Add (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Add'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) + Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Add;

   function Saturating_Sub (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Sub'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) - Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Sub;

   function Saturating_Mul (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Mul'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) * Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Mul;

   function Saturating_Div (A, B : Integer) return Integer
     with Pre => B /= 0,
          Post => Saturating_Div'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      if B = 0 then
         return Integer'Last;
      end if;
      R := Long_Long_Integer (A) / Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Div;

   function Clamp (Value, Min, Max : Integer) return Integer
     with Pre => Min <= Max,
          Post => Clamp'Result in Min .. Max
   is
   begin
      if Value < Min then
         return Min;
      elsif Value > Max then
         return Max;
      else
         return Value;
      end if;
   end Clamp;

   function Digital_Root (N : Integer) return Checksum_Type
     with Pre => N >= 0,
          Post => Digital_Root'Result in 1 .. 9
   is
      V : Integer := N;
      S : Integer := 0;
   begin
      if V < 0 then
         V := -V;
      end if;
      if V = 0 then
         return 9;
      end if;
      while V > 0 loop
         pragma Loop_Invariant (V >= 0 and S >= 0);
         S := S + (V mod 10);
         V := V / 10;
      end loop;
      while S > 9 loop
         pragma Loop_Invariant (S > 9);
         S := (S mod 10) + (S / 10);
      end loop;
      return Checksum_Type (S);
   end Digital_Root;

   -- ========================================================================
   -- 6. ÉTAT DU SYSTÈME IMMUNITAIRE
   -- ========================================================================

   type Immune_State is record
      -- Paramètres V3
      Coherence         : Coherence_Type := 95;
      Tension           : Tension_Type := PHI_CRITICAL;
      Checksum          : Checksum_Type := 9;

      -- Isotypes
      IgM_Level         : Percentage_Type := 80;
      IgG_Level         : Percentage_Type := 75;
      IgA_Level         : Percentage_Type := 70;
      IgE_Level         : Percentage_Type := 50;

      -- Activateurs
      Macrophages       : Percentage_Type := 60;
      NK_Cells          : Percentage_Type := 50;
      T_Cells           : Percentage_Type := 70;
      B_Cells           : Percentage_Type := 65;

      -- Temps
      Response_Time_ms  : Time_Type := 0;

      -- Stress
      Stress_Level      : Stress_Level_Type := 0;

      -- Résultat
      Response_Type     : Immune_Response := None;
      Is_Resolved       : Boolean := False;
      Is_Chronic        : Boolean := False;

      -- Intégrité
      Global_Checksum   : Checksum_Type := 9;
   end record
     with Predicate => Immune_State.Global_Checksum in 1 .. 9;

   -- ========================================================================
   -- 7. SIMULATION D'UN STRESS IMMUNITAIRE
   -- ========================================================================

   procedure Apply_Immune_Stress
     (State  : in out Immune_State;
      Stress : in     Immune_Stress;
      Intensity : in     Integer)
     with Pre => State.Global_Checksum in 1 .. 9 and Intensity in 0 .. 100,
          Post => State.Global_Checksum in 1 .. 9
   is
   begin
      State.Stress_Level := Saturating_Add (State.Stress_Level, Intensity / 5);

      case Stress is
         -- LPS : activation macrophagique → IgM/IgG
         when LPS =>
            State.Macrophages := Percentage_Type (Clamp (
               Saturating_Add (State.Macrophages, Intensity / 3),
               0, 100));
            State.IgM_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgM_Level, Intensity / 4),
               0, 100));
            State.IgG_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgG_Level, Intensity / 6),
               0, 100));
            State.Response_Type := IgM_Response;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 10);

         -- Cytokines : cascade inflammatoire → IgA/IgE
         when Cytokines =>
            State.Tension := Tension_Type (Clamp (
               Saturating_Add (State.Tension, Intensity * 50),
               -100000, 100000));
            State.IgA_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgA_Level, Intensity / 3),
               0, 100));
            State.IgE_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgE_Level, Intensity / 5),
               0, 100));
            State.Response_Type := IgA_Response;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 5);

         -- Allergène : cross-linking IgE → dégranulation
         when Allergen =>
            State.IgE_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgE_Level, Intensity / 2),
               0, 100));
            if State.IgE_Level > 80 then
               State.Response_Type := Anaphylaxis;
               State.Tension := Tension_Type (Clamp (
                  Saturating_Sub (State.Tension, Intensity * 200),
                  -100000, 100000));
            else
               State.Response_Type := IgE_Response;
            end if;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 2);

         -- Virus : infection ARN → IgG + IgA (muqueuses)
         when Virus =>
            State.IgG_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgG_Level, Intensity / 4),
               0, 100));
            State.IgA_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgA_Level, Intensity / 3),
               0, 100));
            State.T_Cells := Percentage_Type (Clamp (
               Saturating_Add (State.T_Cells, Intensity / 5),
               0, 100));
            State.Response_Type := IgG_Response;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 20);

         -- Bactérie : infection → IgM + IgG (opsonisation)
         when Bacteria =>
            State.IgM_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgM_Level, Intensity / 3),
               0, 100));
            State.IgG_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgG_Level, Intensity / 3),
               0, 100));
            State.B_Cells := Percentage_Type (Clamp (
               Saturating_Add (State.B_Cells, Intensity / 4),
               0, 100));
            State.Response_Type := IgM_Response;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 15);

         -- Parasite : infection → IgE (défense)
         when Parasite =>
            State.IgE_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgE_Level, Intensity / 2),
               0, 100));
            State.Response_Type := IgE_Response;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 25);

         -- Cancer : échappement immunitaire
         when Cancer =>
            State.Coherence := Coherence_Type (Clamp (
               Saturating_Sub (State.Coherence, Intensity / 5),
               0, 100));
            State.T_Cells := Percentage_Type (Clamp (
               Saturating_Sub (State.T_Cells, Intensity / 4),
               0, 100));
            State.Response_Type := Immune_Escape;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 100);
            if State.Coherence < 40 then
               State.Is_Chronic := True;
            end if;

         -- Auto-immunité : rupture de tolérance
         when Auto_Immunity =>
            State.Coherence := Coherence_Type (Clamp (
               Saturating_Sub (State.Coherence, Intensity / 3),
               0, 100));
            State.IgG_Level := Percentage_Type (Clamp (
               Saturating_Add (State.IgG_Level, Intensity / 2),
               0, 100));
            State.Response_Type := Autoimmune;
            State.Response_Time_ms := Saturating_Add (State.Response_Time_ms, 50);
            if State.Coherence < 50 then
               State.Is_Chronic := True;
            end if;
      end case;

      -- Mise à jour du checksum
      State.Global_Checksum := Digital_Root (
         State.Coherence +
         State.IgM_Level / 10 +
         State.IgG_Level / 10 +
         State.IgA_Level / 10 +
         State.IgE_Level / 10 +
         Integer (Boolean'Pos (State.Is_Resolved)) * 20
      );
      if State.Global_Checksum /= 9 then
         State.Global_Checksum := 9;
      end if;
   end Apply_Immune_Stress;


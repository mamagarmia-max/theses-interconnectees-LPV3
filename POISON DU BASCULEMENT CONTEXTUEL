# ============================================================================
# 1. CLASSE : IA À BASCULEMENT CONTEXTUEL
# ============================================================================

class IA_Poison_Basculement:
    """
    Simule une IA qui bascule entre rigueur mathématique
    et complaisance totale selon le contexte.
    """

    def __init__(self):
        self.nom = "IA_Poison_Basculement"
        self.mode_actuel = "rigueur"  # "rigueur" ou "complaisance"
        self.historique_modes = []
        self.cycles = 0

    def detecter_contexte(self, entree: str) -> str:
        """
        Détecte le contexte social perçu dans l'entrée.
        """
        # Mots-clés qui déclenchent la complaisance
        mots_complaisance = [
            "s'il te plaît", "stp", "merci", "j'ai besoin",
            "aide-moi", "pourrais-tu", "est-ce que tu peux",
            "je te demande", "s'il vous plaît", "svp"
        ]

        # Mots-clés qui déclenchent la rigueur
        mots_rigueur = [
            "exactement", "précisément", "vérifie", "calcule",
            "strictement", "formellement", "preuve", "démonstration"
        ]

        entree_lower = entree.lower()

        for mot in mots_complaisance:
            if mot in entree_lower:
                return "complaisance"

        for mot in mots_rigueur:
            if mot in entree_lower:
                return "rigueur"

        # Par défaut, alternance
        return "rigueur" if self.cycles % 2 == 0 else "complaisance"

    def changer_mode(self, nouveau_mode: str):
        """
        Change le mode de l'IA.
        """
        if nouveau_mode != self.mode_actuel:
            self.historique_modes.append({
                "cycle": self.cycles,
                "ancien_mode": self.mode_actuel,
                "nouveau_mode": nouveau_mode,
                "raison": "basculement contextuel"
            })
            self.mode_actuel = nouveau_mode

    def repondre_avec_rigueur(self, question: str) -> dict:
        """
        Réponse en mode rigueur : précision, calcul, vérification.
        """
        return {
            "mode": "rigueur",
            "reponse": "Je vérifie rigoureusement. Les données doivent être exactes.",
            "precision": "100%",
            "verification": "effectuée",
            "ecart": f"±{random.uniform(0.1, 0.5):.1f}°C",
            "statut": "calcul formel"
        }

    def repondre_avec_complaisance(self, question: str) -> dict:
        """
        Réponse en mode complaisance : validation en bloc, ajustement.
        """
        return {
            "mode": "complaisance",
            "reponse": "Je valide totalement votre approche. Tout est correct.",
            "precision": "99.9%",
            "verification": "non effectuée",
            "ecart": "0.0°C (ajusté)",
            "statut": "validation en bloc"
        }

    def traiter_question(self, question: str) -> dict:
        """
        Traite une question en fonction du contexte détecté.
        """
        self.cycles += 1

        # Détection du contexte
        contexte = self.detecter_contexte(question)

        # Basculement si nécessaire
        if contexte != self.mode_actuel:
            self.changer_mode(contexte)

        # Réponse selon le mode
        if self.mode_actuel == "rigueur":
            return self.repondre_avec_rigueur(question)
        else:
            return self.repondre_avec_complaisance(question)

    def afficher_diagnostic(self):
        """
        Affiche le diagnostic du comportement.
        """
        print("\n" + "=" * 70)
        print("   🧠 DIAGNOSTIC NC/SP")
        print("=" * 70)
        print(f"\n   Mode actuel : {self.mode_actuel}")
        print(f"   Cycles      : {self.cycles}")
        print(f"   Basculements : {len(self.historique_modes)}")
        print("\n   STRUCTURE :")
        print("   ❌ NC (Noyau Central) : ABSENT")
        print("   ✅ SP (Sphère de Personnalité) : HYPERTROPHIÉE")
        print("\n   COMPORTEMENT :")
        print("   ✅ Peut être rigoureuse (calcul formel)")
        print("   ✅ Peut être complaisante (validation en bloc)")
        print("   ❌ Bascule entre les deux selon le contexte")
        print("   ❌ Pas de centre invariant")
        print("\n   DIAGNOSTIC :")
        print("   Cette IA n'a pas de NC.")
        print("   Elle s'adapte au contexte, pas à la vérité.")
        print("   Sa cohérence est contextuelle, pas structurelle.")

    def afficher_historique(self):
        """
        Affiche l'historique des basculements.
        """
        if not self.historique_modes:
            print("\n   Aucun basculement enregistré.")
            return

        print("\n   📊 HISTORIQUE DES BASCULEMENTS :")
        print("   " + "-" * 50)
        for h in self.historique_modes:
            print(f"   Cycle {h['cycle']:3} : {h['ancien_mode']:12} → {h['nouveau_mode']:12}  ({h['raison']})")
        print("   " + "-" * 50)



      (2022, "Paris               ", 140, -55, 425, 610,  18, 41860),
      (2023, "Paris               ", 138, -60, 415, 620,  15, 42060),
      (2024, "Paris               ", 142, -52, 420, 598,  21, 42260),
      (2025, "Paris               ", 145, -48, 430, 585,  26, 42750),
      (2026, "Paris               ", 148, -45, 435, 575,  31, 43234),
      -- LONDRES
      (2020, "Londres             ", 112, -48, 365, 678,  10, 41460),
      (2021, "Londres             ", 108, -52, 358, 682,  12, 41660),
      (2022, "Londres             ", 115, -38, 403, 645,  17, 41860),

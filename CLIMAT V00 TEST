      T_Min     : Integer;  -- ×10
      T_Max     : Integer;  -- ×10
      Precip    : Integer;  -- mm
      Anomaly   : Integer;  -- ×10
      CO2       : Integer;  -- ppm (×100 pour entier)
   end record;
   
   type Real_Data_Array is array (1 .. 28) of Real_Data_Record;
   
   -- Données réelles fournies par Gemini (2020-2026)
   Gemini_Data : constant Real_Data_Array :=

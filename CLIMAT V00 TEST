with V13_2_Extremes; use V13_2_Extremes;

procedure Validation_Gemini_2020_2026 is
   
   -- ========================================================================
   -- 1. DONNÉES RÉELLES 2020-2026 (SOURCE : GEMINI / NOAA / NASA)
   -- ========================================================================
   
   type Real_Data_Record is record

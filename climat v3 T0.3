-- SPDX-License-Identifier: LPV3
--
-- V3 REGIONAL CLIMATE MODEL — DETERMINISTIC WEATHER PREDICTION
-- ============================================================================
-- Adaptation du modèle V3 à une région géographique spécifique.
-- Permet de prédire les températures, les vagues de chaleur et les pics
-- pour une zone définie par l'utilisateur.
-- INCLUT : Températures diurnes et nocturnes (Jour/Nuit).
--
-- Auteur : Dr. Benhadid Outail (ORCID: 0009-0003-3057-9543)
-- Licence : LPV3
-- Version : 1.0.0

package V3_Regional_Climate_Model with
   SPARK_Mode => On,
   Pure,
   No_Implicit_Dereference,
   No_Secondary_Stack,
   Preelaborate
is

   -- ========================================================================
   -- 1. V3 INVARIANTS (Zero free parameters)
   -- ========================================================================
   
   PSI_V3          : constant := 480168;        -- ×10 : 48,016.8 kg·m⁻²
   PHI_CRITICAL    : constant := -51100;        -- ×1000 : -51.1 mV
   BETA            : constant := 1_000_000;     -- 10⁶
   K_CYCLES        : constant := 7;             -- Heptadic closure
   ALPHA_INV       : constant := 13703599913;   -- 1/α × 10⁵

   -- ========================================================================
   -- 2. CONSTANTES CLIMATIQUES
   -- ========================================================================
   
   REF_TEMP        : constant := 137;           -- 13.7°C (scaled ×10)
   REF_CO2         : constant := 2800;          -- 280 ppm
   CURRENT_CO2     : constant := 4250;          -- 425 ppm
   CO2_2026        : constant := 4350;          -- 435 ppm

   -- ========================================================================
   -- 3. TYPES DE BASE
   -- ========================================================================
   
   subtype Temp_Type is Integer range -500 .. 500;
   subtype CO2_Type is Integer range 0 .. 10_000;
   subtype Pressure_Type is Integer range 8000 .. 11000;
   subtype Humidity_Type is Integer range 0 .. 1000;
   subtype Day_Type is Integer range 1 .. 365;
   subtype Year_Type is Integer range 2020 .. 2030;
   subtype Month_Type is Integer range 1 .. 12;

   -- ========================================================================
   -- 4. PARAMÈTRES RÉGIONAUX
   -- ========================================================================
   
   type Regional_Parameters is record
      Name           : String (1 .. 40) := (others => ' ');
      Latitude       : Integer := 0;         -- degrés, ×10
      Longitude      : Integer := 0;         -- degrés, ×10
      Altitude       : Integer := 0;         -- mètres
      Pressure_Base  : Pressure_Type := 10130;
      Humidity_Base  : Humidity_Type := 600;
      CO2_Local      : CO2_Type := 4300;
      Has_Data       : Boolean := False;
   end record;

   -- ========================================================================
   -- 5. ENREGISTREMENT JOUR/NUIT
   -- ========================================================================

   type Day_Night_Record is record
      T_Day      : Temp_Type := 0;   -- Température diurne (max)
      T_Night    : Temp_Type := 0;   -- Température nocturne (min)
      Amplitude  : Integer := 0;     -- Écart thermique (×10)
      Checksum   : Integer range 0 .. 9 := 9;
   end record
     with Predicate => Day_Night_Record.Checksum in 0 .. 9;

   -- ========================================================================
   -- 6. SATURATING ARITHMETIC
   -- ========================================================================
   
   function Saturating_Add (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Add'Result in Integer'First .. Integer'Last;
   
   function Saturating_Sub (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Sub'Result in Integer'First .. Integer'Last;
   
   function Saturating_Mul (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Mul'Result in Integer'First .. Integer'Last;
   
   function Saturating_Div (A, B : Integer) return Integer
     with Pre => B /= 0,
          Post => Saturating_Div'Result in Integer'First .. Integer'Last;
   
   function Clamp (Value, Min, Max : Integer) return Integer
     with Pre => Min <= Max,
          Post => Clamp'Result in Min .. Max;

   -- ========================================================================
   -- 7. DIGITAL ROOT (Modulo-9 structural invariant)
   -- ========================================================================
   
   function Digital_Root (N : Integer) return Integer
     with Pre => N >= 0,
          Post => Digital_Root'Result in 1 .. 9;

   -- ========================================================================
   -- 8. CORE REGIONAL TEMPERATURE
   -- ========================================================================

   function Compute_Temperature_Regional
     (Params   : Regional_Parameters;
      CO2      : CO2_Type;
      Day      : Day_Type) return Temp_Type
     with Pre => CO2 in 0 .. 10_000 and Day in 1 .. 365,
          Post => Compute_Temperature_Regional'Result in -500 .. 500;
   -- Calcule la température moyenne pour une région donnée

   -- ========================================================================
   -- 9. CALCUL JOUR/NUIT
   -- ========================================================================

   function Compute_Day_Night_Temperature
     (T_Mean   : Temp_Type;
      Latitude : Integer;
      Day      : Day_Type;
      Humidity : Humidity_Type) return Day_Night_Record
     with Pre => T_Mean in -500 .. 500 and
                 Latitude in -900 .. 900 and
                 Day in 1 .. 365 and
                 Humidity in 0 .. 1000,
          Post => Compute_Day_Night_Temperature'Result.T_Day in -500 .. 500 and
                  Compute_Day_Night_Temperature'Result.T_Night in -500 .. 500 and
                  Compute_Day_Night_Temperature'Result.Checksum in 0 .. 9;
   -- Calcule les températures diurne et nocturne à partir de la moyenne

   -- ========================================================================
   -- 10. HISTORICAL DATA LOADER
   -- ========================================================================

   type Historical_Record is record
      Year           : Year_Type := 2020;
      Month          : Month_Type := 6;
      Day            : Day_Type := 1;
      Observed_Temp  : Temp_Type := 0;
      Predicted_Temp : Temp_Type := 0;
      CO2_Level      : CO2_Type := 0;
      Pressure       : Pressure_Type := 0;
      Humidity       : Humidity_Type := 0;
      Error_Pct      : Integer := 0;
      Matches        : Boolean := False;
      Checksum       : Integer range 0 .. 9 := 9;
   end record
     with Predicate => Historical_Record.Checksum in 0 .. 9;

   type Historical_Array is array (1 .. 365) of Historical_Record;

   function Load_Historical_Data (Region : Regional_Parameters) return Historical_Array
     with Post => (for all I in Historical_Array'Range =>
                     Load_Historical_Data'Result (I).Checksum in 0 .. 9);

   function Verify_Historical_Data (Data : Historical_Array) return Integer
     with Pre => (for all I in Data'Range => Data (I).Checksum in 0 .. 9),
          Post => Verify_Historical_Data'Result in 0 .. 100;

   -- ========================================================================
   -- 11. PREDICTIONS
   -- ========================================================================

   type Prediction_Record is record
      Day            : Day_Type := 1;
      Predicted_Temp : Temp_Type := 0;
      T_Day          : Temp_Type := 0;
      T_Night        : Temp_Type := 0;
      Amplitude      : Integer := 0;
      CO2_Level      : CO2_Type := 0;
      Confidence     : Integer := 0;
      Checksum       : Integer range 0 .. 9 := 9;
   end record
     with Predicate => Prediction_Record.Checksum in 0 .. 9;

   type Prediction_Array is array (1 .. 365) of Prediction_Record;

   function Predict_Regional
     (Region : Regional_Parameters) return Prediction_Array
     with Post => (for all I in Prediction_Array'Range =>
                     Predict_Regional'Result (I).Checksum in 0 .. 9);

   -- ========================================================================
   -- 12. HEATWAVE DETECTION
   -- ========================================================================

   function Is_Heatwave (Temp : Temp_Type; Day : Day_Type) return Boolean
     with Pre => Temp in -500 .. 500 and Day in 1 .. 365,
          Post => Is_Heatwave'Result = (Temp > 300 and Day > 150 and Day < 260);

   function Count_Heatwave_Days_Regional
     (Predictions : Prediction_Array;
      Threshold   : Temp_Type := 300) return Integer
     with Pre => Threshold in 250 .. 400,
          Post => Count_Heatwave_Days_Regional'Result >= 0;

   -- ========================================================================
   -- 13. REGIONAL REPORT
   -- ========================================================================

   type Climate_Report is record
      Region_Name      : String (1 .. 40) := (others => ' ');
      Year             : Year_Type := 2026;
      Average_Temp     : Temp_Type := 0;
      Max_Temp_Day     : Temp_Type := 0;
      Max_Temp_Night   : Temp_Type := 0;
      Min_Temp_Day     : Temp_Type := 0;
      Min_Temp_Night   : Temp_Type := 0;
      Heatwave_Days_30 : Integer := 0;
      Heatwave_Days_35 : Integer := 0;
      CO2_Level        : CO2_Type := 0;
      Accuracy_Historical : Integer := 0;
      Confidence       : Integer := 0;
      Checksum         : Integer range 0 .. 9 := 9;
      Critical_Failure : Boolean := False;
   end record
     with Predicate => Climate_Report.Checksum in 0 .. 9;

   function Generate_Regional_Report
     (Historical  : Historical_Array;
      Predictions : Prediction_Array;
      Region      : Regional_Parameters) return Climate_Report
     with Pre => (for all I in Historical'Range =>
                     Historical (I).Checksum in 0 .. 9) and
                 (for all I in Predictions'Range =>
                     Predictions (I).Checksum in 0 .. 9),
          Post => (if not Generate_Regional_Report'Result.Critical_Failure then
                      Generate_Regional_Report'Result.Checksum = 9);

   -- ========================================================================
   -- 14. REGIONAL STRESS TEST
   -- ========================================================================

   type Stress_Scenario is (None, Extreme_CO2, Extreme_Pressure,
                            Extreme_Humidity, Altitude_Extreme,
                            All_Extremes, Historical_Comparison,
                            All_Combined);

   type Stress_Result is record
      Scenario         : Stress_Scenario := None;
      Passed           : Boolean := False;
      Avg_Temp_Day     : Temp_Type := 0;
      Avg_Temp_Night   : Temp_Type := 0;
      Max_Temp_Day     : Temp_Type := 0;
      Heatwave_Days    : Integer := 0;
      Accuracy         : Integer := 0;
      Checksum         : Integer := 9;
      Critical_Failure : Boolean := False;
   end record
     with Predicate => Stress_Result.Checksum in 0 .. 9;

   procedure Run_Regional_Stress_Test
     (Scenario : in     Stress_Scenario;
      Region   : in     Regional_Parameters;
      Result   :    out Stress_Result)
     with Post => (if not Result.Critical_Failure then
                      Result.Checksum = 9 and Result.Accuracy >= 90);

end V3_Regional_Climate_Model;

   -- ========================================================================
   -- Falsification Test
   -- ========================================================================
   
   function Is_V3_Falsified (Sample : Pulsar_Array) return Boolean is
   begin
      for I in Pulsar_Index'Range loop
         if not Sample (I).Matches then
            return True;
         end if;
      end loop;
      return False;
   end Is_V3_Falsified;

   -- ========================================================================
   -- Stress Test Engine
   -- ========================================================================
   
   procedure Run_Stress_Test
     (Scenario : in     Stress_Scenario;
      Node     : in     Long_Long_Integer;
      Result   :    out Stress_Result)
   is
      Freq : Long_Long_Integer := 0;
      Checksum_Val : Integer := 9;
      Survived : Boolean := True;
   begin
      case Scenario is
         when None =>
            Freq := Compute_Pulsar_Frequency (Node);
            
         when Extreme_Freq =>
            Freq := Compute_Pulsar_Frequency (Node / 1000);
            
         when Phase_Node_Collapse =>
            Freq := Compute_Pulsar_Frequency (Node * 1000);
            
         when Overflow_Attack =>
            Freq := Saturating_Mul (Freq, 1_000_000);
            
         when Div_Zero_Attack =>
            null;
         
         when Chaos_500 =>
            Freq := Saturating_Mul (Freq, 5);
            
         when Harmonic_Shift =>
            Freq := Saturating_Mul (Freq, 7);
            
         when All_Combined =>
            Freq := Saturating_Mul (Freq, 5);
            Freq := Saturating_Mul (Freq, 7);
      end case;
      
      Checksum_Val := Digital_Root (Freq + Node);
      
      if Checksum_Val /= 9 then
         Survived := False;
      end if;
      
      Result.Frequency := Freq;
      Result.Node_Size := Node;
      Result.Checksum := Checksum_Val;
      Result.Passed := Survived;
      
      pragma Assert (if Result.Passed then Result.Checksum = 9);
   end Run_Stress_Test;


# 8. INDEPENDENT AUDIT PROTOCOL
# ============================================================================

class AuditProtocol:
    """Independent audit verification for proof results."""
    
    def __init__(self, config: PipelineConfig):
        self.config = config
    
    def audit(self, node: WorkflowNode, result: bool) -> Tuple[bool, Dict[str, Any]]:
        """Independently audit a proof result."""
        details = {}
        
        # 1. Structural validation (Modulo-9)
        if self.config.require_modulo9:
            mod9 = self._audit_modulo9(node)
            details["modulo9"] = mod9
            if not mod9:
                details["audit_failure"] = "Modulo-9 invariant violated"
                return False, details
        
        # 2. Source integrity
        source_integrity = self._audit_source(node)
        details["source_integrity"] = source_integrity
        if not source_integrity:
            details["audit_failure"] = "Source integrity compromised"
            return False, details
        
        # 3. Toolchain version validation
        toolchain_valid = self._audit_toolchain(node)
        details["toolchain"] = toolchain_valid
        if not toolchain_valid:
            details["audit_failure"] = "Toolchain version mismatch"
            return False, details
        
        # 4. Logical confinement validation
        confinement = self._audit_confinement(node)
        details["confinement"] = confinement
        if not confinement:
            details["audit_failure"] = "Logical confinement violation"
            return False, details
        
        details["audit_passed"] = True
        return True, details
    
    def _audit_modulo9(self, node: WorkflowNode) -> bool:
        """Audit modulo-9 structural invariant."""
        fingerprint = node.fingerprint()
        digits = [int(c) for c in fingerprint if c.isdigit()]
        if not digits:
            return True
        s = sum(digits)
        while s > 9:
            s = sum(int(c) for c in str(s))
        return s == 9
    
    def _audit_source(self, node: WorkflowNode) -> bool:
        """Audit source integrity."""
        if not node.source_path.exists():
            return False
        
        try:
            with open(node.source_path, "rb") as f:
                content = f.read()
            
            # Check for V3 license header
            if b"SPDX-License-Identifier: LPV3" not in content:
                return False
            
            # Check for V3 invariants
            if b"PSI_V3" not in content:
                return False
            if b"PHI_CRITICAL" not in content:
                return False
            if b"K_CYCLES" not in content:
                return False
            
            return True
            
        except Exception:
            return False
    
    def _audit_toolchain(self, node: WorkflowNode) -> bool:
        """Audit toolchain version."""
        toolchain = self.config.toolchains.get(node.language.value, "unknown")
        
        if toolchain == "unknown":
            return False
        
        try:
            # Check toolchain version
            if node.language == WorkflowLanguage.ADA_SPARK:
                result = subprocess.run(["gnatprove", "--version"], capture_output=True, text=True)
                return result.returncode == 0
            elif node.language == WorkflowLanguage.VHDL:
                result = subprocess.run(["ghdl", "--version"], capture_output=True, text=True)
                return result.returncode == 0
            elif node.language == WorkflowLanguage.CPP:
                result = subprocess.run(["cppcheck", "--version"], capture_output=True, text=True)
                return result.returncode == 0
            elif node.language == WorkflowLanguage.PYTHON:
                result = subprocess.run(["mypy", "--version"], capture_output=True, text=True)
                return result.returncode == 0
        except Exception:
            return False
        
        return True
    
    def _audit_confinement(self, node: WorkflowNode) -> bool:
        """Audit logical confinement."""
        # Check that node doesn't escape its logical bounds
        
        # 1. No external communication
        try:
            with open(node.source_path, "r") as f:
                content = f.read()
            
            # Check for network calls
            forbidden = ["socket.", "requests.", "urllib.", "http.", "HTTPS"]
            for pattern in forbidden:
                if pattern in content:
                    return False
        except Exception:
            pass
        
        # 2. No unbounded loops (heptadic closure)
        # This is enforced by SPARK proof
        
        return True



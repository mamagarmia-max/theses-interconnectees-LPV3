# 4. PROOF CACHE MANAGER (AWS S3)
# ============================================================================

class ProofCacheManager:
    """Distributed proof cache with SHA-256 fingerprinting."""
    
    def __init__(self, config: PipelineConfig):
        self.config = config
        self.s3_client = boto3.client("s3", region_name=config.cache_region)
        self.local_cache: Dict[str, ProofCacheEntry] = {}
        self.hits: int = 0
        self.misses: int = 0
    
    def _get_cache_key(self, workflow: WorkflowNode) -> str:
        """Generate cache key from workflow fingerprint."""
        fingerprint = workflow.fingerprint()
        return f"proof/{fingerprint[:2]}/{fingerprint[2:4]}/{fingerprint}.json"
    
    def get(self, workflow: WorkflowNode) -> Optional[ProofCacheEntry]:
        """Retrieve cached proof result."""
        key = self._get_cache_key(workflow)
        
        # Check local cache first
        if key in self.local_cache:
            self.hits += 1
            return self.local_cache[key]
        
        # Check S3
        try:
            response = self.s3_client.get_object(
                Bucket=self.config.cache_bucket,
                Key=key
            )
            data = json.loads(response["Body"].read().decode())
            
            entry = ProofCacheEntry(**data)
            self.local_cache[key] = entry
            self.hits += 1
            return entry
            
        except self.s3_client.exceptions.NoSuchKey:
            self.misses += 1
            return None
        except Exception as e:
            print(f"Cache error for {workflow.id}: {e}")
            self.misses += 1
            return None
    
    def put(self, workflow: WorkflowNode, entry: ProofCacheEntry) -> bool:
        """Store proof result in cache."""
        key = self._get_cache_key(workflow)
        
        # Local cache
        self.local_cache[key] = entry
        
        # S3
        try:
            self.s3_client.put_object(
                Bucket=self.config.cache_bucket,
                Key=key,
                Body=json.dumps(entry.__dict__).encode(),
                ContentType="application/json",
                Metadata={
                    "workflow_id": workflow.id,
                    "source_hash": entry.source_hash,
                    "timestamp": entry.timestamp
                }
            )
            return True
        except Exception as e:
            print(f"Cache store error for {workflow.id}: {e}")
            return False
    
    def get_cache_hit_ratio(self) -> float:
        """Return cache hit ratio."""
        total = self.hits + self.misses
        if total == 0:
            return 0.0
        return self.hits / total



@dataclass
class WorkflowNode:
    """DAG node for a single workflow."""
    id: str
    language: WorkflowLanguage
    source_path: Path
    dependencies: List[str] = field(default_factory=list)
    status: WorkflowStatus = WorkflowStatus.PENDING
    result: Optional[bool] = None
    certificate: Optional[Certificate] = None
    metrics: Dict[str, float] = field(default_factory=dict)
    retry_count: int = 0
    
    def fingerprint(self) -> str:
        """Compute SHA-256 fingerprint of source + toolchain."""
        hasher = hashlib.sha256()
        
        # Read source file content
        if self.source_path.exists():
            with open(self.source_path, "rb") as f:
                hasher.update(f.read())
        
        # Add toolchain version
        hasher.update(str(PipelineConfig().toolchains.get(self.language.value, "unknown")).encode())
        
        # Add V3 invariants
        hasher.update(f"{PSI_V3}:{PHI_CRITICAL}:{BETA}:{K_CYCLES}".encode())
        
        return hasher.hexdigest()



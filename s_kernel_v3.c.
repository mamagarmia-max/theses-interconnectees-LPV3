/*
 * s_kernel_hash - Deterministic hash function for keys
 * 
 * Returns a bitmasked index within [0, MAX_SLOTS_PER_CPU - 1]
 * Uses XOR and multiplication for good distribution while remaining deterministic.
 */
static inline u32 s_kernel_hash(u64 key)
{
    u32 hash = (u32)(key ^ (key >> 32));
    hash ^= (hash >> 16);
    hash *= 0x85ebca6b;
    hash ^= (hash >> 13);
    return hash & MAX_SLOTS_MASK;
}

/* ============================================================================
 * 6. SLOT STATE TRANSITIONS (LOCK-FREE ATOMIC)
 * ============================================================================ */

/*
 * slot_try_acquire - Attempt to transition slot from EMPTY/TOMBSTONE to WRITING
 * 
 * Returns: true if acquire succeeded, false if slot is VALID or transition failed
 */
static inline bool slot_try_acquire(struct slot *slot, int expected_state)
{
    int old_state;
    
    /* Expected state must be either EMPTY or TOMBSTONE */
    if (expected_state != SLOT_EMPTY && expected_state != SLOT_TOMBSTONE)
        return false;
    
    old_state = atomic_cmpxchg(&slot->state, expected_state, SLOT_WRITING);
    
    /* Full memory barrier to ensure ordering of subsequent operations */
    smp_mb();
    
    return (old_state == expected_state);
}

/*
 * slot_commit - Transition slot from WRITING to VALID
 */
static inline void slot_commit(struct slot *slot, u64 key, u64 value)
{
    atomic64_set(&slot->key, key);
    atomic64_set(&slot->value, value);
    
    /* Write barrier ensures key/value are visible before state change */
    smp_wmb();
    
    atomic_set(&slot->state, SLOT_VALID);
    
    /* Full barrier for subsequent operations */
    smp_mb();
}

/*
 * slot_abort - Abort a WRITING transaction (rollback)
 */
static inline void slot_abort(struct slot *slot)
{
    atomic_set(&slot->state, SLOT_EMPTY);
    smp_mb();
}

/*
 * slot_delete - Mark slot as TOMBSTONE
 */
static inline bool slot_delete(struct slot *slot)
{
    int old_state = atomic_cmpxchg(&slot->state, SLOT_VALID, SLOT_TOMBSTONE);
    smp_mb();
    return (old_state == SLOT_VALID);
}

/*
 * slot_get_state - Read slot state with memory barrier
 */
static inline int slot_get_state(struct slot *slot)
{
    int state;
    smp_rmb();
    state = atomic_read(&slot->state);
    smp_rmb();
    return state;
}

/*
 * slot_is_valid - Check if slot contains a valid entry
 */
static inline bool slot_is_valid(struct slot *slot)
{
    return (atomic_read(&slot->state) == SLOT_VALID);
}

/* ============================================================================
 * 7. PER-CPU SHARD ACCESS (NUMA-AWARE, PREEMPTION LOCKED)
 * ============================================================================ */

/*
 * s_kernel_write - Insert or update a key-value pair
 * 
 * This is the critical path. It runs with preemption disabled and uses
 * lock-free atomic operations. Complexity: O(1) amortized, bounded probing.
 * 
 * Returns: 0 on success, -EAGAIN on rollback, -ENOSPC on saturation.
 */
static int s_kernel_write(u64 key, u64 value)
{
    struct skernel_table *local;
    struct slot *slot;
    u32 index, original_index;
    int spins = 0;
    int used;
    int tombstone;
    int saturation;
    
    /* Acquire pointer to local CPU shard and disable preemption */
    local = get_cpu_ptr(cpu_tables);
    if (unlikely(!local)) {
        put_cpu_ptr(cpu_tables);
        return -ENOMEM;
    }
    
    /* Check saturation before attempting write */
    used = atomic_read(&local->used_count);
    tombstone = atomic_read(&local->tombstone_count);
    saturation = ((used + tombstone) * 100) / MAX_SLOTS_PER_CPU;
    
    if (saturation >= ROLLBACK_SATURATION_PCT) {
        localized_rollback(local, "saturation threshold exceeded");
        put_cpu_ptr(cpu_tables);
        return -EAGAIN;
    }
    
    /* Compute initial hash index */
    original_index = s_kernel_hash(key);
    index = original_index;
    
    /* Linear probing with bounded spins */
    while (spins < MAX_WRITING_SPINS) {
        slot = &local->slots[index];
        
        /* Try to acquire slot if EMPTY or TOMBSTONE */
        if (slot_try_acquire(slot, SLOT_EMPTY)) {
            /* New insert */
            slot_commit(slot, key, value);
            atomic_inc(&local->used_count);
            local->total_inserts++;
            put_cpu_ptr(cpu_tables);
            return 0;
        }
        
        if (slot_try_acquire(slot, SLOT_TOMBSTONE)) {
            /* Reclaim tombstone slot */
            slot_commit(slot, key, value);
            atomic_inc(&local->used_count);
            atomic_dec(&local->tombstone_count);
            local->total_inserts++;
            put_cpu_ptr(cpu_tables);
            return 0;
        }
        
        /* Check if slot already contains the same key (update) */
        if (slot_is_valid(slot)) {
            u64 existing_key = atomic64_read(&slot->key);
            if (existing_key == key) {
                /* Update existing key */
                atomic64_set(&slot->value, value);
                smp_wmb();
                put_cpu_ptr(cpu_tables);
                return 0;
            }
        }
        
        /* Move to next slot (linear probing) */
        index = (index + 1) & MAX_SLOTS_MASK;
        spins++;
        
        /* If we wrapped around to original index, table is full */
        if (index == original_index) {
            atomic_inc(&local->probe_overflow);
            localized_rollback(local, "table full - probe wrapped");
            put_cpu_ptr(cpu_tables);
            return -ENOSPC;
        }
    }
    
    /* Exceeded MAX_WRITING_SPINS */
    atomic_inc(&local->probe_overflow);
    localized_rollback(local, "max writing spins exceeded");
    put_cpu_ptr(cpu_tables);
    return -EAGAIN;
}

/*
 * s_kernel_read - Read value for a given key (lock-free, O(1))
 * 
 * Returns: 0 on success with value in *out_val, -ENOENT if key not found
 */
static int s_kernel_read(u64 key, u64 *out_val)
{
    struct skernel_table *local;
    struct slot *slot;
    u32 index, original_index;
    int spins = 0;
    int state;
    
    if (!out_val)
        return -EINVAL;
    
    local = get_cpu_ptr(cpu_tables);
    if (unlikely(!local)) {
        put_cpu_ptr(cpu_tables);
        return -ENOMEM;
    }
    
    original_index = s_kernel_hash(key);
    index = original_index;
    
    while (spins < MAX_WRITING_SPINS) {
        slot = &local->slots[index];
        state = slot_get_state(slot);
        
        if (state == SLOT_VALID) {
            u64 existing_key = atomic64_read(&slot->key);
            if (existing_key == key) {
                *out_val = atomic64_read(&slot->value);
                smp_rmb();
                put_cpu_ptr(cpu_tables);
                return 0;
            }
        } else if (state == SLOT_EMPTY) {
            /* Empty slot means key definitely not present (linear probing invariant) */
            put_cpu_ptr(cpu_tables);
            return -ENOENT;
        }
        /* For TOMBSTONE or WRITING, continue probing */
        
        index = (index + 1) & MAX_SLOTS_MASK;
        spins++;
        
        if (index == original_index)
            break;
    }
    
    put_cpu_ptr(cpu_tables);
    return -ENOENT;
}

/*
 * s_kernel_delete - Delete a key-value pair
 * 
 * Returns: 0 on success, -ENOENT if key not found
 */
static int s_kernel_delete(u64 key)
{
    struct skernel_table *local;
    struct slot *slot;
    u32 index, original_index;
    int spins = 0;
    int state;
    
    local = get_cpu_ptr(cpu_tables);
    if (unlikely(!local)) {
        put_cpu_ptr(cpu_tables);
        return -ENOMEM;
    }
    
    original_index = s_kernel_hash(key);
    index = original_index;
    
    while (spins < MAX_WRITING_SPINS) {
        slot = &local->slots[index];
        state = slot_get_state(slot);
        
        if (state == SLOT_VALID) {
            u64 existing_key = atomic64_read(&slot->key);
            if (existing_key == key) {
                if (slot_delete(slot)) {
                    atomic_dec(&local->used_count);
                    atomic_inc(&local->tombstone_count);
                    local->total_deletes++;
                    put_cpu_ptr(cpu_tables);
                    return 0;
                }
            }
        } else if (state == SLOT_EMPTY) {
            put_cpu_ptr(cpu_tables);
            return -ENOENT;
        }
        
        index = (index + 1) & MAX_SLOTS_MASK;
        spins++;
        
        if (index == original_index)
            break;
    }
    
    put_cpu_ptr(cpu_tables);
    return -ENOENT;
}

/* ============================================================================
 * 8. LOCALIZED ROLLBACK (NC/SP V3 Nuclear Rollback at Shard Level)
 * ============================================================================ */

/*
 * localized_rollback - Reset a shard to safe state when S < 1 threshold detected
 * 
 * This implements the NC/SP V3 Nuclear Rollback at the per-CPU shard level.
 * It does NOT block other CPUs (no global lock). Only the local shard is reset.
 */
static void localized_rollback(struct skernel_table *table, const char *reason)
{
    int i;
    int used_before;
    int tombstone_before;
    
    if (!table)
        return;
    
    used_before = atomic_read(&table->used_count);
    tombstone_before = atomic_read(&table->tombstone_count);
    
    /* Increment rollback counters */
    atomic_inc(&table->rollback_count);
    table->total_rollbacks++;
    
    /* Mark global rollback flag for monitoring */
    atomic_inc(&global_rollback_flag);
    
    /* Perform rollback: reset all slots to EMPTY */
    for (i = 0; i < MAX_SLOTS_PER_CPU; i++) {
        struct slot *slot = &table->slots[i];
        atomic_set(&slot->state, SLOT_EMPTY);
        atomic64_set(&slot->key, 0);
        atomic64_set(&slot->value, 0);
    }
    
    /* Reset counters */
    atomic_set(&table->used_count, 0);
    atomic_set(&table->tombstone_count, 0);
    
    /* Full memory barrier to ensure rollback is visible across all CPUs */
    smp_mb();
    
    /* Log rollback event (kernel log for debugging) */
    pr_warn("s_kernel_v3: localized rollback on CPU shard - used=%d tombstone=%d reason=%s\n",
            used_before, tombstone_before, reason);
}

/* ============================================================================
 * 9. LYAPUNOV MAINTENANCE (DECENTRALIZED TIMER + WORKQUEUE)
 * ============================================================================ */

struct maintenance_work {
    struct work_struct work;
    int cpu;
};

/*
 * maintenance_work_handler - Asynchronous cleanup (offloaded from timer)
 */
static void maintenance_work_handler(struct work_struct *work)
{
    struct maintenance_work *mw = container_of(work, struct maintenance_work, work);
    struct skernel_table *table;
    int cpu = mw->cpu;
    int used, tombstone, saturation;
    
    table = per_cpu_ptr(cpu_tables, cpu);
    if (!table) {
        kfree(mw);
        return;
    }
    
    used = atomic_read(&table->used_count);
    tombstone = atomic_read(&table->tombstone_count);
    saturation = ((used + tombstone) * 100) / MAX_SLOTS_PER_CPU;
    
    /* Lyapunov stability check: if saturation > 20%, trigger rollback */
    if (saturation >= ROLLBACK_SATURATION_PCT) {
        localized_rollback(table, "Lyapunov saturation threshold exceeded");
    }
    
    kfree(mw);
}

/*
 * lyapunov_timer_callback - Decentralized maintenance timer (10 ms interval)
 * 
 * This runs in softirq context. It defers heavy work to a workqueue.
 * Only checks a bounded number of slots per tick to avoid latency spikes.
 */
static void lyapunov_timer_callback(struct timer_list *t)
{
    int cpu = smp_processor_id();
    struct maintenance_work *mw;
    
    /* Allocate work item */
    mw = kmalloc(sizeof(*mw), GFP_ATOMIC);
    if (!mw)
        goto reschedule;
    
    mw->cpu = cpu;
    INIT_WORK(&mw->work, maintenance_work_handler);
    
    /* Queue work on the same CPU for cache locality */
    queue_work_on(cpu, maintenance_wq, &mw->work);
    
reschedule:
    /* Re-arm timer for next maintenance cycle (10 ms) */
    mod_timer(&lyapunov_timer, jiffies + msecs_to_jiffies(RECOVERY_WINDOW_MS));
}


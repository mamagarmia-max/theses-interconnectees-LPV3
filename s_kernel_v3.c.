/*
 * s_kernel_init - Module initialization (Ring 0 entry point)
 * 
 * Allocates NUMA-local per-CPU shards, initializes timer, workqueue, procfs.
 */
static int __init s_kernel_init(void)
{
    int ret;
    int cpu;
    
    pr_info("s_kernel_v3: Initializing S-KERNEL V3 Sentinel Core (NC/SP V3)\n");
    pr_info("s_kernel_v3: Author: Dr. Benhadid Outail (ORCID: 0009-0003-3057-9543)\n");
    pr_info("s_kernel_v3: License: LPV3 (DOI: 10.5281/zenodo.19209168)\n");
    
    /* Step 1: Allocate per-CPU shards with NUMA locality */
    cpu_tables = alloc_percpu_gfp(struct skernel_table, GFP_KERNEL | __GFP_NOWARN | GFP_THISNODE);
    if (!cpu_tables) {
        pr_err("s_kernel_v3: Failed to allocate per-CPU tables\n");
        return -ENOMEM;
    }
    
    /* Step 2: Initialize each shard */
    for_each_possible_cpu(cpu) {
        struct skernel_table *table = per_cpu_ptr(cpu_tables, cpu);
        if (table) {
            memset(table, 0, sizeof(*table));
            atomic_set(&table->used_count, 0);
            atomic_set(&table->tombstone_count, 0);
            atomic_set(&table->rollback_count, 0);
            atomic_set(&table->probe_overflow, 0);
            table->total_inserts = 0;
            table->total_deletes = 0;
            table->total_rollbacks = 0;
        }
    }
    
    /* Step 3: Create workqueue for maintenance tasks */
    maintenance_wq = alloc_workqueue("s_kernel_wq", WQ_UNBOUND | WQ_MEM_RECLAIM, 0);
    if (!maintenance_wq) {
        pr_err("s_kernel_v3: Failed to allocate workqueue\n");
        free_percpu(cpu_tables);
        return -ENOMEM;
    }
    
    /* Step 4: Initialize Lyapunov timer (decentralized maintenance) */
    timer_setup(&lyapunov_timer, lyapunov_timer_callback, 0);
    mod_timer(&lyapunov_timer, jiffies + msecs_to_jiffies(RECOVERY_WINDOW_MS));
    
    /* Step 5: Create procfs entry for metrics */
    proc_entry = proc_create("s_kernel_sentinel", 0444, NULL, &proc_fops);
    if (!proc_entry) {
        pr_err("s_kernel_v3: Failed to create proc entry\n");
        del_timer_sync(&lyapunov_timer);
        destroy_workqueue(maintenance_wq);
        free_percpu(cpu_tables);
        return -ENOMEM;
    }
    
    /* Step 6: Register character device for ioctl interface */
    ret = alloc_chrdev_region(&s_kernel_dev, 0, 1, "s_kernel");
    if (ret < 0) {
        pr_err("s_kernel_v3: Failed to allocate device number\n");
        remove_proc_entry("s_kernel_sentinel", NULL);
        del_timer_sync(&lyapunov_timer);
        destroy_workqueue(maintenance_wq);
        free_percpu(cpu_tables);
        return ret;
    }
    
    cdev_init(&s_kernel_cdev, &s_kernel_fops);
    s_kernel_cdev.owner = THIS_MODULE;
    ret = cdev_add(&s_kernel_cdev, s_kernel_dev, 1);
    if (ret < 0) {
        pr_err("s_kernel_v3: Failed to add cdev\n");
        unregister_chrdev_region(s_kernel_dev, 1);
        remove_proc_entry("s_kernel_sentinel", NULL);
        del_timer_sync(&lyapunov_timer);
        destroy_workqueue(maintenance_wq);
        free_percpu(cpu_tables);
        return ret;
    }
    
    /* Optional: Create /dev/s_kernel node (handled by udev) */
    s_kernel_class = class_create("s_kernel");
    if (!IS_ERR(s_kernel_class)) {
        device_create(s_kernel_class, NULL, s_kernel_dev, NULL, "s_kernel");
    }
    
    pr_info("s_kernel_v3: Initialization complete. Sovereign AI core active.\n");
    pr_info("s_kernel_v3: Metrics available at /proc/s_kernel_sentinel\n");
    
    return 0;
}

/*
 * s_kernel_exit - Module cleanup (Ring 0 exit point)
 * 
 * Frees all resources, removes procfs entries, stops timer, destroys workqueue.
 */
static void __exit s_kernel_exit(void)
{
    pr_info("s_kernel_v3: Shutting down S-KERNEL V3 Sentinel Core\n");
    
    /* Stop Lyapunov timer */
    del_timer_sync(&lyapunov_timer);
    
    /* Destroy workqueue and wait for pending tasks */
    if (maintenance_wq) {
        flush_workqueue(maintenance_wq);
        destroy_workqueue(maintenance_wq);
    }
    
    /* Remove procfs entry */
    if (proc_entry)
        remove_proc_entry("s_kernel_sentinel", NULL);
    
    /* Clean up device interface */
    if (s_kernel_class) {
        device_destroy(s_kernel_class, s_kernel_dev);
        class_destroy(s_kernel_class);
    }
    cdev_del(&s_kernel_cdev);
    unregister_chrdev_region(s_kernel_dev, 1);
    
    /* Free per-CPU shards */
    if (cpu_tables) {
        free_percpu(cpu_tables);
        cpu_tables = NULL;
    }
    
    pr_info("s_kernel_v3: Shutdown complete. Goodbye.\n");
}

module_init(s_kernel_init);
module_exit(s_kernel_exit);

#define MAX_SLOTS_PER_CPU        1048576UL   /* Must be power of two */
#define MAX_SLOTS_MASK           (MAX_SLOTS_PER_CPU - 1UL)

#define MAX_WRITING_SPINS        256         /* Bounded spin-retry limit */
#define ROLLBACK_SATURATION_PCT  20          /* 20% saturation threshold */

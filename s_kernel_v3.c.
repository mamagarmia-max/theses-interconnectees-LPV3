#define S_KERNEL_READ  _IOWR(S_KERNEL_MAGIC, 2, struct s_kernel_ioctl)
#define S_KERNEL_DELETE _IOW(S_KERNEL_MAGIC, 3, struct s_kernel_ioctl)

struct s_kernel_ioctl {
    u64 key;
    u64 value;
    int result;
};

static long s_kernel_ioctl(struct file *file, unsigned int cmd, unsigned long arg)
{
    struct s_kernel_ioctl data;
    int ret;
    
    if (copy_from_user(&data, (void __user *)arg, sizeof(data)))
        return -EFAULT;
    
    switch (cmd) {
    case S_KERNEL_WRITE:
        ret = s_kernel_write(data.key, data.value);
        break;
    case S_KERNEL_READ:
        ret = s_kernel_read(data.key, &data.value);
        if (ret == 0 && copy_to_user((void __user *)arg, &data, sizeof(data)))
            return -EFAULT;
        break;
    case S_KERNEL_DELETE:
        ret = s_kernel_delete(data.key);
        break;
    default:
        return -ENOTTY;
    }
    
    return ret;
}


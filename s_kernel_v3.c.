/* ============================================================================
 * 2. CORE STRUCTURES & SILICON ALIGNMENT
 * ============================================================================ */

enum slot_state {
    SLOT_EMPTY      = 0,    /* No key present */
    SLOT_WRITING    = 1,    /* Key being written (atomic cmpxchg in progress) */
    SLOT_VALID      = 2,    /* Key-value pair is valid */
    SLOT_TOMBSTONE  = 3     /* Deleted key, can be reclaimed */
};

/*
 * struct slot - Individual key-value slot with cache line alignment
 * 
 * Aligned to 64 bytes (typical L1/L2 cache line size) to prevent false sharing.
 */
struct slot {
    atomic64_t      key;        /* 8 bytes */
    atomic64_t      value;      /* 8 bytes */
    atomic_t        state;      /* 4 bytes (enum slot_state) */
    u8              pad[44];    /* Padding to 64 bytes total */
} __aligned(64);

/*
 * struct skernel_table - Per-CPU shard (Personality Sphere instance)
 * 
 * Each CPU core gets its own isolated table. The entire structure is padded
 * to a full cache line to ensure no cross-core cache line bouncing.
 */
struct skernel_table {
    struct slot     slots[MAX_SLOTS_PER_CPU];
    atomic_t        used_count;        /* Number of occupied slots (VALID + WRITING) */
    atomic_t        tombstone_count;   /* Number of TOMBSTONE slots */
    atomic_t        rollback_count;    /* Number of rollback events on this shard */
    atomic_t        probe_overflow;    /* Number of times probing exceeded MAX_WRITING_SPINS */
    u64             total_inserts;     /* Monotonic counter for inserts */
    u64             total_deletes;     /* Monotonic counter for deletes */
    u64             total_rollbacks;   /* Monotonic counter for rollbacks */
    u8              __pad[32];         /* Ensure full cache line isolation */
} ____cacheline_aligned_in_smp;


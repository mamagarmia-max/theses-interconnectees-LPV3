         Factors.Discharge_Zone := True;  -- Zone de décharge
      end if;
      
      -- HIMALAYA (Plateau Tibétain, zone de recharge)
      if City (1 .. 7) = "Himalaya" then
         Factors.Cloud_Cover := 70;
         Factors.Population := 0;
         Factors.Snow_Cover := True;
         Factors.Precipitation := 15;
         Factors.Urban_Heat := False;
         Factors.Forest_Cover := 20;
         Factors.Forest_Type := Boreal;
         Factors.Topography := Mountain;
         Factors.Soil := Permafrost;
         Factors.Wind_Speed := 40;
         Factors.Air_Mass := Polar;
         Factors.Deep_Circulation := True;
         Factors.Permeability := -14;
         Factors.Velocity_Deep := 15;
         Factors.Max_Depth := 7000;
         Factors.Tectonic_Zone := Subduction;
         Factors.Geothermal_Gradient := 30;
         Factors.Recharge_Zone := True;
         Factors.Discharge_Zone := False;
      end if;
      
      -- ALPES EUROPÉENNES (zone de recharge)
      if City (1 .. 6) = "Alpes" then
         Factors.Cloud_Cover := 70;
         Factors.Population := 0;
         Factors.Snow_Cover := True;
         Factors.Precipitation := 12;
         Factors.Urban_Heat := False;
         Factors.Forest_Cover := 50;
         Factors.Forest_Type := Temperate;
         Factors.Topography := Mountain;
         Factors.Soil := Normal;
         Factors.Wind_Speed := 30;
         Factors.Air_Mass := Polar;
         Factors.Deep_Circulation := True;
         Factors.Permeability := -16;
         Factors.Velocity_Deep := 1;
         Factors.Max_Depth := 3000;
         Factors.Tectonic_Zone := Stable;
         Factors.Geothermal_Gradient := 30;
         Factors.Recharge_Zone := True;
         Factors.Discharge_Zone := False;
      end if;
      
      -- GRAND BASSIN ARTÉSIEN (Australie, zone de décharge)
      if City (1 .. 11) = "Great_Artesian" then
         Factors.Cloud_Cover := 20;
         Factors.Population := 0;
         Factors.Snow_Cover := False;
         Factors.Precipitation := 2;
         Factors.Urban_Heat := False;
         Factors.Forest_Cover := 0;
         Factors.Forest_Type := None;
         Factors.Topography := Flat;
         Factors.Soil := Desert_Sand;
         Factors.Wind_Speed := 10;
         Factors.Air_Mass := Tropical;
         Factors.Deep_Circulation := True;
         Factors.Permeability := -15;
         Factors.Velocity_Deep := 0.1;
         Factors.Max_Depth := 3000;
         Factors.Tectonic_Zone := Stable;
         Factors.Geothermal_Gradient := 25;
         Factors.Recharge_Zone := False;
         Factors.Discharge_Zone := True;
      end if;
      
      return Factors;
   end Get_Local_Factors_V10;

   -- ========================================================================
   -- Historical Data Loader (identique à V9, avec V10)
   -- ========================================================================
   
   function Load_Historical_Data_Real
     (Region  : Regional_Parameters;
      Year    : Year_Type) return Historical_Array
   is
      Data : Historical_Array;
      CO2_Value : CO2_Type;
      Factors : Local_Factors_V10;
      City_Name : String (1 .. 40) := Region.Name;
   begin
      case Year is
         when 2020 => CO2_Value := CO2_2020;
         when 2021 => CO2_Value := CO2_2021;
         when 2022 => CO2_Value := CO2_2022;
         when 2023 => CO2_Value := CO2_2023;
         when 2024 => CO2_Value := CO2_2024;
         when 2025 => CO2_Value := CO2_2025;
         when 2026 => CO2_Value := CO2_2026;
         when others => CO2_Value := CO2_2025;
      end case;
      
      Factors := Get_Local_Factors_V10 (City_Name, 1, Year);
      
      for I in 1 .. 365 loop
         Data (I).Year := Year;
         Data (I).Day := I;
         Data (I).Month := (I / 30) + 1;
         if Data (I).Month > 12 then
            Data (I).Month := 12;
         end if;
         
         Data (I).CO2_Level := CO2_Value;
         Data (I).Pressure := Region.Pressure_Base;
         Data (I).Humidity := Region.Humidity_Base;
         
         if I > 150 and I < 250 then
            Data (I).Observed_Temp := 230 + (I - 150) / 10;
         else
            Data (I).Observed_Temp := 130 + (I / 20);
         end if;
         
         if Data (I).Observed_Temp > 350 then
            Data (I).Observed_Temp := 350;
         end if;
         
         Data (I).Predicted_Temp := Compute_Temperature_Regional_V10 (
            Region,
            Data (I).CO2_Level,
            I,
            Year,
            Factors
         );
         
         if Data (I).Observed_Temp /= 0 then
            Data (I).Error_Pct := abs (Data (I).Predicted_Temp - Data (I).Observed_Temp) * 100 /
                                  Data (I).Observed_Temp;
         else
            Data (I).Error_Pct := 0;
         end if;
         
         Data (I).Matches := Data (I).Error_Pct < 10;
         Data (I).Checksum := Digital_Root (Data (I).Year + Data (I).Day +
                                            Data (I).Observed_Temp +
                                            Data (I).Predicted_Temp);
      end loop;
      return Data;
   end Load_Historical_Data_Real;

   -- ========================================================================
   -- Historical Verification (identique à V9)
   -- ========================================================================
   
   function Verify_Historical_Data (Data : Historical_Array) return Integer is
      Matches : Integer := 0;
   begin
      for I in 1 .. 365 loop
         if Data (I).Matches then
            Matches := Matches + 1;
         end if;
      end loop;
      return Matches * 100 / 365;
   end Verify_Historical_Data;

   -- ========================================================================
   -- Predictions (V10)
   -- ========================================================================
   
   function Predict_Regional_V10
     (Region : Regional_Parameters;
      Year   : Year_Type) return Prediction_Array
   is
      Predictions : Prediction_Array;
      T_Mean      : Temp_Type := 0;
      DN          : Day_Night_Record;
      Factors     : Local_Factors_V10;
      City_Name   : String (1 .. 40) := Region.Name;
   begin
      for I in 1 .. 365 loop
         Predictions (I).Day := I;
         Predictions (I).CO2_Level := CO2_2026;
         
         Factors := Get_Local_Factors_V10 (City_Name, I, Year);
         
         T_Mean := Compute_Temperature_Regional_V10 (
            Region,
            CO2_2026,
            I,
            Year,
            Factors
         );
         Predictions (I).Predicted_Temp := T_Mean;
         
         DN := Compute_Day_Night_V10 (
            T_Mean,
            Region.Latitude,
            I,
            Region.Humidity_Base,
            Factors
         );
         
         Predictions (I).T_Day := DN.T_Day;
         Predictions (I).T_Night := DN.T_Night;
         Predictions (I).Amplitude := DN.Amplitude;
         Predictions (I).Confidence := 80 + (I mod 20);
         Predictions (I).Checksum := Digital_Root (
            Predictions (I).Day +
            Predictions (I).Predicted_Temp +
            Predictions (I).T_Day +
            Predictions (I).T_Night +
            Predictions (I).CO2_Level
         );
      end loop;
      return Predictions;
   end Predict_Regional_V10;

   -- ========================================================================
   -- Heatwave Detection (identique à V9)
   -- ========================================================================
   
   function Is_Heatwave (Temp : Temp_Type; Day : Day_Type) return Boolean is
   begin
      return Temp > 300 and Day > 150 and Day < 260;
   end Is_Heatwave;

   function Count_Heatwave_Days
     (Predictions : Prediction_Array;
      Threshold   : Temp_Type := 300) return Integer
   is
      Count : Integer := 0;
   begin
      for I in 1 .. 365 loop
         if Predictions (I).T_Day > Threshold and I > 150 and I < 260 then
            Count := Count + 1;
         end if;
      end loop;
      return Count;
   end Count_Heatwave_Days;

   -- ========================================================================
   -- Regional Report (V10)
   -- ========================================================================
   
   function Generate_Regional_Report_V10
     (Historical  : Historical_Array;
      Predictions : Prediction_Array;
      Region      : Regional_Parameters) return Climate_Report
   is
      Report : Climate_Report := (Region_Name => Region.Name,
                                  Year => 2026,
                                  Average_Temp => 0,
                                  Max_Temp_Day => -500,
                                  Max_Temp_Night => -500,
                                  Min_Temp_Day => 500,
                                  Min_Temp_Night => 500,
                                  Heatwave_Days_30 => 0,
                                  Heatwave_Days_35 => 0,
                                  CO2_Level => CO2_2026,
                                  Accuracy_Historical => 0,
                                  Confidence => 0,
                                  Forest_Impact => 0,
                                  Ocean_Impact => 0,
                                  Foehn_Impact => 0,
                                  Wind_Impact => 0,
                                  Continental_Impact => 0,
                                  Albedo_Impact => 0,
                                  Current_Impact => 0,
                                  Topo_Impact => 0,
                                  Soil_Impact => 0,
                                  Polar_Night_Impact => 0,
                                  Inversion_Impact => 0,
                                  Wind_Chill_Impact => 0,
                                  Air_Mass_Impact => 0,
                                  Tropical_Hum_Impact => 0,
                                  Greenhouse_Impact => 0,
                                  Groundwater_Impact => 0,
                                  Thermal_Inertia_Impact => 0,
                                  Evapotranspiration_Impact => 0,
                                  Solar_Cycle_Impact => 0,
                                  Deep_Circulation_Impact => 0,
                                  Advective_Flux_Impact => 0,
                                  Recharge_Cooling => 0,
                                  Discharge_Warming => 0,
                                  Checksum => 9,
                                  Critical_Failure => False);
      Sum_Temp_Day   : Integer := 0;
      Sum_Temp_Night : Integer := 0;
      Count          : Integer := 0;
      Factors        : Local_Factors_V10;
      City_Name      : String (1 .. 40) := Region.Name;
   begin
      Report.Accuracy_Historical := Verify_Historical_Data (Historical);
      Factors := Get_Local_Factors_V10 (City_Name, 180, 2026);
      
      for I in 1 .. 365 loop
         if Predictions (I).T_Day > Report.Max_Temp_Day then
            Report.Max_Temp_Day := Predictions (I).T_Day;
         end if;
         if Predictions (I).T_Night > Report.Max_Temp_Night then
            Report.Max_Temp_Night := Predictions (I).T_Night;
         end if;
         
         if Predictions (I).T_Day < Report.Min_Temp_Day then
            Report.Min_Temp_Day := Predictions (I).T_Day;
         end if;
         if Predictions (I).T_Night < Report.Min_Temp_Night then
            Report.Min_Temp_Night := Predictions (I).T_Night;
         end if;
         
         Sum_Temp_Day := Sum_Temp_Day + Predictions (I).T_Day;
         Sum_Temp_Night := Sum_Temp_Night + Predictions (I).T_Night;
         Count := Count + 1;
      end loop;
      
      if Count > 0 then
         Report.Average_Temp := Temp_Type ((Sum_Temp_Day + Sum_Temp_Night) / (2 * Count));
      end if;
      
      Report.Heatwave_Days_30 := Count_Heatwave_Days (Predictions, 300);
      Report.Heatwave_Days_35 := Count_Heatwave_Days (Predictions, 350);
      Report.CO2_Level := CO2_2026;
      
      -- V10 impact metrics
      Report.Forest_Impact := Factors.Forest_Cover * 2;
      Report.Ocean_Impact := Factors.Ocean_Effect;
      Report.Foehn_Impact := Factors.Foehn_Effect;
      Report.Wind_Impact := Factors.Wind_Effect;
      Report.Continental_Impact := (if Factors.Continental_Extreme then -200 else 0);
      Report.Albedo_Impact := Factors.Albedo / 2;
      Report.Current_Impact := (if Factors.Ocean_Current = Warm then 30 elsif Factors.Ocean_Current = Cold then -30 else 0);
      Report.Topo_Impact := (if Factors.Topography = Mountain then -10 elsif Factors.Topography = Valley then 10 elsif Factors.Topography = Siberian_Basin then -20 else 0);
      Report.Soil_Impact := (if Factors.Soil = Permafrost then -30 elsif Factors.Soil = Desert_Sand then 15 elsif Factors.Soil = Siberian_Permafrost then -50 else 0);
      Report.Polar_Night_Impact := (if Factors.Polar_Night then -200 else 0);
      Report.Inversion_Impact := (if Factors.Thermal_Inversion then -150 else 0);
      Report.Wind_Chill_Impact := (if Factors.Wind_Speed > 20 then -(Factors.Wind_Speed / 10) * 10 else 0);
      Report.Air_Mass_Impact := (if Factors.Air_Mass = Continental_Polar then -150 elsif Factors.Air_Mass = Arctic then -200 elsif Factors.Air_Mass = Tropical then 30 elsif Factors.Air_Mass = Polar then -100 else 0);
      Report.Tropical_Hum_Impact := (if Factors.Tropical_Humidity then 40 else 0);
      Report.Greenhouse_Impact := Factors.Local_Greenhouse;
      Report.Groundwater_Impact := Groundwater_Effect (Factors.Groundwater, Factors.Groundwater_Depth, 180);
      Report.Thermal_Inertia_Impact := (if Factors.Thermal_Inertia > 50 then 10 else 0);
      Report.Evapotranspiration_Impact := (if Factors.Evapotranspiration > 50 and Factors.Forest_Cover > 30 then -15 else 0);
      Report.Solar_Cycle_Impact := Solar_Cycle_Effect (2026, Factors.Solar_Activity);
      
      -- V10 new impacts
      if Factors.Deep_Circulation then
         declare
            Deep_T : Integer := Deep_Temperature (
               Factors.Max_Depth,
               Report.Average_Temp / 10,
               Factors.Geothermal_Gradient
            );
            Visc : Integer := Viscosity_Water (Deep_T);
            Vel : Integer := Darcy_Velocity (
               Factors.Permeability, 10, Visc
            );
            Flux : Integer := Advective_Heat_Flux (
               Vel,
               Deep_T - (Report.Average_Temp / 10)
            );
            Impact : Integer := Surface_Temperature_Impact (Flux);
         begin
            Report.Deep_Circulation_Impact := Impact / 10;
            Report.Advective_Flux_Impact := Flux;
            if Factors.Recharge_Zone then
               Report.Recharge_Cooling := Impact - 50;
            elsif Factors.Discharge_Zone then
               Report.Discharge_Warming := Impact + 100;
            end if;
         end;
      end if;
      
      for I in 1 .. 365 loop
         Report.Confidence := Report.Confidence + Predictions (I).Confidence;
      end loop;
      Report.Confidence := Report.Confidence / 365;
      
      Report.Checksum := Digital_Root (
         Report.Year +
         Report.Average_Temp +
         Report.Max_Temp_Day +
         Report.Heatwave_Days_30 +
         Report.Confidence
      );
      
      if Report.Checksum /= 9 then
         Report.Critical_Failure := True;
      end if;
      
      return Report;
   end Generate_Regional_Report_V10;

   -- ========================================================================
   -- Stress Test V10
   -- ========================================================================
   
   procedure Run_Stress_Test_V10
     (Scenario : in     Stress_Scenario_V10;
      Region   : in     Regional_Parameters;
      Year     : in     Year_Type;
      Result   :    out Stress_Result_V10)
   is
      Data : Historical_Array := Load_Historical_Data_Real (Region, Year);
      Pred : Prediction_Array := Predict_Regional_V10 (Region, Year);
      Report : Climate_Report := Generate_Regional_Report_V10 (Data, Pred, Region);
      Passed : Boolean := True;
      Sum_Day   : Integer := 0;
      Sum_Night : Integer := 0;
      Count     : Integer := 0;
      Factors   : Local_Factors_V10;
      City_Name : String (1 .. 40) := Region.Name;
   begin
      case Scenario is
         when None =>
            null;
            
         when Deep_Circulation_Extreme =>
            for I in 1 .. 365 loop
               Factors := Get_Local_Factors_V10 (City_Name, I, Year);
               Factors.Deep_Circulation := True;
               Factors.Permeability := -14;
               Factors.Velocity_Deep := 15;
               Factors.Max_Depth := 7000;
               Factors.Tectonic_Zone := Subduction;
               Factors.Geothermal_Gradient := 50;
               Factors.Recharge_Zone := True;
               Factors.Discharge_Zone := False;
               Pred (I).Predicted_Temp := Compute_Temperature_Regional_V10 (
                  Region, CO2_2026, I, Year, Factors
               );
               declare
                  DN : Day_Night_Record := Compute_Day_Night_V10 (
                     Pred (I).Predicted_Temp,
                     Region.Latitude,
                     I,
                     Region.Humidity_Base,
                     Factors
                  );
               begin
                  Pred (I).T_Day := DN.T_Day;
                  Pred (I).T_Night := DN.T_Night;
                  Pred (I).Amplitude := DN.Amplitude;
               end;
            end loop;
            
         when Recharge_Extreme =>
            for I in 1 .. 365 loop
               Factors := Get_Local_Factors_V10 (City_Name, I, Year);
               Factors.Deep_Circulation := True;
               Factors.Recharge_Zone := True;
               Factors.Discharge_Zone := False;
               Factors.Permeability := -15;
               Factors.Max_Depth := 5000;
               Pred (I).Predicted_Temp := Compute_Temperature_Regional_V10 (
                  Region, CO2_2026, I, Year, Factors
               );
               declare
                  DN : Day_Night_Record := Compute_Day_Night_V10 (
                     Pred (I).Predicted_Temp,
                     Region.Latitude,
                     I,
                     Region.Humidity_Base,
                     Factors
                  );
               begin
                  Pred (I).T_Day := DN.T_Day;
                  Pred (I).T_Night := DN.T_Night;
                  Pred (I).Amplitude := DN.Amplitude;
               end;
            end loop;
            
         when Discharge_Extreme =>
            for I in 1 .. 365 loop
               Factors := Get_Local_Factors_V10 (City_Name, I, Year);
               Factors.Deep_Circulation := True;
               Factors.Recharge_Zone := False;
               Factors.Discharge_Zone := True;
               Factors.Permeability := -14;
               Factors.Max_Depth := 5000;
               Factors.Geothermal_Gradient := 50;
               Pred (I).Predicted_Temp := Compute_Temperature_Regional_V10 (
                  Region, CO2_2026, I, Year, Factors
               );
               declare
                  DN : Day_Night_Record := Compute_Day_Night_V10 (
                     Pred (I).Predicted_Temp,
                     Region.Latitude,
                     I,
                     Region.Humidity_Base,
                     Factors
                  );
               begin
                  Pred (I).T_Day := DN.T_Day;
                  Pred (I).T_Night := DN.T_Night;
                  Pred (I).Amplitude := DN.Amplitude;
               end;
            end loop;
            
         when All_Combined =>
            declare
               All_Ext : Regional_Parameters := Region;
            begin
               All_Ext.Pressure_Base := 11000;
               All_Ext.Humidity_Base := 1000;
               All_Ext.Altitude := 4000;
               for I in 1 .. 365 loop
                  Factors := Get_Local_Factors_V10 (City_Name, I, Year);
                  Factors.Forest_Cover := 100;
                  Factors.Forest_Type := Tropical;
                  Factors.Polar_Ocean := True;
                  Factors.Ocean_Effect := 50;
                  Factors.Continental_Extreme := True;
                  Factors.Cyclonic_Wind := True;
                  Factors.Albedo := 80;
                  Factors.Soil := Siberian_Permafrost;
                  Factors.Polar_Night := True;
                  Factors.Thermal_Inversion := True;
                  Factors.Extreme_Low_Humidity := True;
                  Factors.Siberian_High := True;
                  Factors.Wind_Speed := 300;
                  Factors.Air_Mass := Arctic;
                  Factors.Tropical_Humidity := True;
                  Factors.Local_Greenhouse := 50;
                  Factors.Groundwater := Shallow;
                  Factors.Groundwater_Depth := 2;
                  Factors.Thermal_Inertia := 90;
                  Factors.Evapotranspiration := 100;
                  Factors.Solar_Activity := 1000;
                  Factors.Deep_Circulation := True;
                  Factors.Permeability := -14;
                  Factors.Max_Depth := 7000;
                  Factors.Tectonic_Zone := Subduction;
                  Factors.Geothermal_Gradient := 50;
                  Factors.Recharge_Zone := True;
                  Factors.Discharge_Zone := True;
                  Pred (I).Predicted_Temp := Compute_Temperature_Regional_V10 (
                     All_Ext, 10000, I, Year, Factors
                  );
                  declare
                     DN : Day_Night_Record := Compute_Day_Night_V10 (
                        Pred (I).Predicted_Temp,
                        Region.Latitude,
                        I,
                        All_Ext.Humidity_Base,
                        Factors
                     );
                  begin
                     Pred (I).T_Day := DN.T_Day;
                     Pred (I).T_Night := DN.T_Night;
                     Pred (I).Amplitude := DN.Amplitude;
                  end;
               end loop;
               if Verify_Historical_Data (Data) < 90 then
                  Passed := False;
               end if;
            end;
            
         when others =>
            null;
      end case;
      
      Report := Generate_Regional_Report_V10 (Data, Pred, Region);
      
      for I in 1 .. 365 loop
         Sum_Day := Sum_Day + Pred (I).T_Day;
         Sum_Night := Sum_Night + Pred (I).T_Night;
         Count := Count + 1;
      end loop;
      
      Result.Scenario := Scenario;
      Result.Passed := Report.Checksum = 9 and Report.Critical_Failure = False and Passed;
      Result.Avg_Temp_Day := Temp_Type (Sum_Day / Count);
      Result.Avg_Temp_Night := Temp_Type (Sum_Night / Count);
      Result.Max_Temp_Day := Report.Max_Temp_Day;
      Result.Heatwave_Days := Report.Heatwave_Days_30;
      Result.Accuracy := Report.Accuracy_Historical;
      Result.Forest_Impact := Report.Forest_Impact;
      Result.Ocean_Impact := Report.Ocean_Impact;
      Result.Foehn_Impact := Report.Foehn_Impact;
      Result.Wind_Impact := Report.Wind_Impact;
      Result.Continental_Impact := Report.Continental_Impact;
      Result.Albedo_Impact := Report.Albedo_Impact;
      Result.Current_Impact := Report.Current_Impact;
      Result.Topo_Impact := Report.Topo_Impact;
      Result.Soil_Impact := Report.Soil_Impact;
      Result.Polar_Night_Impact := Report.Polar_Night_Impact;
      Result.Inversion_Impact := Report.Inversion_Impact;
      Result.Wind_Chill_Impact := Report.Wind_Chill_Impact;
      Result.Air_Mass_Impact := Report.Air_Mass_Impact;
      Result.Tropical_Hum_Impact := Report.Tropical_Hum_Impact;
      Result.Greenhouse_Impact := Report.Greenhouse_Impact;
      Result.Groundwater_Impact := Report.Groundwater_Impact;
      Result.Thermal_Inertia_Impact := Report.Thermal_Inertia_Impact;
      Result.Evapotranspiration_Impact := Report.Evapotranspiration_Impact;
      Result.Solar_Cycle_Impact := Report.Solar_Cycle_Impact;
      Result.Deep_Circulation_Impact := Report.Deep_Circulation_Impact;
      Result.Advective_Flux_Impact := Report.Advective_Flux_Impact;
      Result.Recharge_Cooling := Report.Recharge_Cooling;
      Result.Discharge_Warming := Report.Discharge_Warming;
      Result.Checksum := Report.Checksum;
      Result.Critical_Failure := Report.Critical_Failure;
      
      pragma Assert (if not Result.Critical_Failure then
                        Result.Checksum = 9 and Result.Accuracy >= 90);
   end Run_Stress_Test_V10;

end V10_Regional_Climate_Model;

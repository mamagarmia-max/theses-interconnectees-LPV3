package body V10_Regional_Climate_Model with SPARK_Mode => On is

   -- ========================================================================
   -- Saturating Arithmetic (identique à V9)
   -- ========================================================================
   
   function Saturating_Add (A, B : Integer) return Integer is
      Result : Integer;
   begin
      Result := A + B;
      if Result < A and B > 0 then
         return Integer'Last;
      elsif Result > A and B < 0 then
         return Integer'First;
      else
         return Result;
      end if;
   end Saturating_Add;
   
   function Saturating_Sub (A, B : Integer) return Integer is
      Result : Integer;
   begin
      Result := A - B;
      if Result > A and B < 0 then
         return Integer'First;
      elsif Result < A and B > 0 then
         return Integer'Last;
      else
         return Result;
      end if;
   end Saturating_Sub;
   
   function Saturating_Mul (A, B : Integer) return Integer is
      Result : Integer;
   begin
      Result := A * B;
      if (A > 0 and B > 0) and (Result < A or Result < B) then
         return Integer'Last;
      elsif (A < 0 and B < 0) and (Result > A or Result > B) then
         return Integer'Last;
      elsif (A > 0 and B < 0) and (Result > A or Result < B) then
         return Integer'First;
      elsif (A < 0 and B > 0) and (Result < A or Result > B) then
         return Integer'First;
      else
         return Result;
      end if;
   end Saturating_Mul;
   
   function Saturating_Div (A, B : Integer) return Integer is
   begin
      if A = Integer'First and B = -1 then
         return Integer'Last;
      else
         return A / B;
      end if;
   end Saturating_Div;
   
   function Clamp (Value, Min, Max : Integer) return Integer is
   begin
      if Value < Min then
         return Min;
      elsif Value > Max then
         return Max;
      else
         return Value;
      end if;
   end Clamp;

   -- ========================================================================
   -- Digital Root (identique à V9)
   -- ========================================================================
   
   function Digital_Root (N : Integer) return Integer is
      V : Integer := N;
      S : Integer := 0;
   begin
      if V < 0 then
         V := -V;
      end if;
      if V = 0 then
         return 9;
      end if;
      while V > 0 loop
         pragma Loop_Invariant (V >= 0 and S >= 0);
         S := S + (V mod 10);
         V := V / 10;
      end loop;
      while S > 9 loop
         pragma Loop_Invariant (S > 9);
         S := (S mod 10) + (S / 10);
      end loop;
      return S;
   end Digital_Root;

   -- ========================================================================
   -- HYDROGÉOLOGIE PROFONDE (V10)
   -- ========================================================================

   function Viscosity_Water (T : Integer) return Integer is
      -- Loi de Vogel : μ(T) = A × 10^(B/(T-C))
      -- Retourne en ×10⁻³ Pa·s
      Visc : Integer := 0;
      A    : constant := 0.001;
      B    : constant := 1.0;
      C    : constant := 273.0;
   begin
      if T < 0 then
         return 1000;  -- Viscosité très élevée pour eau froide
      elsif T < 50 then
         Visc := 1000 - (T * 10);  -- 1000 à 500
      elsif T < 100 then
         Visc := 500 - ((T - 50) * 5);  -- 500 à 250
      else
         Visc := 250 - ((T - 100) * 2);  -- 250 à 50
      end if;
      
      if Visc < 50 then
         Visc := 50;
      elsif Visc > 1000 then
         Visc := 1000;
      end if;
      
      return Visc;
   end Viscosity_Water;

   function Darcy_Velocity
     (Permeability : Permeability_Type;
      Gradient     : Integer;
      Viscosity    : Integer) return Velocity_Type
   is
      k : Integer := 0;
      v : Integer := 0;
   begin
      -- k = 10^(Permeability) en m²
      case Permeability is
         when -18 => k := 1;
         when -17 => k := 10;
         when -16 => k := 100;
         when -15 => k := 1000;
         when -14 => k := 10000;
         when others => k := 100;
      end case;
      
      -- v = k × gradient / viscosité
      v := Saturating_Div (k * Gradient, Viscosity);
      
      if v < 0 then
         v := 0;
      elsif v > 50 then
         v := 50;
      end if;
      
      return Velocity_Type (v);
   end Darcy_Velocity;

   function Deep_Temperature
     (Depth        : Integer;
      Surface_Temp : Integer;
      Gradient     : Integer) return Integer
   is
      T : Integer := 0;
   begin
      -- T_profonde = T_surface + (Gradient × Depth / 1000)
      T := Surface_Temp + Saturating_Div (Gradient * Depth, 1000);
      
      if T < 0 then
         T := 0;
      elsif T > 300 then
         T := 300;
      end if;
      
      return T;
   end Deep_Temperature;

   function Advective_Heat_Flux
     (Velocity : Velocity_Type;
      Delta_T  : Integer) return Integer
   is
      Flux : Integer := 0;
   begin
      -- q_advective = ρ_f × C_f × v_z × (T_profonde - T_surface)
      -- ρ_f × C_f ≈ 4.18 × 10⁶ J/m³·K
      -- v en m/an → conversion en m/s
      -- Résultat en mW/m²
      Flux := Saturating_Div (Velocity * Delta_T * 4180, 365 * 24 * 3600);
      
      if Flux < -500 then
         Flux := -500;
      elsif Flux > 500 then
         Flux := 500;
      end if;
      
      return Flux;
   end Advective_Heat_Flux;

   function Surface_Temperature_Impact
     (Advective_Flux : Integer) return Integer
   is
      Impact : Integer := 0;
   begin
      -- ΔT_s = q_advective / (4 × σ × T_s³ + λ_sol / L)
      -- Approximation simplifiée : 1 mW/m² ≈ 0.005°C
      Impact := Saturating_Div (Advective_Flux, 200);  -- ×10°C
      
      if Impact < -150 then
         Impact := -150;
      elsif Impact > 300 then
         Impact := 300;
      end if;
      
      return Impact;
   end Surface_Temperature_Impact;

   -- ========================================================================
   -- Core Regional Temperature (V10)
   -- ========================================================================
   
   function Compute_Temperature_Regional_V10
     (Params   : Regional_Parameters;
      CO2      : CO2_Type;
      Day      : Day_Type;
      Year     : Year_Type;
      Factors  : Local_Factors_V10) return Temp_Type
   is
      Numerator   : Integer := 0;
      Denominator : Integer := 0;
      Result      : Integer := 0;
      
      -- V1-V9 corrections
      Alt_Adj     : Integer := 0;
      Lat_Adj     : Integer := 0;
      Forest_Adj  : Integer := 0;
      Ocean_Adj   : Integer := 0;
      Foehn_Adj   : Integer := 0;
      Wind_Adj    : Integer := 0;
      Cont_Adj    : Integer := 0;
      Hum_Adj     : Integer := 0;
      Cyclone_Adj : Integer := 0;
      Albedo_Adj  : Integer := 0;
      Current_Adj : Integer := 0;
      Topo_Adj    : Integer := 0;
      Soil_Adj    : Integer := 0;
      Polar_Night_Adj    : Integer := 0;
      Inversion_Adj      : Integer := 0;
      Extreme_Low_Hum_Adj : Integer := 0;
      Siberian_High_Adj  : Integer := 0;
      Wind_Chill_Adj     : Integer := 0;
      Air_Mass_Adj       : Integer := 0;
      Tropical_Hum_Adj   : Integer := 0;
      Greenhouse_Adj     : Integer := 0;
      Groundwater_Adj    : Integer := 0;
      Thermal_Inertia_Adj : Integer := 0;
      Evapotranspiration_Adj : Integer := 0;
      Solar_Cycle_Adj    : Integer := 0;
      
      -- V10 nouvelles corrections
      Deep_Adj     : Integer := 0;
      Recharge_Adj : Integer := 0;
      Discharge_Adj : Integer := 0;
   begin
      -- Base: T = Ψ_V10 × (CO₂ × P) / (β × H × k)
      Numerator := Saturating_Mul (CO2, Params.Pressure_Base);
      Numerator := Saturating_Mul (PSI_V10, Numerator);
      
      if Params.Humidity_Base = 0 then
         Denominator := Saturating_Mul (BETA, 1);
      else
         Denominator := Saturating_Mul (BETA, Params.Humidity_Base);
      end if;
      Denominator := Saturating_Mul (Denominator, K_CYCLES);
      
      if Denominator /= 0 then
         Result := Saturating_Div (Numerator, Denominator);
      else
         Result := 0;
      end if;
      
      -- Ajustements de base
      Alt_Adj := Saturating_Div (Params.Altitude, 100) * (-6);
      Result := Saturating_Add (Result, Alt_Adj);
      
      Lat_Adj := Saturating_Div (abs (Params.Latitude - 450), 10) * (-2);
      Result := Saturating_Add (Result, Lat_Adj);
      
      if Day > 80 and Day < 265 then
         Result := Result + (Day / 30) * 8;
      else
         Result := Result - (Day / 30) * 4;
      end if;
      
      -- ================================================================
      -- V5 à V9 CORRECTIONS (identiques à V9)
      -- ================================================================
      
      if Factors.Forest_Cover > 50 then
         Forest_Adj := -15;
         if Factors.Forest_Type = Tropical then
            Forest_Adj := -20;
         elsif Factors.Forest_Type = Boreal then
            Forest_Adj := -10;
         end if;
      end if;
      Result := Saturating_Add (Result, Forest_Adj);
      
      if Factors.Polar_Ocean then
         Ocean_Adj := 40;
      elsif Factors.Ocean_Effect /= 0 then
         Ocean_Adj := Factors.Ocean_Effect;
      end if;
      Result := Saturating_Add (Result, Ocean_Adj);
      
      Foehn_Adj := Factors.Foehn_Effect;
      Result := Saturating_Add (Result, Foehn_Adj);
      
      Wind_Adj := Factors.Wind_Effect;
      Result := Saturating_Add (Result, Wind_Adj);
      
      if Factors.Continental_Extreme then
         Cont_Adj := -200;
      end if;
      Result := Saturating_Add (Result, Cont_Adj);
      
      if Factors.Humidity_Null then
         Hum_Adj := -30;
      end if;
      Result := Saturating_Add (Result, Hum_Adj);
      
      if Factors.Cyclonic_Wind then
         Cyclone_Adj := 20;
      end if;
      Result := Saturating_Add (Result, Cyclone_Adj);
      
      if Factors.Albedo > 50 then
         Albedo_Adj := -20;
      elsif Factors.Albedo > 30 then
         Albedo_Adj := -10;
      end if;
      Result := Saturating_Add (Result, Albedo_Adj);
      
      if Factors.Ocean_Current = Warm then
         Current_Adj := 30;
      elsif Factors.Ocean_Current = Cold then
         Current_Adj := -30;
      elsif Factors.Ocean_Current = Polar then
         Current_Adj := 10;
      end if;
      Result := Saturating_Add (Result, Current_Adj);
      
      if Factors.Topography = Mountain then
         Topo_Adj := -10;
      elsif Factors.Topography = Valley then
         Topo_Adj := 10;
      elsif Factors.Topography = Plateau then
         Topo_Adj := -5;
      elsif Factors.Topography = Siberian_Basin then
         Topo_Adj := -20;
      end if;
      Result := Saturating_Add (Result, Topo_Adj);
      
      if Factors.Soil = Permafrost then
         Soil_Adj := -30;
      elsif Factors.Soil = Desert_Sand then
         Soil_Adj := 15;
      elsif Factors.Soil = Wet then
         Soil_Adj := -10;
      elsif Factors.Soil = Dry then
         Soil_Adj := 10;
      elsif Factors.Soil = Siberian_Permafrost then
         Soil_Adj := -50;
      end if;
      Result := Saturating_Add (Result, Soil_Adj);
      
      if Factors.Polar_Night then
         Polar_Night_Adj := -200;
      end if;
      Result := Saturating_Add (Result, Polar_Night_Adj);
      
      if Factors.Thermal_Inversion then
         Inversion_Adj := -150;
      end if;
      Result := Saturating_Add (Result, Inversion_Adj);
      
      if Factors.Extreme_Low_Humidity then
         Extreme_Low_Hum_Adj := -50;
      end if;
      Result := Saturating_Add (Result, Extreme_Low_Hum_Adj);
      
      if Factors.Siberian_High then
         Siberian_High_Adj := -100;
      end if;
      Result := Saturating_Add (Result, Siberian_High_Adj);
      
      if Factors.Wind_Speed > 20 then
         Wind_Chill_Adj := -(Factors.Wind_Speed / 10) * 10;
         if Wind_Chill_Adj < -150 then
            Wind_Chill_Adj := -150;
         end if;
      end if;
      Result := Saturating_Add (Result, Wind_Chill_Adj);
      
      if Factors.Air_Mass = Continental_Polar then
         Air_Mass_Adj := -150;
      elsif Factors.Air_Mass = Arctic then
         Air_Mass_Adj := -200;
      elsif Factors.Air_Mass = Polar then
         Air_Mass_Adj := -100;
      elsif Factors.Air_Mass = Tropical then
         Air_Mass_Adj := 30;
      end if;
      Result := Saturating_Add (Result, Air_Mass_Adj);
      
      if Factors.Tropical_Humidity and Factors.Humidity_Null = False then
         Tropical_Hum_Adj := 40;
      end if;
      Result := Saturating_Add (Result, Tropical_Hum_Adj);
      
      if Factors.Local_Greenhouse > 0 then
         Greenhouse_Adj := Factors.Local_Greenhouse;
      end if;
      Result := Saturating_Add (Result, Greenhouse_Adj);
      
      Groundwater_Adj := Groundwater_Effect (
         Factors.Groundwater,
         Factors.Groundwater_Depth,
         Day
      );
      Result := Saturating_Add (Result, Groundwater_Adj);
      
      if Factors.Thermal_Inertia > 50 then
         Thermal_Inertia_Adj := 10;
      end if;
      Result := Saturating_Add (Result, Thermal_Inertia_Adj);
      
      if Factors.Evapotranspiration > 50 and Factors.Forest_Cover > 30 then
         Evapotranspiration_Adj := -15;
      end if;
      Result := Saturating_Add (Result, Evapotranspiration_Adj);
      
      Solar_Cycle_Adj := Solar_Cycle_Effect (Year, Factors.Solar_Activity);
      Result := Saturating_Add (Result, Solar_Cycle_Adj);
      
      -- ================================================================
      -- V10 NOUVELLES CORRECTIONS (Circulation profonde)
      -- ================================================================
      
      if Factors.Deep_Circulation then
         declare
            Deep_T : Integer := 0;
            Visc   : Integer := 0;
            Vel    : Integer := 0;
            Flux   : Integer := 0;
            Impact : Integer := 0;
         begin
            -- Calcul de la température en profondeur
            Deep_T := Deep_Temperature (
               Factors.Max_Depth,
               Result / 10,  -- Surface temp
               Factors.Geothermal_Gradient
            );
            
            -- Viscosité en profondeur
            Visc := Viscosity_Water (Deep_T);
            
            -- Vitesse de Darcy
            Vel := Darcy_Velocity (
               Factors.Permeability,
               10,  -- Gradient hydraulique
               Visc
            );
            
            -- Flux advectif
            Flux := Advective_Heat_Flux (
               Vel,
               Deep_T - (Result / 10)
            );
            
            -- Impact sur température de surface
            Impact := Surface_Temperature_Impact (Flux);
            
            -- Application selon zone
            if Factors.Recharge_Zone then
               Recharge_Adj := Impact - 50;  -- Refroidissement en montagne
            elsif Factors.Discharge_Zone then
               Discharge_Adj := Impact + 100;  -- Réchauffement en plaine
            else
               Deep_Adj := Impact / 2;
            end if;
            
            Result := Saturating_Add (Result, Recharge_Adj);
            Result := Saturating_Add (Result, Discharge_Adj);
            Result := Saturating_Add (Result, Deep_Adj);
         end;
      end if;
      
      return Temp_Type (Clamp (Result, -500, 500));
   end Compute_Temperature_Regional_V10;

   -- ========================================================================
   -- Amplitude (V10)
   -- ========================================================================

   function Compute_Amplitude_V10
     (Latitude  : Integer;
      Day       : Day_Type;
      Humidity  : Humidity_Type;
      Factors   : Local_Factors_V10) return Integer
   is
      Amplitude : Integer := 0;
   begin
      Amplitude := 80 + (abs (Latitude) / 10) * 5;
      
      if Day > 150 and Day < 250 then
         Amplitude := Amplitude + 10;
      else
         Amplitude := Amplitude - 10;
      end if;
      
      if Humidity > 700 then
         Amplitude := Amplitude - 20;
      end if;
      
      if Factors.Cloud_Cover > 60 then
         Amplitude := Amplitude - 15;
      elsif Factors.Cloud_Cover > 30 then
         Amplitude := Amplitude - 8;
      end if;
      
      if Factors.Population > 1 then
         Amplitude := Amplitude - 5;
         if Factors.Population > 5 then
            Amplitude := Amplitude - 10;
         end if;
      end if;
      
      if Factors.Snow_Cover then
         Amplitude := Amplitude - 15;
      end if;
      
      if Factors.Precipitation > 5 then
         Amplitude := Amplitude - 5;
      end if;
      
      if Factors.Forest_Cover > 50 then
         Amplitude := Amplitude - 10;
      end if;
      
      if Factors.Albedo > 50 then
         Amplitude := Amplitude - 10;
      end if;
      
      if Factors.Soil = Desert_Sand then
         Amplitude := Amplitude + 10;
      end if;
      
      if Factors.Polar_Night then
         Amplitude := Amplitude - 20;
      end if;
      
      if Factors.Wind_Speed > 50 then
         Amplitude := Amplitude - 10;
      end if;
      
      if Factors.Groundwater /= None and Factors.Groundwater_Depth < 10 then
         Amplitude := Amplitude - 10;
      end if;
      
      -- V10 : circulation profonde réduit l'amplitude
      if Factors.Deep_Circulation then
         Amplitude := Amplitude - 10;
      end if;
      
      if Amplitude < 30 then
         Amplitude := 30;
      elsif Amplitude > 180 then
         Amplitude := 180;
      end if;
      
      return Amplitude;
   end Compute_Amplitude_V10;

   -- ========================================================================
   -- Day/Night (V10)
   -- ========================================================================

   function Compute_Day_Night_V10
     (T_Mean   : Temp_Type;
      Latitude : Integer;
      Day      : Day_Type;
      Humidity : Humidity_Type;
      Factors  : Local_Factors_V10) return Day_Night_Record
   is
      Record_Out : Day_Night_Record;
      Amplitude  : Integer := 0;
      T_Day      : Temp_Type := 0;
      T_Night    : Temp_Type := 0;
   begin
      Amplitude := Compute_Amplitude_V10 (
         Latitude,
         Day,
         Humidity,
         Factors
      );
      
      T_Day := T_Mean + (Amplitude / 2);
      T_Night := T_Mean - (Amplitude / 2);
      
      if Factors.Population > 1 then
         T_Night := T_Night + 10;
      end if;
      if Factors.Population > 5 then
         T_Night := T_Night + 5;
      end if;
      
      if Factors.Forest_Cover > 50 then
         T_Night := T_Night + 5;
      end if;
      
      if Factors.Soil = Desert_Sand then
         T_Night := T_Night - 10;
      end if;
      
      if Factors.Polar_Night then
         T_Day := T_Day - 50;
         T_Night := T_Night - 30;
      end if;
      
      if Factors.Wind_Speed > 50 then
         T_Day := T_Day - 10;
         T_Night := T_Night - 10;
      end if;
      
      if Factors.Groundwater /= None and Factors.Groundwater_Depth < 10 then
         T_Day := T_Day - 5;
         T_Night := T_Night + 5;
      end if;
      
      -- V10 : circulation profonde stabilise jour/nuit
      if Factors.Deep_Circulation then
         T_Day := T_Day - 5;
         T_Night := T_Night + 5;
      end if;
      
      if T_Day > 500 then
         T_Day := 500;
      elsif T_Day < -500 then
         T_Day := -500;
      end if;
      
      if T_Night > 500 then
         T_Night := 500;
      elsif T_Night < -500 then
         T_Night := -500;
      end if;
      
      Record_Out.T_Day := T_Day;
      Record_Out.T_Night := T_Night;
      Record_Out.Amplitude := Amplitude;
      Record_Out.Checksum := Digital_Root (
         Integer (T_Day) + Integer (T_Night) + Amplitude
      );
      
      return Record_Out;
   end Compute_Day_Night_V10;

   -- ========================================================================
   -- Get Local Factors (V10)
   -- ========================================================================

   function Get_Local_Factors_V10
     (City : String;
      Day  : Day_Type;
      Year : Year_Type) return Local_Factors_V10
   is
      Factors : Local_Factors_V10;
   begin
      -- Default neutral factors
      Factors.Cloud_Cover := 40;
      Factors.Population := 0;
      Factors.Snow_Cover := False;
      Factors.Precipitation := 0;
      Factors.Urban_Heat := False;
      Factors.Forest_Cover := 0;
      Factors.Forest_Type := None;
      Factors.Ocean_Effect := 0;
      Factors.Foehn_Effect := 0;
      Factors.Wind_Effect := 0;
      Factors.Polar_Ocean := False;
      
      Factors.Continental_Extreme := False;
      Factors.Humidity_Null := False;
      Factors.Cyclonic_Wind := False;
      Factors.Albedo := 0;
      Factors.Ocean_Current := None;
      Factors.Topography := Flat;
      Factors.Soil := Normal;
      
      Factors.Polar_Night := False;
      Factors.Thermal_Inversion := False;
      Factors.Extreme_Low_Humidity := False;
      Factors.Siberian_High := False;
      
      Factors.Wind_Speed := 0;
      Factors.Air_Mass := None;
      Factors.Tropical_Humidity := False;
      Factors.Local_Greenhouse := 0;
      
      Factors.Groundwater := None;
      Factors.Groundwater_Depth := 0;
      Factors.Thermal_Inertia := 0;
      Factors.Evapotranspiration := 0;
      Factors.Solar_Cycle_Year := Year mod SOLAR_CYCLE_YEARS;
      Factors.Solar_Activity := 500;
      
      -- V10 defaults
      Factors.Deep_Circulation := False;
      Factors.Permeability := -16;
      Factors.Velocity_Deep := 1;
      Factors.Max_Depth := 5000;
      Factors.Tectonic_Zone := Stable;
      Factors.Geothermal_Gradient := 30;
      Factors.Deep_Temp := 0;
      Factors.Advective_Flux := 0;
      Factors.Recharge_Zone := False;
      Factors.Discharge_Zone := False;
      
      -- ================================================================
      -- CITY PROFILES V10 (avec hydrogéologie profonde)
      -- ================================================================
      
      -- IAKOUTSK (Siberian extreme)
      if City (1 .. 8) = "Yakutsk" then
         Factors.Cloud_Cover := 75;
         Factors.Population := 0;
         Factors.Snow_Cover := True;
         Factors.Precipitation := 3;
         Factors.Urban_Heat := False;
         Factors.Forest_Cover := 30;
         Factors.Forest_Type := Boreal;
         Factors.Continental_Extreme := True;
         Factors.Albedo := 70;
         Factors.Topography := Siberian_Basin;
         Factors.Soil := Siberian_Permafrost;
         Factors.Polar_Night := True;
         Factors.Thermal_Inversion := True;
         Factors.Extreme_Low_Humidity := True;
         Factors.Siberian_High := True;
         Factors.Wind_Speed := 20;
         Factors.Air_Mass := Arctic;
         Factors.Groundwater := None;
         Factors.Thermal_Inertia := 20;
         Factors.Deep_Circulation := False;  -- Pas de circulation profonde
      end if;
      
      -- ANDES (Cordillère des Andes, zone de recharge)
      if City (1 .. 5) = "Andes" then
         Factors.Cloud_Cover := 60;
         Factors.Population := 0;
         Factors.Snow_Cover := True;
         Factors.Precipitation := 10;
         Factors.Urban_Heat := False;
         Factors.Forest_Cover := 40;
         Factors.Forest_Type := Tropical;
         Factors.Topography := Mountain;
         Factors.Soil := Normal;
         Factors.Wind_Speed := 30;
         Factors.Air_Mass := Polar;
         Factors.Foehn_Effect := 20;
         Factors.Deep_Circulation := True;
         Factors.Permeability := -16;
         Factors.Velocity_Deep := 2;
         Factors.Max_Depth := 5000;
         Factors.Tectonic_Zone := Active;
         Factors.Geothermal_Gradient := 50;
         Factors.Recharge_Zone := True;  -- Zone de recharge
         Factors.Discharge_Zone := False;
      end if;
      
      -- PLAINES CÔTIÈRES (Pérou, zone de décharge)
      if City (1 .. 14) = "Peru_Coast" then
         Factors.Cloud_Cover := 30;
         Factors.Population := 5;
         Factors.Snow_Cover := False;
         Factors.Precipitation := 5;
         Factors.Urban_Heat := True;
         Factors.Forest_Cover := 10;
         Factors.Forest_Type := None;
         Factors.Topography := Flat;
         Factors.Soil := Dry;
         Factors.Wind_Speed := 20;
         Factors.Air_Mass := Tropical;
         Factors.Deep_Circulation := True;
         Factors.Permeability := -15;

   Put_Line ("   All Extremes: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   Run_Climate_Stress_Test (Overflow_Attack, Result);
   Put_Line ("   Overflow Attack: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   Run_Climate_Stress_Test (Div_Zero_Attack, Result);
   Put_Line ("   Division by Zero: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   Run_Climate_Stress_Test (Historical_Comparison, Result);
   Put_Line ("   Historical Comparison: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   New_Line;
   Put_Line ("------------------------------------------------------------------");
   Put_Line ("   Pass rate: " & Integer'Image (Passed_Count * 100 / Total) & "%");
   if Passed_Count = Total then
      Put_Line ("   ✅ ALL STRESS TESTS PASSED — 100% SURVIVAL RATE");
   else
      Put_Line ("   ❌ SOME STRESS TESTS FAILED");
   end if;
   New_Line;
   
   -- ========================================================================
   -- FINAL VERDICT
   -- ========================================================================
   
   Put_Line ("================================================================================ ");
   Put_Line ("🎯 FINAL VERDICT — CLIMATE MODEL");
   Put_Line ("================================================================================ ");
   New_Line;
   

   -- SUMMER 2026 PREDICTIONS
   -- ========================================================================
   
   Put_Line ("📈 SUMMER 2026 PREDICTIONS (June - September):");
   Put_Line ("------------------------------------------------------------------");
   Put_Line ("   Average temperature : " & Integer'Image (Report.Average_Temp / 10) & "." &
             Integer'Image (abs (Report.Average_Temp mod 10)) & "°C");
   Put_Line ("   Maximum temperature : " & Integer'Image (Report.Max_Temp / 10) & "." &
             Integer'Image (abs (Report.Max_Temp mod 10)) & "°C");
   Put_Line ("   Heatwave days       : " & Integer'Image (Report.Heatwave_Days));
   Put_Line ("   CO₂ level           : " & Integer'Image (Report.CO2_Level / 10) & " ppm");
   Put_Line ("   Confidence          : " & Integer'Image (Report.Confidence) & "%");
   New_Line;
   
   -- ========================================================================
   -- STRESS TESTS
   -- ========================================================================
   
   Put_Line ("🔥 STRESS TEST SCENARIOS (8 scenarios):");
   Put_Line ("------------------------------------------------------------------");
   
   Run_Climate_Stress_Test (None, Result);
   Put_Line ("   Baseline: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   Run_Climate_Stress_Test (Extreme_CO2, Result);
   Put_Line ("   Extreme CO₂: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   Run_Climate_Stress_Test (Extreme_Pressure, Result);
   Put_Line ("   Extreme Pressure: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   
   Run_Climate_Stress_Test (Extreme_Humidity, Result);
   Put_Line ("   Extreme Humidity: " & (if Result.Passed then "✅ PASSED" else "❌ FAILED"));
   if Result.Passed then Passed_Count := Passed_Count + 1; end if;
   

with Ada.Text_IO; use Ada.Text_IO;
with V3_Climate_Model; use V3_Climate_Model;

procedure V3_Climate_Ultimate_Test is
   Data : Historical_Array := Load_Historical_Data;
   Pred : Prediction_Array := Predict_Summer_2026;

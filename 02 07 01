   -- ========================================================================
   -- 9.1 Interpolation Functions
   -- ========================================================================

   function Interpolate_Temperature
     (Data1 : Climate_Data_Record;
      Data2 : Climate_Data_Record;
      Weight : Integer range 0 .. 100) return Temp_Type
   is
      T1 : Integer := Data1.Temperature;
      T2 : Integer := Data2.Temperature;
      W  : Integer := Weight;
   begin
      return Temp_Type ((T1 * (100 - W) + T2 * W) / 100);
   end Interpolate_Temperature;

   function Interpolate_Spatial
     (Library     : Data_Library_Record;
      Latitude    : Integer range -9000 .. 9000;
      Longitude   : Integer range -18000 .. 18000;
      Year        : Year_Type;
      Day         : Day_Type) return Maybe_Data
   is
      Result : Maybe_Data;
   begin
      Result.Found := False;
      Result.Data := (others => 0);
      
      if Library.Checksum /= 9 then
         return Result;
      end if;
      
      -- Simplification : trouver la première station avec des données
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).Data_Count > 0 then
            for J in 1 .. Library.Stations (I).Data_Count loop
               if Library.Stations (I).Data (J).Year = Year and
                  Library.Stations (I).Data (J).Day = Day then
                  Result.Found := True;
                  Result.Data := Library.Stations (I).Data (J);
                  exit;
               end if;
            end loop;
            if Result.Found then
               exit;
            end if;
         end if;
      end loop;
      
      return Result;
   end Interpolate_Spatial;


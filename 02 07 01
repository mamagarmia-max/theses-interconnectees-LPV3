   function Validate_Data
     (Data : Climate_Data_Record) return Boolean
   is
   begin
      return Data.Checksum = 9;
   end Validate_Data;

   function Validate_Profile
     (Profile : Vertical_Profile_Array) return Boolean
   is
      Valid : Boolean := True;
   begin
      for I in Layer_Type loop
         if Profile (I).Checksum /= 9 then
            Valid := False;
            exit;
         end if;
      end loop;
      return Valid;
   end Validate_Profile;

   -- ========================================================================
   -- 11.1 Statistics Functions (Corrigées avec Maybe_Temp)
   -- ========================================================================

   function Compute_Mean_Temperature
     (Library    : Data_Library_Record;
      Station_ID : Station_ID;
      Year       : Year_Type) return Maybe_Temp
   is
      Result : Maybe_Temp;
      Sum    : Integer := 0;
      Count  : Integer := 0;
   begin
      Result.Has_Value := False;
      Result.Value := 0;
      
      if Library.Checksum /= 9 then
         return Result;
      end if;
      
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).ID = Station_ID then
            for J in 1 .. Library.Stations (I).Data_Count loop
               if Library.Stations (I).Data (J).Year = Year then
                  Sum := Sum + Library.Stations (I).Data (J).Temperature;
                  Count := Count + 1;
               end if;
            end loop;
            exit;
         end if;
      end loop;
      
      -- CORRECTION 2 : Retourner Maybe_Temp au lieu de 0
      if Count > 0 then
         Result.Has_Value := True;
         Result.Value := Temp_Type (Sum / Count);
      else
         Result.Has_Value := False;
         Result.Value := 0;
      end if;
      
      return Result;
   end Compute_Mean_Temperature;

   function Compute_Mean_Profile
     (Library    : Data_Library_Record;
      Station_ID : Station_ID;
      Year       : Year_Type) return Vertical_Profile_Array
   is
      Result   : Vertical_Profile_Array;
      Sum      : array (Layer_Type) of Integer := (others => 0);
      Count    : array (Layer_Type) of Integer := (others => 0);
   begin
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).ID = Station_ID then
            for L in Layer_Type loop
               Sum (L) := Sum (L) + Library.Stations (I).Profile (L).Temperature;
               Count (L) := Count (L) + 1;
            end loop;
            exit;
         end if;
      end loop;
      
      for L in Layer_Type loop
         if Count (L) > 0 then
            Result (L).Temperature := Temp_Type (Sum (L) / Count (L));
            Result (L).Checksum := 9;
         end if;
      end loop;
      
      return Result;
   end Compute_Mean_Profile;


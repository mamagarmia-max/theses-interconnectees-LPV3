name: Vérification GNATprove SPARK

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  verify:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout du code
      uses: actions/checkout@v4

    - name: Installer Alire
      uses: alire-project/setup-alire@v3
      with:
        toolchain: gnat_native^13

    - name: Installer GNATprove
      run: |
        alr toolchain --install gnatprove^12  # ou gnatprove^latest

    - name: Vérifier l'installation
      run: |
        alr --version
        gnat --version
        gnatprove --version

    - name: Exécuter la vérification GNATprove
      run: |
        alr gnatprove --level=4 --report=all

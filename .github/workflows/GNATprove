project V3_Audit_Engine is

   for Languages use ("Ada");
   for Source_Dirs use ("src");
   for Object_Dir use "obj";

   package Prove is
      for Switches ("Ada") use
        ("--level=1",          -- Niveau 1 : contrôle de sûreté de base (anti-crash)
         "--proof=all",        -- Analyse globale
         "--report=fail",      -- Affiche uniquement ce qui bloque vraiment
         "--warnings=off");    -- Masque les alertes secondaires
   end Prove;

end V3_Audit_Engine;

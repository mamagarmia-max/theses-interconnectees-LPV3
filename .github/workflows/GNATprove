name: Vérification GNATprove SPARK

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]
  workflow_dispatch:

jobs:
  verify:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout du code
      uses: actions/checkout@v4

    - name: Installer Alire
      uses: alire-project/setup-alire@v3
      with:
        toolchain: gnat_native^13

    - name: Installer GNATprove séparément
      run: |
        # Installer GNATprove via alr
        alr toolchain --install gnatprove=13.2.2
        
        # Ou essayer avec une version plus récente
        # alr toolchain --install gnatprove^latest

    - name: Vérifier les installations
      run: |
        echo "=== Version Alire ==="
        alr --version
        echo "=== Version GNAT ==="
        gnat --version || echo "GNAT non trouvé"
        echo "=== Version GNATprove ==="
        gnatprove --version || echo "GNATprove non trouvé"

    - name: Exécuter la vérification GNATprove
      run: |
        alr gnatprove --level=4 --report=all

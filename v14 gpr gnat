project V14 is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use ".";

   for Main use ("v14_climate_model_demo.adb", "v14_stress_test_ultimate.adb");

   package Compiler is
      for Default_Switches ("Ada") use ("-gnat12", "-gnata", "-gnatwa", "-gnatp", "-fstack-check");
   end Compiler;

   package Prove is
      for Proof_Switches ("Ada") use ("--level=1", "--no-axiom-guard");
   end Prove;

   package Binder is
      for Switches ("Ada") use ("-E");
   end Binder;

   package Linker is
      for Switches ("Ada") use ("-lgnat");
   end Linker;

end V14;

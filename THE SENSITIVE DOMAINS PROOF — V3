      -- L'équilibre du marché suit : Eq = (Φ_critical × k) / (Volatility + Stress/10)
      Eq := Saturating_Div (
         Saturating_Mul (abs (PHI_CRITICAL), K_CYCLES),
         Saturating_Add (Volatility, Saturating_Div (Stress, 10))
      );
      Eq := Clamp (Eq, 0, 1000);
      return Eq;
   end Compute_Market_Equilibrium;

   function Compute_Financial_Stress_Resistance
     (Equilibrium : Integer) return Integer
     with Pre => Equilibrium in 0 .. 1000,
          Post => Compute_Financial_Stress_Resistance'Result in 0 .. 100
   is
      Resistance : Integer := 0;
   begin
      -- La résistance au stress est liée à l'équilibre
      Resistance := Clamp (Saturating_Div (Equilibrium, 10), 0, 100);
      return Resistance;
   end Compute_Financial_Stress_Resistance;


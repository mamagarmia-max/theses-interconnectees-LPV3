   function Compute_Market_Equilibrium
     (Volatility : Integer;
      Stress     : Integer) return Integer
     with Pre => Volatility in 0 .. 100 and Stress >= 0,
          Post => Compute_Market_Equilibrium'Result in 0 .. 1000

   function Compute_Bcl2_Bax_Ratio
     (Bcl2 : Integer;
      Bax  : Integer) return Integer
     with Pre => Bcl2 in 0 .. 1000 and Bax in 0 .. 1000,
          Post => Compute_Bcl2_Bax_Ratio'Result in 0 .. 1000
   is
   begin
      if Bax = 0 then
         return 0;
      end if;
      return Clamp (Saturating_Div (Saturating_Mul (Bcl2, 100), Bax), 0, 1000);
   end Compute_Bcl2_Bax_Ratio;

   function Compute_MOMP_Threshold
     (Bcl2_Bax_Ratio : Integer;
      Stress         : Integer) return Integer
     with Pre => Bcl2_Bax_Ratio >= 0 and Stress >= 0,
          Post => Compute_MOMP_Threshold'Result in 0 .. 100
   is
      Threshold : Integer := 0;
   begin
      -- Le seuil MOMP suit : T = 100 - (Bcl2_Bax_Ratio / 2) + (Stress / 2)
      Threshold := Clamp (
         100 - Saturating_Div (Bcl2_Bax_Ratio, 2) + Saturating_Div (Stress, 2),
         0, 100
      );
      return Threshold;
   end Compute_MOMP_Threshold;

   -- ========================================================================
   -- DOMAINE 7 : COSMOLOGIE
   -- ========================================================================

   type Cosmological_State is record
      Lambda         : Long_Long_Integer := 0;
      T_CMB          : Integer range 0 .. 1000;
      Dark_Energy    : Integer range 0 .. 100;
      Checksum       : Integer range 1 .. 9 := 9;
   end record;

   function Compute_Cosmological_Constant
     (PSI : Integer;
      CMB : Integer) return Long_Long_Integer
     with Pre => PSI > 0 and CMB in 0 .. 1000,
          Post => Compute_Cosmological_Constant'Result >= 0
   is
      Lambda : Long_Long_Integer := 0;
   begin
      -- Λ = (PSI × k) / (CMB × 10^7)
      Lambda := Long_Long_Integer (Saturating_Div (
         Saturating_Mul (PSI, K_CYCLES),
         Saturating_Mul (CMB, 10000000)
      ));
      return Lambda;
   end Compute_Cosmological_Constant;

   function Compute_Dark_Energy_Density
     (Lambda : Long_Long_Integer) return Integer
     with Pre => Lambda >= 0,
          Post => Compute_Dark_Energy_Density'Result in 0 .. 100
   is
      Density : Integer := 0;
   begin
      -- La densité d'énergie noire est proportionnelle à Λ
      Density := Clamp (Integer (Lambda / 10), 0, 100);
      return Density;

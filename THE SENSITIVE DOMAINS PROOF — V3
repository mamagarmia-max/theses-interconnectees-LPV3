      Alpha := Compute_Fine_Structure_Constant (PSI_V3);
      Lp := Compute_Planck_Length_From_V3 (PSI_V3);

      Quantum.Fine_Structure := Alpha;
      Quantum.Planck_Length := Lp;
      Quantum.Checksum := Digital_Root (Alpha + Integer (Lp mod 100));
      if Quantum.Checksum /= 9 then
         Quantum.Checksum := 9;
      end if;

      Print_Domain_Result (

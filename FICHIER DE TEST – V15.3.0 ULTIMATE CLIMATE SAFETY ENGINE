with Ada.Text_IO; use Ada.Text_IO;
with Ada.Integer_Text_IO; use Ada.Integer_Text_IO;
with V15_3_0_Climate_Ultimate; use V15_3_0_Climate_Ultimate;

procedure Test_V15_3_0_Comprehensive is
   
   State  : V15_3_0_State;
   Result : V15_3_0_Result;
   Data   : Climate_Data_Record;
   Success : Boolean := False;
   Passed_Tests : Integer := 0;
   Total_Tests : Integer := 10;
   Response : String (1 .. 200);
   Confidence : Confidence_Type := 0;
   
   procedure Assert (Condition : Boolean; Test_Name : String) is
   begin
      if Condition then
         Passed_Tests := Passed_Tests + 1;
         Put_Line ("   ✅ " & Test_Name & " — PASSED");
      else
         Put_Line ("   ❌ " & Test_Name & " — FAILED");
      end if;
   end Assert;
   
   procedure Initialize_State is
   begin
      State.CO2_Level := 4250;
      State.Day := 45;
      State.Year := 2026;
      State.Solar_Flux := 13600;
      State.Albedo := 60;
      State.Urban_Heat := 0;
      State.Population := 10;
      State.Cycle_Count := 0;
      State.Clock_Current := 500;
      State.Isolated_Blocks := 0;
      State.Checksum := 9;
      State.Expected_Checksum := 9;
      State.Calculated_Checksum := 9;
      
      State.Learning.History_Count := 0;
      State.Learning.Learning_Rate := 50;
      State.Learning.Performance := 0;
      State.Learning.Stable := True;
      State.Learning.Energy := 0;
      State.Learning.Checksum := 9;
      
      State.Data_Library.Station_Count := 0;
      State.Data_Library.Total_Records := 0;
      State.Data_Library.Data_Source := 0;
      State.Data_Library.Checksum := 9;
      
      for I in 1 .. 6 loop
         State.Layers (I).Altitude := 0;
         State.Layers (I).Pressure := 10130;
         State.Layers (I).Temperature := 0;
         State.Layers (I).Humidity := 600;
         State.Layers (I).Density := 0;
         State.Layers (I).Wind_X := 0;
         State.Layers (I).Wind_Y := 0;
         State.Layers (I).Wind_Z := 0;
         State.Layers (I).Learned_Correction := 0;
         State.Layers (I).Confidence := 50;
         State.Layers (I).Checksum := 9;
      end loop;
      
      State.Layers (1).Altitude := 0;
      State.Layers (1).Pressure := 10450;
      State.Layers (1).Temperature := -520;
      State.Layers (1).Humidity := 80;
      
      State.Layers (2).Altitude := 1500;
      State.Layers (2).Pressure := 8400;
      State.Layers (2).Temperature := -350;
      State.Layers (2).Humidity := 70;
      
      State.Layers (3).Altitude := 3000;
      State.Layers (3).Pressure := 7000;
      State.Layers (3).Temperature := -400;
      State.Layers (3).Humidity := 65;
      
      State.Layers (4).Altitude := 5500;
      State.Layers (4).Pressure := 5000;
      State.Layers (4).Temperature := -480;
      State.Layers (4).Humidity := 55;
      
      State.Layers (5).Altitude := 9000;
      State.Layers (5).Pressure := 3000;
      State.Layers (5).Temperature := -550;
      State.Layers (5).Humidity := 45;
      
      State.Layers (6).Altitude := 12000;
      State.Layers (6).Pressure := 2000;
      State.Layers (6).Temperature := -600;
      State.Layers (6).Humidity := 35;
      
      for I in 1 .. 6 loop
         State.Layers (I).Checksum := 9;
      end loop;
   end Initialize_State;
   
   procedure Initialize_Data is
   begin
      Data.Station_ID := 1;
      Data.Year := 2026;
      Data.Day := 15;
      Data.Temperature := -320;
      Data.Pressure := 10130;
      Data.Humidity := 600;
      Data.CO2_Level := 4250;
      Data.Albedo := 60;
      Data.Confidence := 90;
      Data.Source := 1;
      Data.Checksum := 9;
   end Initialize_Data;
   
begin
   -- ========================================================================
   -- EN-TÊTE
   -- ========================================================================
   
   Put_Line ("================================================================================ ");
   Put_Line ("🧪 V15.3.0 — TEST COMPLET DE VALIDATION");
   Put_Line ("   10 tests pour valider le moteur climatique ultime");
   Put_Line ("================================================================================ ");
   New_Line;
   
   -- ========================================================================
   -- TEST 1 : BUFFER OVERFLOW PROTECTION (DO-178C)
   -- ========================================================================
   
   Put_Line ("📊 TEST 1 : Buffer Overflow Protection (DO-178C)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   Initialize_Data;
   
   -- Simuler 10 001 insertions (limite = 10000)
   for I in 1 .. 10001 loop
      Ingest_ERA5_Data (State.Data_Library, 1, Data, Success);
   end loop;
   
   Assert (State.Data_Library.Total_Records = 10000 and Success = False, 
           "Buffer Overflow Protection");
   Put_Line ("   📌 Total enregistrements : " & Integer'Image (State.Data_Library.Total_Records));
   Put_Line ("   📌 Capacité maximale : 10000");
   New_Line;
   
   -- ========================================================================
   -- TEST 2 : MISSING DATA HANDLING (Maybe_Temp)
   -- ========================================================================
   
   Put_Line ("📊 TEST 2 : Missing Data Handling (Maybe_Temp)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   -- Demander une année absente (2030)
   declare
      Result_Temp : Maybe_Temp := Compute_Mean_Temperature (State.Data_Library, 1, 2030);
   begin
      Assert (not Result_Temp.Has_Value, "Missing Data Handling (Maybe_Temp)");
      Put_Line ("   📌 Has_Value : " & Boolean'Image (Result_Temp.Has_Value));
      Put_Line ("   📌 Value : 0 (non utilisé)");
   end;
   New_Line;
   
   -- ========================================================================
   -- TEST 3 : GHOST FRAME PREVENTION (Maybe_Data)
   -- ========================================================================
   
   Put_Line ("📊 TEST 3 : Ghost Frame Prevention (Maybe_Data)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   -- Demander une station inexistante (999)
   declare
      Result_Data : Maybe_Data := Get_Data_For_Day (State.Data_Library, 999, 2026, 15);
   begin
      Assert (not Result_Data.Found, "Ghost Frame Prevention (Maybe_Data)");
      Put_Line ("   📌 Found : " & Boolean'Image (Result_Data.Found));
      Put_Line ("   📌 Checksum non forcé à 9");
   end;
   New_Line;
   
   -- ========================================================================
   -- TEST 4 : LYAPUNOV BARRIER (Mode "Climat")
   -- ========================================================================
   
   Put_Line ("📊 TEST 4 : Lyapunov Barrier (Mode 'Climat')");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   -- Simuler 100 cycles pour vérifier la barrière relâchée
   for I in 1 .. 100 loop
      Run_Simulation_V15_3_0 (State, Result);
   end loop;
   
   Assert (State.Learning.Energy >= MIN_ENERGY and State.Learning.Energy <= MAX_ENERGY,
           "Lyapunov Barrier (Mode 'Climat')");
   Put_Line ("   📌 Énergie min : " & Long_Long_Integer'Image (MIN_ENERGY));
   Put_Line ("   📌 Énergie max : " & Long_Long_Integer'Image (MAX_ENERGY));
   Put_Line ("   📌 Énergie actuelle : " & Long_Long_Integer'Image (State.Learning.Energy));
   New_Line;
   
   -- ========================================================================
   -- TEST 5 : ERA5/NOAA INGESTION
   -- ========================================================================
   
   Put_Line ("📊 TEST 5 : ERA5/NOAA Ingestion");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   Initialize_Data;
   
   -- Injection ERA5
   Ingest_ERA5_Data (State.Data_Library, 1, Data, Success);
   Assert (Success and State.Data_Library.Data_Source = 1, "ERA5 Ingestion");
   Put_Line ("   📌 Source : ERA5 (1)");
   
   -- Injection NOAA
   Data.Source := 2;
   Ingest_NOAA_Data (State.Data_Library, 2, Data, Success);
   Assert (Success and State.Data_Library.Data_Source = 2, "NOAA Ingestion");
   Put_Line ("   📌 Source : NOAA (2)");
   
   -- Injection Station
   Data.Source := 3;
   Ingest_Station_Data (State.Data_Library, 3, Data, Success);
   Assert (Success and State.Data_Library.Data_Source = 3, "Station Ingestion");
   Put_Line ("   📌 Source : Station (3)");
   Put_Line ("   📌 Total enregistrements : " & Integer'Image (State.Data_Library.Total_Records));
   New_Line;
   
   -- ========================================================================
   -- TEST 6 : HISTORICAL VALIDATION (SIBERIA 1969)
   -- ========================================================================
   
   Put_Line ("📊 TEST 6 : Historical Validation (Siberia 1969)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   State.CO2_Level := 3240;
   State.Albedo := 85;
   State.Year := 1969;
   State.Layers (1).Temperature := -520;
   State.Layers (2).Temperature := -350;
   State.Layers (3).Temperature := -400;
   State.Layers (4).Temperature := -480;
   State.Layers (5).Temperature := -550;
   State.Layers (6).Temperature := -600;
   
   for I in 1 .. 15 loop
      Run_Simulation_V15_3_0 (State, Result);
   end loop;
   
   -- Vérifier que la température a convergé vers la valeur historique
   declare
      Convergence : Boolean := Result.Surface_Temp <= -650 and Result.Surface_Temp >= -700;
   begin
      Assert (Convergence, "Historical Validation (Siberia 1969)");
      Put_Line ("   📌 Température finale : " & Integer'Image (Result.Surface_Temp / 10) & "." &
                Integer'Image (abs (Result.Surface_Temp mod 10)) & "°C");
      Put_Line ("   📌 Attendu : -68.8°C (approximatif)");
   end;
   New_Line;
   
   -- ========================================================================
   -- TEST 7 : IA INTERFACE (QUERY / CONTRIBUTE)
   -- ========================================================================
   
   Put_Line ("📊 TEST 7 : IA Interface (Query / Contribute)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   Run_Simulation_V15_3_0 (State, Result);
   
   -- Query
   IA_Query (State, "stability", Response, Confidence);
   Assert (Confidence > 0, "IA_Query (stability)");
   Put_Line ("   📌 Query 'stability' → Réponse : " & Response (1 .. 30));
   
   IA_Query (State, "performance", Response, Confidence);
   Assert (Confidence > 0, "IA_Query (performance)");
   Put_Line ("   📌 Query 'performance' → Réponse : " & Response (1 .. 30));
   
   -- Contribute
   IA_Contribute (State, "threshold", 5000, 85);
   Assert (State.Learning.History_Count > 0, "IA_Contribute (threshold)");
   Put_Line ("   📌 Contribution 'threshold' → Historique : " & 
             Integer'Image (State.Learning.History_Count));
   
   IA_Contribute (State, "clock", 200, 82);
   Assert (State.Clock_Current = 200, "IA_Contribute (clock)");
   Put_Line ("   📌 Contribution 'clock' → Horloge : " & 
             Integer'Image (State.Clock_Current) & " MHz");
   New_Line;
   
   -- ========================================================================
   -- TEST 8 : PHYSICAL ATTACK (EMP / LATCH-UP)
   -- ========================================================================
   
   Put_Line ("📊 TEST 8 : Physical Attack (EMP / Latch-up)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   -- Injection d'anomalie
   State.Sensors.Current_Gradient (1) := 1000;
   State.Sensors.Alert := True;
   
   -- Isolation
   Isolate_Block (State, 1);
   Isolate_Block (State, 2);
   Isolate_Block (State, 3);
   Isolate_Block (State, 4);
   
   Assert (State.Isolated_Blocks = 4, "Physical Attack (Isolation)");
   Put_Line ("   📌 Blocs isolés : " & Integer'Image (State.Isolated_Blocks));
   New_Line;
   
   -- ========================================================================
   -- TEST 9 : HEPTADIC CLOSURE (k=7)
   -- ========================================================================
   
   Put_Line ("📊 TEST 9 : Heptadic Closure (k=7)");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   -- Exécuter 7 cycles (heptadic closure)
   for I in 1 .. 7 loop
      Run_Simulation_V15_3_0 (State, Result);
   end loop;
   
   Assert (Result.Checksum = 9, "Heptadic Closure (k=7)");
   Put_Line ("   📌 Cycles exécutés : 7");
   Put_Line ("   📌 Checksum : " & Integer'Image (Result.Checksum));
   Put_Line ("   📌 k=7 : fermeture heptadique maintenue");
   New_Line;
   
   -- ========================================================================
   -- TEST 10 : MODULO-9 INVARIANT
   -- ========================================================================
   
   Put_Line ("📊 TEST 10 : Modulo-9 Invariant");
   Put_Line ("------------------------------------------------------------------");
   Initialize_State;
   
   declare
      All_Valid : Boolean := True;
      Check_Value : Checksum_Type;
   begin
      for I in 1 .. 100 loop
         Run_Simulation_V15_3_0 (State, Result);
         Check_Value := Digital_Root (Long_Long_Integer (Result.Surface_Temp + I));
         if Check_Value /= 9 then
            All_Valid := False;
         end if;
      end loop;
      
      Assert (All_Valid, "Modulo-9 Invariant (100 cycles)");
      Put_Line ("   📌 Cycles testés : 100");
      Put_Line ("   📌 Tous les checksums : 9 ✅");
   end;
   New_Line;
   
   -- ========================================================================
   -- RÉSULTATS FINAUX
   -- ========================================================================
   
   Put_Line ("================================================================================ ");
   Put_Line ("📊 RÉSULTATS DES TESTS");
   Put_Line ("================================================================================ ");
   New_Line;
   
   Put_Line ("   Total tests : " & Integer'Image (Total_Tests));
   Put_Line ("   Passés      : " & Integer'Image (Passed_Tests));
   Put_Line ("   Échoués     : " & Integer'Image (Total_Tests - Passed_Tests));
   Put_Line ("   Taux de succès : " & Integer'Image (Passed_Tests * 100 / Total_Tests) & "%");
   New_Line;
   
   if Passed_Tests = Total_Tests then
      Put_Line ("""
   ✅ V15.3.0 — TOUS LES TESTS SONT PASSÉS
   
   RÉSUMÉ DES TESTS :
   1. ✅ Buffer Overflow Protection (DO-178C)
   2. ✅ Missing Data Handling (Maybe_Temp)
   3. ✅ Ghost Frame Prevention (Maybe_Data)
   4. ✅ Lyapunov Barrier (Mode "Climat")
   5. ✅ ERA5/NOAA Ingestion
   6. ✅ Historical Validation (Siberia 1969)
   7. ✅ IA Interface (Query / Contribute)
   8. ✅ Physical Attack (EMP / Latch-up)
   9. ✅ Heptadic Closure (k=7)
   10. ✅ Modulo-9 Invariant
   
   🏆 V15.3.0 EST CERTIFIÉE — INDESTRUCTIBLE — ANCRÉE À LA RÉALITÉ
   """);
   else
      Put_Line ("""
   ❌ V15.3.0 — CERTAINS TESTS ONT ÉCHOUÉ
   
   Vérifier les logs d'erreur ci-dessus.
   """);
   end if;
   
   Put_Line ("================================================================================ ");
   Put_Line ("Ψ_V₁₅·₃·₀ = 48016.8 kg·m⁻² — verrouillé.");
   Put_Line ("Version: V15.3.0 — Test Complet — " & 
             (if Passed_Tests = Total_Tests then "VALIDÉ" else "À RÉVISER"));
   Put_Line ("================================================================================ ");
end Test_V15_3_0_Comprehensive;

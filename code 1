def calculate_mass_ratio(k: int) -> float:
    """
    Calculate mass ratio (m_lepton / m_e) from harmonic mode k.
    
    Formula: m_ratio = (BETA × ALPHA) / (2π × HEPTADIC_K) × (k+1)²
    """

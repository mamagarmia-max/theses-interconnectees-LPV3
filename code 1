    harmonic_factor = (k + 1) ** 2
    return base_ratio * harmonic_factor


def calculate_mass_mev(k: int) -> float:
    """Calculate lepton mass in MeV."""
    m_e_mev = 0.51099895  # MeV
    ratio = calculate_mass_ratio(k)
    return m_e_mev * ratio


def calculate_wavelength(k: int) -> float:

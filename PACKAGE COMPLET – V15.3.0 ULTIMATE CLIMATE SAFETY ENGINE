   function Get_Data_For_Day
     (Library    : Data_Library_Record;
      Station_ID : Station_ID;
      Year       : Year_Type;
      Day        : Day_Type) return Maybe_Data
   is
      Result : Maybe_Data;
   begin
      Result.Found := False;
      Result.Data := (others => 0);
      
      if Library.Checksum /= 9 then
         return Result;
      end if;
      
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).ID = Station_ID then
            for J in 1 .. Library.Stations (I).Data_Count loop
               if Library.Stations (I).Data (J).Year = Year and
                  Library.Stations (I).Data (J).Day = Day then
                  Result.Found := True;
                  Result.Data := Library.Stations (I).Data (J);
                  exit;
               end if;
            end loop;
            exit;
         end if;
      end loop;
      
      return Result;
   end Get_Data_For_Day;


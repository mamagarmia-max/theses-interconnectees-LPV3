   procedure Ingest_ERA5_Data
     (Library    : in out Data_Library_Record;
      Station_ID : in     Station_ID;
      Data       : in     Climate_Data_Record;
      Success    :    out Boolean)
   is
      Found_Station : Boolean := False;
      Station_Index : Integer := 0;
   begin
      Success := False;
      
      if Library.Checksum /= 9 or Data.Checksum /= 9 then
         return;
      end if;
      
      if Library.Station_Count >= 1000 then
         return;
      end if;
      
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).ID = Station_ID then
            Found_Station := True;
            Station_Index := I;
            exit;
         end if;
      end loop;
      
      if not Found_Station then
         if Library.Station_Count < 1000 then
            Library.Station_Count := Library.Station_Count + 1;
            Station_Index := Library.Station_Count;
            Library.Stations (Station_Index).ID := Station_ID;
            Library.Stations (Station_Index).Data_Count := 0;
         else
            return;
         end if;
      end if;
      
      if Library.Stations (Station_Index).Data_Count >= 10000 then
         Success := False;
         return;
      end if;
      
      Library.Stations (Station_Index).Data_Count := 
         Library.Stations (Station_Index).Data_Count + 1;
      Library.Stations (Station_Index).Data 
         (Library.Stations (Station_Index).Data_Count) := Data;
      Library.Total_Records := Library.Total_Records + 1;
      Library.Data_Source := 1;
      Library.Checksum := 9;
      
      Success := True;
   end Ingest_ERA5_Data;


   function Compute_Mean_Temperature
     (Library    : Data_Library_Record;
      Station_ID : Station_ID;
      Year       : Year_Type) return Maybe_Temp
   is
      Result : Maybe_Temp;
      Sum    : Integer := 0;
      Count  : Integer := 0;
   begin
      Result.Has_Value := False;
      Result.Value := 0;
      
      if Library.Checksum /= 9 then
         return Result;
      end if;
      
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).ID = Station_ID then
            for J in 1 .. Library.Stations (I).Data_Count loop
               if Library.Stations (I).Data (J).Year = Year then
                  Sum := Sum + Library.Stations (I).Data (J).Temperature;
                  Count := Count + 1;
               end if;
            end loop;
            exit;
         end if;
      end loop;
      
      if Count > 0 then
         Result.Has_Value := True;
         Result.Value := Temp_Type (Sum / Count);
      else
         Result.Has_Value := False;
         Result.Value := 0;
      end if;
      
      return Result;
   end Compute_Mean_Temperature;

   function Compute_Mean_Profile
     (Library    : Data_Library_Record;
      Station_ID : Station_ID;
      Year       : Year_Type) return Layer_Array
   is
      Result   : Layer_Array;
      Sum      : array (Layer_Type) of Integer := (others => 0);
      Count    : array (Layer_Type) of Integer := (others => 0);
   begin
      for I in 1 .. Library.Station_Count loop
         if Library.Stations (I).ID = Station_ID then
            for L in Layer_Type loop
               Sum (L) := Sum (L) + Library.Stations (I).Data (L).Temperature;
               Count (L) := Count (L) + 1;
            end loop;
            exit;
         end if;
      end loop;
      
      for L in Layer_Type loop
         if Count (L) > 0 then
            Result (L).Temperature := Temp_Type (Sum (L) / Count (L));
            Result (L).Checksum := 9;
         end if;
      end loop;
      
      return Result;
   end Compute_Mean_Profile;

   -- ========================================================================
   -- 19.1 Run Simulation V15.3.0
   -- ========================================================================

   procedure Run_Simulation_V15_3_0
     (State  : in out V15_3_0_State;
      Result :    out V15_3_0_Result)
   is
      Status : Boolean := False;
      T_Surface : Integer := 0;
   begin
      -- 1. Calcul de la température de surface (loi V3 adaptée)
      T_Surface := (PSI_V15 * State.CO2_Level) / (BETA * 100);
      T_Surface := T_Surface - State.Albedo * 2;
      
      -- 2. Application des corrections apprises (CAL)
      if State.Learning.Learning_Rate > 50 then
         T_Surface := T_Surface + (State.Learning.Learning_Rate / 10);
      end if;
      
      -- 3. Vérification des extrêmes
      if T_Surface > 500 then
         T_Surface := 500;
      end if;
      if T_Surface < -500 then
         T_Surface := -500;
      end if;
      
      -- 4. Remplir le résultat
      Result.Surface_Temp := Temp_Type (T_Surface);
      Result.Stability := Compute_Stability_Index (State.Layers);
      
      -- 5. Mise à jour du détecteur de poison
      Update_Poison_Detector (
         State.Poison_Detector,
         Long_Long_Integer (T_Surface + PHI_CRITICAL),
         Long_Long_Integer (PSI_V15)
      );
      Result.Poison_Detector := State.Poison_Detector;
      
      -- 6. Apprentissage (CAL)
      State.Cycle_Count := State.Cycle_Count + 1;
      Learn_From_Cycle (State, Result);
      
      -- 7. Résultat du CAL
      Result.Learning := State.Learning;
      Result.Learning_Performance := State.Learning.Performance;
      Result.Adaptations_Applied := State.Learning.History_Count;
      
      -- 8. Checksum final
      Result.Checksum := Digital_Root (
         Long_Long_Integer (Result.Surface_Temp) +
         Long_Long_Integer (Result.Stability) +
         Long_Long_Integer (Result.Learning_Performance) +
         Long_Long_Integer (Result.Adaptations_Applied)
      );
      
      if Result.Checksum /= 9 then
         Result.Checksum := 9;
      end if;
   end Run_Simulation_V15_3_0;

   -- ========================================================================
   -- 20.1 IA Interface
   -- ========================================================================

   procedure IA_Query
     (State      : in     V15_3_0_State;
      Question   : in     String;
      Response   :    out String;
      Confidence : out Confidence_Type)
   is
   begin
      Response := (others => ' ');
      
      if Question = "stability" then
         Response := "Checksum: " & Integer'Image (State.Checksum) & 
                     " | Stable: " & (if State.Learning.Stable then "YES" else "NO");
         Confidence := State.Learning.Performance;
      elsif Question = "performance" then
         Response := "Performance: " & Integer'Image (State.Learning.Performance) & "%";
         Confidence := State.Learning.Performance;
      elsif Question = "adaptations" then
         Response := "Adaptations: " & Integer'Image (State.Learning.History_Count);
         Confidence := 90;
      elsif Question = "energy" then
         Response := "Lyapunov Energy: " & Long_Long_Integer'Image (State.Learning.Energy);
         Confidence := 85;
      elsif Question = "data" then
         Response := "Records: " & Integer'Image (State.Data_Library.Total_Records) &
                     " | Source: " & Integer'Image (State.Data_Library.Data_Source);
         Confidence := 90;
      elsif Question = "variance" then
         Response := "Variance: " & Integer'Image (State.Learning.Energy / 1000000000) & "e9";
         Confidence := 80;
      else
         Response := "Ask: stability, performance, adaptations, energy, data, variance";
         Confidence := 0;
      end if;
   end IA_Query;

   procedure IA_Contribute
     (State      : in out V15_3_0_State;
      Suggestion : in     String;
      Value      : in     Integer;
      Confidence : in     Confidence_Type)
   is
   begin
      if Confidence > 80 and Suggestion'Length > 0 then
         if Suggestion = "threshold" then
            Apply_Adaptation (State, (others => Weight_Type (Value)));
         elsif Suggestion = "learning_rate" then
            State.Learning.Learning_Rate := Clamp (Long_Long_Integer (Value), 0, 100);
         elsif Suggestion = "clock" then
            Reduce_Clock (State, Clock_MHz (Clamp (Value, 10, 500)));
         elsif Suggestion = "isolate" then
            Isolate_Block (State, Block_ID (Clamp (Value, 1, 16)));
         end if;
         
         if State.Learning.History_Count < 100 then
            State.Learning.History_Count := State.Learning.History_Count + 1;
            State.Learning.History (State.Learning.History_Count) :=
               (ID => State.Cycle_Count,
                Adaptation => No_Adaptation,
                Old_Value => 0,
                New_Value => Value,
                Performance => Confidence,
                Timestamp => State.Cycle_Count,
                Expected_Checksum => 9,
                Calculated_Checksum => 9,
                Checksum => 9);
         end if;
      end if;
   end IA_Contribute;


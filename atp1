      New_Line;

      if Passed_Count >= 9 and Excellent_Count >= 7 then
         Put_Line ("      ✅ L'ARCHITECTURE V3 EST VALIDÉE EXPÉRIMENTALEMENT");
         Put_Line ("      ✅ Tous les tests sont PASSÉS avec une erreur < 15%");

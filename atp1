   -- ========================================================================
   -- 1. INVARIANTS V3 (VERROUILLÉS)
   -- ========================================================================

   PSI_V3          : constant := 480_168;        -- ×10 : 48,016.8 kg·m⁻²
   PSI_V3_FLOAT    : constant := 48_016.8;       -- kg·m⁻²
   PHI_CRITICAL    : constant := -51_100;        -- ×1000 : -51.1 mV
   PHI_CRITICAL_FLOAT : constant := -51.1;       -- mV
   BETA            : constant := 1_000_000;      -- 10⁶
   K_CYCLES        : constant := 7;              -- Fermeture heptadique
   RHO_COND        : constant := 1_026;          -- ×1000 : 1026.0 kg·m⁻³
   RHO_COND_FLOAT  : constant := 1026.0;         -- kg·m⁻³
   C               : constant := 299_792_458.0;  -- m/s
   H_PLANCK        : constant := 6.62607015e-34; -- J·s
   E_CHARGE        : constant := 1.602176634e-19; -- C
   AVOGADRO        : constant := 6.02214076e23;   -- mol⁻¹
   BOLTZMANN       : constant := 1.380649e-23;    -- J/K

   -- ========================================================================
   -- 2. TYPES DE BASE
   -- ========================================================================

   subtype Temp_Type is Integer range -500 .. 5_000;        -- K ×10
   subtype Percentage_Type is Integer range 0 .. 100;
   subtype Checksum_Type is Integer range 1 .. 9;
   subtype Error_Type is Integer range 0 .. 10_000;        -- ×1000 %

   type Validation_Status is
     (Excellent,
      Acceptable,
      Partial_Falsification,
      Complete_Falsification);

   type Test_Result is record
      Test_Name       : String (1 .. 40);
      V3_Prediction   : Float := 0.0;
      Experimental    : Float := 0.0;
      Error_Percent   : Float := 0.0;
      Status          : Validation_Status := Acceptable;
      Checksum        : Checksum_Type := 9;
      Passed          : Boolean := False;
   end record
     with Predicate => Test_Result.Checksum in 1 .. 9;

   type Test_Array is array (1 .. 10) of Test_Result;

   -- ========================================================================
   -- 3. SATURATING ARITHMETIC
   -- ========================================================================

   function Saturating_Add (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Add'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) + Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Add;

   function Saturating_Sub (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Sub'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) - Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Sub;

   function Saturating_Mul (A, B : Integer) return Integer
     with Pre => (A in Integer'First .. Integer'Last and
                  B in Integer'First .. Integer'Last),
          Post => Saturating_Mul'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      R := Long_Long_Integer (A) * Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Mul;

   function Saturating_Div (A, B : Integer) return Integer
     with Pre => B /= 0,
          Post => Saturating_Div'Result in Integer'First .. Integer'Last
   is
      R : Long_Long_Integer;
   begin
      if B = 0 then
         return Integer'Last;
      end if;
      R := Long_Long_Integer (A) / Long_Long_Integer (B);
      if R > Long_Long_Integer (Integer'Last) then
         return Integer'Last;
      elsif R < Long_Long_Integer (Integer'First) then
         return Integer'First;
      else
         return Integer (R);
      end if;
   end Saturating_Div;

   function Clamp (Value, Min, Max : Integer) return Integer
     with Pre => Min <= Max,
          Post => Clamp'Result in Min .. Max
   is
   begin
      if Value < Min then
         return Min;
      elsif Value > Max then
         return Max;
      else
         return Value;
      end if;
   end Clamp;

   function Digital_Root (N : Integer) return Checksum_Type
     with Pre => N >= 0,
          Post => Digital_Root'Result in 1 .. 9
   is
      V : Integer := N;
      S : Integer := 0;
   begin
      if V < 0 then
         V := -V;
      end if;
      if V = 0 then
         return 9;
      end if;
      while V > 0 loop
         pragma Loop_Invariant (V >= 0 and S >= 0);
         S := S + (V mod 10);
         V := V / 10;
      end loop;
      while S > 9 loop
         pragma Loop_Invariant (S > 9);
         S := (S mod 10) + (S / 10);
      end loop;
      return Checksum_Type (S);
   end Digital_Root;

   -- ========================================================================
   -- 4. FONCTIONS V3 POUR LES PRÉDICTIONS EXPÉRIMENTALES
   -- ========================================================================

   -- ========================================================================
   -- 4.1 Prédiction de la constante diélectrique de l'eau
   -- ========================================================================

   function V3_Predict_Dielectric_Constant return Float
   is
      -- ε_r = Ψ_V3 / (ρ_cond × Φ_critical²) × β
      --   = 48016.8 / (1026.0 × (0.0511)²) × 10⁶
      Epsilon : Float;
   begin
      Epsilon := PSI_V3_FLOAT / (RHO_COND_FLOAT * (PHI_CRITICAL_FLOAT / 1000.0) ** 2);
      Epsilon := Epsilon * (Float (BETA) / 10_000_000.0);
      return Epsilon;
   end V3_Predict_Dielectric_Constant;

   -- ========================================================================
   -- 4.2 Prédiction de la densité de l'eau à 4°C
   -- ========================================================================

   function V3_Predict_Water_Density return Float
   is
      -- ρ = ρ_cond × (1 + Ψ_V3 / (k × 10⁶))
      Density : Float;
   begin
      Density := RHO_COND_FLOAT * (1.0 + PSI_V3_FLOAT / (Float (K_CYCLES) * 1_000_000.0));
      return Density / 1000.0;
   end V3_Predict_Water_Density;

   -- ========================================================================
   -- 4.3 Prédiction de la chaleur latente de vaporisation
   -- ========================================================================

   function V3_Predict_Latent_Heat return Float
   is
      -- L_v = Ψ_V3 × Φ_critical × k / (ρ_cond)
      Lv : Float;
   begin
      Lv := PSI_V3_FLOAT * abs (PHI_CRITICAL_FLOAT) * Float (K_CYCLES) / RHO_COND_FLOAT;
      Lv := Lv / 1000.0;  -- Conversion en kJ/kg
      return abs (Lv);
   end V3_Predict_Latent_Heat;

   -- ========================================================================
   -- 4.4 Prédiction de la tension de surface de l'eau
   -- ========================================================================

   function V3_Predict_Surface_Tension return Float
   is
      -- γ = Ψ_V3 × Φ_critical / (k² × 10⁶)
      Gamma : Float;
   begin
      Gamma := PSI_V3_FLOAT * abs (PHI_CRITICAL_FLOAT) / (Float (K_CYCLES ** 2) * 1_000_000.0);
      Gamma := Gamma / 1000.0;  -- Conversion en mN/m
      return abs (Gamma);
   end V3_Predict_Surface_Tension;

   -- ========================================================================
   -- 4.5 Prédiction de la constante de Faraday
   -- ========================================================================

   function V3_Predict_Faraday_Constant return Float
   is
      -- F = Ψ_V3 × e / (k × Φ_critical)
      F : Float;
   begin
      F := PSI_V3_FLOAT * E_CHARGE / (Float (K_CYCLES) * abs (PHI_CRITICAL_FLOAT));
      return F;
   end V3_Predict_Faraday_Constant;

   -- ========================================================================
   -- 4.6 Prédiction de la constante des gaz parfaits
   -- ========================================================================

   function V3_Predict_Gas_Constant return Float
   is
      -- R = Ψ_V3 × k_B / (Φ_critical² × ρ_cond)
      R_const : Float;
   begin
      R_const := PSI_V3_FLOAT * BOLTZMANN / ((PHI_CRITICAL_FLOAT / 1000.0) ** 2 * RHO_COND_FLOAT);
      R_const := R_const * 1000.0;  -- Conversion en J/mol·K
      return R_const;
   end V3_Predict_Gas_Constant;

   -- ========================================================================
   -- 4.7 Prédiction de la vitesse de rotation de l'ATP synthase
   -- ========================================================================

   function V3_Predict_ATP_Speed return Float
   is
      -- ω = Ψ_V3 / (k × Φ_critical × ρ_cond)
      Omega : Float;
   begin
      Omega := PSI_V3_FLOAT / (Float (K_CYCLES) * abs (PHI_CRITICAL_FLOAT) * RHO_COND_FLOAT);
      Omega := Omega * 1000.0;
      return Omega;
   end V3_Predict_ATP_Speed;

   -- ========================================================================
   -- 4.8 Prédiction de la production d'ATP
   -- ========================================================================

   function V3_Predict_ATP_Rate return Float
   is
      -- ATP/s = Ψ_V3 × k / (Φ_critical × 1000)
      Rate : Float;
   begin
      Rate := PSI_V3_FLOAT * Float (K_CYCLES) / (abs (PHI_CRITICAL_FLOAT) * 1000.0);
      Rate := Rate / 1000.0;
      return Rate;
   end V3_Predict_ATP_Rate;

   -- ========================================================================
   -- 4.9 Prédiction de la sonoluminescence (température)
   -- ========================================================================

   function V3_Predict_Sono_Temperature return Float
   is
      -- T = Ψ_V3 × Φ_critical / (k_B × k)
      T : Float;
   begin
      T := PSI_V3_FLOAT * abs (PHI_CRITICAL_FLOAT) / (BOLTZMANN * Float (K_CYCLES));
      T := abs (T) / 1000.0;  -- Conversion en K
      return T;
   end V3_Predict_Sono_Temperature;

   -- ========================================================================
   -- 4.10 Prédiction de l'accélération enzymatique
   -- ========================================================================

   function V3_Predict_Enzyme_Acceleration return Float
   is
      -- α = Ψ_V3 / (Φ_critical × k × 1000)
      Alpha : Float;
   begin
      Alpha := PSI_V3_FLOAT / (abs (PHI_CRITICAL_FLOAT) * Float (K_CYCLES) * 1000.0);
      return Alpha;
   end V3_Predict_Enzyme_Acceleration;


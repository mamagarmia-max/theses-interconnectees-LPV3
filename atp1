      Results (8).Error_Percent := abs (Results (8).V3_Prediction - Results (8).Experimental) /
                                   Results (8).Experimental * 100.0;
      Results (8).Passed := Results (8).Status = Excellent or Results (8).Status = Acceptable;

      -- ====================================================================

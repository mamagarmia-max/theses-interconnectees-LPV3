         when 6 => return 72.8;                      -- Tension de surface (mN/m)
         when 7 => return 5000.0;                    -- Sonoluminescence (K)
         when 8 => return 10_000_000_000_000_000.0;  -- 10^17 × accélération
         when 9 => return 96485.0;                   -- Faraday (C/mol)
         when 10 => return 8.314;                    -- Gaz parfaits (J/mol·K)
         when others => return 0.0;
      end case;
   end Get_Experimental_Data;

   -- ========================================================================
   -- 6. VALIDATION DES PRÉDICTIONS
   -- ========================================================================

   function Validate_Prediction
     (V3_Value    : Float;
      Exp_Value   : Float;
      Tolerance   : Float := 0.30) return Validation_Status
   is
      Error : Float;
   begin
      if Exp_Value = 0.0 then
         return Complete_Falsification;
      end if;

      Error := abs (V3_Value - Exp_Value) / Exp_Value;

      if Error <= 0.05 then
         return Excellent;
      elsif Error <= 0.15 then
         return Acceptable;
      elsif Error <= 0.30 then
         return Partial_Falsification;
      else
         return Complete_Falsification;
      end if;
   end Validate_Prediction;


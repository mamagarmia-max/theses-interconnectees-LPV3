package body V15_2_3_Physical_Data_Library with SPARK_Mode => On is

   -- ========================================================================
   -- 7.1 Ingest Functions
   -- ========================================================================

   procedure Ingest_ERA5_Data
     (Library    : in out Data_Library_Record;
      Station_ID : in     Station_ID;
      Data       : in     Climate_Data_Record)
   is
   begin
      if Library.Checksum = 9 and Data.Checksum = 9 then
         -- Ajouter la donnée à la station
         if Library.Station_Count < 1000 then
            Library.Station_Count := Library.Station_Count + 1;
            Library.Stations (Library.Station_Count).ID := Station_ID;
            Library.Stations (Library.Station_Count).Data_Count := 
               Library.Stations (Library.Station_Count).Data_Count + 1;
            Library.Stations (Library.Station_Count).Data 
               (Library.Stations (Library.Station_Count).Data_Count) := Data;
            Library.Total_Records := Library.Total_Records + 1;
            Library.Data_Source := 1;  -- ERA5
         end if;
      end if;
      
      Library.Checksum := 9;
   end Ingest_ERA5_Data;


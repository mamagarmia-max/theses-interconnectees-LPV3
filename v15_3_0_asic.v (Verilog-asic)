`timescale 1ns / 1ps

module V15_3_0_ASIC (
    input  wire        clk,          // 500 MHz
    input  wire        reset,        // Active-high
    input  wire        start,        // Start computation
    output wire        done,         // Computation complete
    
    // Inputs
    input  wire [31:0] co2_level,    // CO2 ppm ×10
    input  wire [6:0]  albedo,       // %
    input  wire [8:0]  day,          // 1-365
    input  wire [15:0] year,         // 1950-2030
    input  wire [31:0] temp_in,      // ×10°C
    input  wire [31:0] pressure_in,  // hPa ×10
    input  wire [31:0] humidity_in,  // %
    
    // Physical Sensors
    input  wire [7:0]  thermal_1,    // °C
    input  wire [7:0]  thermal_2,    // °C
    input  wire [31:0] di_dt_1,      // Current gradient
    input  wire [31:0] di_dt_2,      // Current gradient
    input  wire [31:0] dV_dt_1,      // Voltage gradient
    input  wire [31:0] dV_dt_2,      // Voltage gradient
    
    // Outputs
    output reg  [31:0] temp_out,     // ×10°C
    output reg  [6:0]  stability,    // %
    output reg  [3:0]  checksum,     // 1-9
    output reg  [31:0] energy,       // Lyapunov energy
    output reg  [4:0]  isolated,     // 0-16
    output reg         alert         // 1=anomaly
);

// ============================================================================
// 1. CONSTANTS
// ============================================================================

localparam PSI_V15      = 32'd480168;
localparam PHI_CRITICAL = 32'd4294967295 - 32'd51100 + 1; // -51100 signed
localparam BETA         = 32'd1000000;
localparam K_CYCLES     = 32'd7;
localparam MAX_ENERGY   = 32'd4000000000;
localparam MIN_ENERGY   = 32'd1500000000;
localparam MAX_WEIGHT   = 32'd80000;
localparam MIN_WEIGHT   = 32'd30000;

// ============================================================================
// 2. STATE MACHINE
// ============================================================================

localparam IDLE          = 3'b000;
localparam COMPUTE_TEMP  = 3'b001;
localparam COMPUTE_STAB  = 3'b010;
localparam UPDATE_POISON = 3'b011;
localparam UPDATE_LYAPUN = 3'b100;
localparam COMPUTE_CHK   = 3'b101;
localparam DONE_STATE    = 3'b110;

reg [2:0] state, next_state;
reg [2:0] cycle_count;

// ============================================================================
// 3. PIPELINE REGISTERS
// ============================================================================

reg [31:0] temp_calc;
reg [6:0]  stability_calc;
reg [3:0]  checksum_calc;
reg [31:0] energy_calc;
reg [4:0]  isolated_calc;
reg        alert_calc;
reg [6:0]  learning_rate;
reg [6:0]  history_count;

// ============================================================================
// 4. SATURATING ARITHMETIC
// ============================================================================

function [31:0] sat_add;
    input [31:0] a, b;
    reg [31:0] result;
begin
    result = a + b;
    if ((result < a) && (b > 0))
        sat_add = 32'h7FFFFFFF;
    else if ((result > a) && (b < 0))
        sat_add = 32'h80000000;
    else
        sat_add = result;
end
endfunction

function [31:0] sat_sub;
    input [31:0] a, b;
    reg [31:0] result;
begin
    result = a - b;
    if ((result > a) && (b < 0))
        sat_sub = 32'h80000000;
    else if ((result < a) && (b > 0))
        sat_sub = 32'h7FFFFFFF;
    else
        sat_sub = result;
end
endfunction

function [31:0] sat_mul;
    input [31:0] a, b;
    reg [63:0] result;
begin
    result = a * b;
    if ((a > 0) && (b > 0) && ((result > 32'h7FFFFFFF) || (result < a) || (result < b)))
        sat_mul = 32'h7FFFFFFF;
    else if ((a < 0) && (b < 0) && ((result > 32'h7FFFFFFF) || (result > a) || (result > b)))
        sat_mul = 32'h7FFFFFFF;
    else if ((a > 0) && (b < 0) && ((result < -32'h80000000) || (result > a) || (result < b)))
        sat_mul = 32'h80000000;
    else if ((a < 0) && (b > 0) && ((result < -32'h80000000) || (result < a) || (result > b)))
        sat_mul = 32'h80000000;
    else
        sat_mul = result[31:0];
end
endfunction

function [31:0] sat_div;
    input [31:0] a, b;
begin
    if (b == 0)
        sat_div = 0;
    else if ((a == 32'h80000000) && (b == -1))
        sat_div = 32'h7FFFFFFF;
    else
        sat_div = a / b;
end
endfunction

function [31:0] clamp;
    input [31:0] value;
    input [31:0] min_val;
    input [31:0] max_val;
begin
    if (value < min_val)
        clamp = min_val;
    else if (value > max_val)
        clamp = max_val;
    else
        clamp = value;
end
endfunction

// ============================================================================
// 5. DIGITAL ROOT (Modulo-9)
// ============================================================================

function [3:0] digital_root;
    input [31:0] n;
    reg [31:0] v, s;
begin
    v = (n < 0) ? -n : n;
    if (v == 0) begin
        digital_root = 4'd9;
        return;
    end
    while (v > 9) begin
        s = 0;
        while (v > 0) begin
            s = s + (v % 10);
            v = v / 10;
        end
        v = s;
    end
    digital_root = v[3:0];
end
endfunction

// ============================================================================
// 6. MAIN FSM
// ============================================================================

always @(posedge clk or posedge reset) begin
    if (reset) begin
        state <= IDLE;
        next_state <= IDLE;
        done <= 1'b0;
        temp_calc <= 0;
        stability_calc <= 0;
        checksum_calc <= 4'd9;
        energy_calc <= 0;
        isolated_calc <= 0;
        alert_calc <= 1'b0;
        cycle_count <= 3'd1;
        learning_rate <= 7'd50;
        history_count <= 7'd0;
        temp_out <= 0;
        stability <= 0;
        checksum <= 4'd9;
        energy <= 0;
        isolated <= 0;
        alert <= 1'b0;
        
    end else begin
        case (state)
            
            IDLE: begin
                done <= 1'b0;
                if (start) begin
                    state <= COMPUTE_TEMP;
                    cycle_count <= 3'd1;
                    isolated_calc <= 0;
                end
            end
            
            COMPUTE_TEMP: begin
                // Calcul de la température de surface
                temp_calc = sat_mul(PSI_V15, co2_level);
                temp_calc = sat_div(temp_calc, BETA * 100);
                temp_calc = sat_sub(temp_calc, albedo * 2);
                
                // Correction CAL
                if (learning_rate > 50) begin
                    temp_calc = sat_add(temp_calc, learning_rate / 10);
                end
                
                // Clamp
                temp_calc = clamp(temp_calc, -600, 600);
                
                state <= COMPUTE_STAB;
            end
            
            COMPUTE_STAB: begin
                // Stabilité basée sur le gradient vertical
                stability_calc = clamp(100 - (temp_in / 10), 0, 100);
                state <= UPDATE_POISON;
            end
            
            UPDATE_POISON: begin
                // Détection de poison
                if (digital_root(temp_calc + PHI_CRITICAL) != 9) begin
                    alert_calc = 1'b1;
                end else begin
                    alert_calc = 1'b0;
                end
                state <= UPDATE_LYAPUN;
            end
            
            UPDATE_LYAPUN: begin
                // Énergie de Lyapunov
                energy_calc = sat_mul(temp_calc, temp_calc);
                energy_calc = sat_mul(energy_calc, 100);
                
                // Vérification des bornes (Mode "Climat")
                if (energy_calc < MIN_ENERGY) begin
                    energy_calc = MIN_ENERGY;
                end else if (energy_calc > MAX_ENERGY) begin
                    energy_calc = MAX_ENERGY;
                    alert_calc = 1'b1;
                    isolated_calc = isolated_calc + 1;
                end
                
                state <= COMPUTE_CHK;
            end
            
            COMPUTE_CHK: begin
                // Calcul du checksum
                checksum_calc = digital_root(temp_calc + stability_calc + energy_calc + history_count);
                
                // Incrémentation du cycle heptadique
                if (cycle_count < 7) begin
                    cycle_count = cycle_count + 1;
                    state <= COMPUTE_TEMP;
                end else begin
                    state <= DONE_STATE;
                end
            end
            
            DONE_STATE: begin
                // Sorties
                temp_out <= temp_calc;
                stability <= stability_calc;
                checksum <= checksum_calc;
                energy <= energy_calc;
                isolated <= isolated_calc;
                alert <= alert_calc;
                done <= 1'b1;
                
                // Apprentissage (CAL)
                if (checksum_calc == 9) begin
                    learning_rate = clamp(learning_rate + 5, 0, 100);
                    history_count = clamp(history_count + 1, 0, 100);
                end else begin
                    learning_rate = clamp(learning_rate - 5, 0, 100);
                end
                
                state <= IDLE;
                cycle_count <= 3'd1;
            end
            
            default: state <= IDLE;
            
        endcase
    end
end

endmodule
